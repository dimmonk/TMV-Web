---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewsScreen from '../components/mobile/ReviewsScreen.astro';
import Reviews from '../components/Reviews.astro';
import { seo, links, url } from '../data/site';
---
<BaseLayout title={seo.reviews.title} description={seo.reviews.description} active="" mobileTab="more" appHeader="back" appTitle="Reviews">
  <div class="mapp" data-chrome="app"><ReviewsScreen /></div>

  <div data-chrome="site">
  <section class="pagehero">
    <div class="pagehero-glow"></div>
    <div class="container pagehero-inner">
      <div class="pagehero-kicker"><span class="rule"></span>4.6★ · 449 Google reviews</div>
      <h1 class="pagehero-title">Loved by the community.</h1>
      <p class="pagehero-lead">Parents, open-gym members, first-timers and athletes — here's what Toronto says about training at The Monkey Vault.</p>
      <div style="margin-top:26px; display:flex; gap:12px; flex-wrap:wrap">
        <a href={links.googleReviews} target="_blank" rel="noopener" class="btn btn-primary">Read on Google <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
        <a href={url('get-started')} class="btn btn-ghost-light">Start your first visit</a>
      </div>
    </div>
  </section>

  <Reviews
    eyebrow="What people say"
    heading="Real words from real members"
    subhead="A snapshot of the reviews families and athletes leave us on Google."
  />
  </div>
</BaseLayout>

<style>
</style>
