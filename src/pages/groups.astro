---
/**
 * Groups & teams — schools, corporate, youth and sports organizations.
 *
 * Lifted out of /events, where it was a #groups section. It is a revenue stream
 * in its own right and deserves an indexable URL and a direct link, but the
 * primary nav is deliberately capped at six, so it reaches people through the
 * More sheet on mobile and the footer's Explore column on desktop — both of
 * which render from src/data/explore.ts.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { seo, cat } from '../data/site';
import { groupTiers, eventPricing } from '../data/events';
import { sq } from '../data/square-links';
---
<BaseLayout
  title={seo.groups.title}
  description={seo.groups.description}
  active="events"
  mobileTab="more"
  appHeader="back"
  appTitle="Groups & Teams"
>
  <section class="pagehero" style={`--party:${cat.groups}`}>
    <div class="pagehero-glow"></div>
    <div class="container herog">
      <div class="pagehero-kicker"><span class="rule"></span>Schools · Teams · Corporate</div>
      <h1 class="herog-title">Bring your whole group.</h1>
      <p class="herog-lead">A fun, active way to build teamwork, confidence and skills — guided by our coaches, under one big roof. From school field trips to corporate team-building.</p>
      <div class="herog-actions">
        <a href={sq.book.groupEvents} target="_blank" rel="noopener" class="btn btn-primary">Plan an event <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
        <a href={sq.book.earlyGymAccess} target="_blank" rel="noopener" class="btn btn-ghost-light">Reserve early access</a>
      </div>
    </div>
  </section>

  <section class="section container" style="padding-bottom:80px">
    <div style="margin-bottom:34px"><SectionHeader num="01" eyebrow="Group events" title="Two ways to bring a group" description="Pick the format that fits your crew — a guided group event, or the whole gym to yourselves before we open." color={cat.groups} /></div>

    <div class="ev-groups">
      <div class="ev-gcard">
        <div class="ev-ghead"><span class="ev-gic" style="background:color-mix(in srgb,#8c52ff 14%,#fff)"><i class="bi bi-people-fill" style="color:#8c52ff" aria-hidden="true"></i></span><div><div class="ev-geyebrow" style="color:#8c52ff">Group Events</div><div class="ev-gtitle">Field trips &amp; team-building</div></div></div>
        <p class="ev-gdesc">Two hours total — an hour of guided activities, then an hour of open gym. Intro parkour workshops, team-building obstacle courses, games and skill development for all levels. Great for field trips, teams and community events.</p>
        <div class="ev-gfoot">
          <div class="ev-glabel">Price per participant</div>
          <div class="ev-tiers">{groupTiers.map((t) => <div class="ev-tier"><span>{t.label}</span><span class="ev-tier-v">{t.val}</span></div>)}</div>
          <p class="ev-gfine">Minimum 10 participants; smaller groups pay the $300 base. Final total is calculated on event day from the final headcount.</p>
          <a href={sq.book.groupEvents} target="_blank" rel="noopener" class="btn btn-dark">Plan an event <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
        </div>
      </div>
      <div class="ev-gcard">
        <div class="ev-ghead"><span class="ev-gic" style="background:color-mix(in srgb,#2e9e4f 14%,#fff)"><i class="bi bi-sunrise" style="color:#2e9e4f" aria-hidden="true"></i></span><div><div class="ev-geyebrow" style="color:#2e9e4f">Early Gym Access</div><div class="ev-gtitle">The gym, all to yourself</div></div></div>
        <p class="ev-gdesc">Reserve The Monkey Vault before we open at 11 AM for exclusive access. Perfect for small groups or focused training with no crowds.</p>
        <div class="ev-gfoot2">
          <div><div class="ev-big2">{eventPricing.earlyAccessFrom}</div><div class="ev-sub">+ $25 / person open gym</div></div>
          <a href={sq.book.earlyGymAccess} target="_blank" rel="noopener" class="btn btn-dark">Reserve time <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
        </div>
      </div>
    </div>
    <p class="ev-note">Booking &amp; cancellation: your card isn't charged at booking — payment is made in person based on final headcount. A fee applies for cancellations within 24 hours or no-shows.</p>
  </section>
</BaseLayout>

<style>
  .pagehero { background: var(--ink); color: #fff; position: relative; overflow: hidden; }
  .pagehero-glow { position: absolute; inset: 0; background: radial-gradient(680px 360px at 90% -12%, color-mix(in srgb, var(--party) 13%, transparent), transparent 70%); }
  .pagehero-kicker { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--party); margin-bottom: 20px; }
  .pagehero-kicker .rule { width: 22px; height: 2px; background: var(--party); }
  .herog { padding-block: 56px 60px; position: relative; }
  .herog-title { font: 800 clamp(34px,8.5vw,52px)/1 var(--font-display); letter-spacing: -.02em; margin-bottom: 16px; }
  .herog-lead { font: 400 16px/1.55 var(--font-body); color: rgba(255,255,255,.72); max-width: 560px; margin-bottom: 28px; }
  .herog-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }

  .ev-groups { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .ev-gcard { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 32px 34px; box-shadow: var(--shadow-sm); }
  .ev-ghead { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .ev-gic { flex: none; width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 21px; }
  .ev-geyebrow { font: 700 11px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; }
  .ev-gtitle { font: 800 21px/1.1 var(--font-display); letter-spacing: -.01em; margin-top: 5px; }
  .ev-gdesc { font: 400 13px/1.5 var(--font-body); color: var(--muted); margin: 0 0 18px; }
  .ev-gfoot { margin-top: auto; padding-top: 18px; border-top: 1px solid var(--line-soft); }
  .ev-glabel { font: 700 11px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; color: var(--muted-3); margin-bottom: 12px; }
  .ev-tiers { display: flex; flex-direction: column; margin-bottom: 14px; }
  .ev-tier { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--line-soft); font: 600 14px/1 var(--font-body); color: var(--text-2); }
  .ev-tier:last-child { border-bottom: 0; }
  .ev-tier-v { font: 800 13.5px/1 var(--font-display); color: var(--ink); }
  .ev-gfine { font: 400 12.5px/1.5 var(--font-body); color: var(--muted-3); margin: 0 0 18px; }
  .ev-gfoot2 { margin-top: auto; padding-top: 18px; border-top: 1px solid var(--line-soft); display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; }
  .ev-big2 { font: 800 22px/1 var(--font-display); color: var(--ink); }
  .ev-sub { font: 400 12.5px/1.4 var(--font-body); color: var(--muted-3); margin-top: 4px; }
  .ev-note { font: 400 12.5px/1.5 var(--font-body); color: var(--muted-3); max-width: 760px; margin: 22px auto 0; text-align: center; }

  @media (max-width: 900px) {
    .ev-groups { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .herog { padding-block: 40px 44px; }
    .ev-gcard { padding: 24px 20px; }
    .ev-gfoot2 { flex-direction: column; align-items: stretch; gap: 14px; }
  }
</style>
