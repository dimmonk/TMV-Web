---
/**
 * The app-style mobile experience (/TMV-Web/m/). Rebuilt from the old
 * design-tool runtime (public/m/mobile.html) as native Astro so it reuses the
 * SAME components + SSOT data as the desktop site: OfferingCard, BookingCard,
 * ClassCard, and data/site + square-links. All 13 screens are server-rendered
 * and shown/hidden by a small client router keyed off the URL hash; the two
 * live screens (schedule, pricing) fetch from the shared src/lib modules.
 */
import MobileLayout from '../../layouts/MobileLayout.astro';
import MobileHero from '../../components/MobileHero.astro';
import OfferingCard from '../../components/OfferingCard.astro';
import BookingCard from '../../components/BookingCard.astro';
import ClassCard from '../../components/ClassCard.astro';
import { offerings } from '../../data/offerings';
import { firstSessionOptions } from '../../data/first-session';
import { camps } from '../../data/camps';
import { groupTiers, eventPricing } from '../../data/events';
import { coreClasses, specializedClasses, partnershipClasses } from '../../data/classes';
import type { ClassItem } from '../../data/classes';
import { cat, links, site, social, hours, reviews, seo, url } from '../../data/site';
import { storeProducts } from '../../data/store';
import { sq } from '../../data/square-links';
import { forSurface } from '../../data/surface';

// Resolve a class's action href for the mobile app. Schedule-linked classes go
// to the mobile Schedule screen; classes whose desktop page has no mobile
// equivalent fall back to booking; partner classes keep their external link.
const classHref = (c: ClassItem): string => {
  if ('external' in c.link) return c.link.external;
  if (c.link.screen === 'schedule') return '#schedule';
  if (c.link.screen === 'private-lessons') return sq.book.privateLesson;
  return sq.athletic.membership; // athletic-program
};

// Compact size props for the mobile OfferingCard variant.
const OC = {
  height: '360px', mediaRatio: '16/9', titleSize: '17px', descSize: '12.5px',
  backTitleSize: '18px', padFront: '16px 16px 18px', padBack: '20px 20px 18px',
};

// ---- Book ----
const dropIns = [
  { title: 'Open Gym', color: cat.openGym, desc: 'Any day, stay as long as you like — 11 AM to 10 PM. Day pass from $25.', sub: 'Just sign the waiver and jump in.' },
  { title: 'Group Classes', color: cat.classes, desc: 'Recreational, Flips, Calisthenics, Tricking, Gymnastics & more.', sub: 'Show up at class time — see the Schedule tab for times.' },
];
const bookOptions = [
  { color: cat.private, bookingTag: 'By appointment', title: 'Private Lesson', description: '1-on-1 coaching built around your goals and pace.', pills: 'All ages | Your coach or ours', price: 'From $85', priceNote: '5-packs available', actionLabel: 'Book', href: sq.book.privateLesson },
  { color: cat.camps, bookingTag: 'Register', title: 'Weekly Camps', description: 'A full week of parkour over school breaks.', pills: 'Ages 5+ | Mon–Fri', price: '$350 / week', priceNote: 'late pickup to 4 PM', actionLabel: 'See dates', href: sq.camps.weeklyCamps },
  { color: cat.parties, bookingTag: 'By appointment', title: 'Birthday Party', description: 'A coached session, a private room and free play.', pills: 'Ages 5+ | Private room', price: 'From $350', priceNote: 'up to 15 kids', actionLabel: 'Enquire', href: sq.book.fullBirthday },
];

// ---- Store (hrefs from the Square link SSOT) ----

// ---- Get Started ----
// first-session options come from data/first-session.ts (shared with desktop)
const mFsHref: Record<string, string> = { intro: sq.getStarted.introduction, private: sq.getStarted.privateClass, group: '#schedule', opengym: '#train' };
const mFsTarget = (key: string): '_blank' | '_self' => (key === 'intro' || key === 'private' ? '_blank' : '_self');
const gsBring = [
  'Comfortable clothes you can move in.',
  'A clean pair of indoor shoes (or train barefoot).',
  'A water bottle to stay hydrated.',
];
const gsArrive = [
  { n: '1', text: 'Arrive 15 minutes early to sign in.' },
  { n: '2', text: 'Stash your things in a locker (bring a lock).' },
  { n: '3', text: 'Read the Rules poster at the entrance.' },
  { n: '4', text: 'Join the group warm-up on the spring floor.' },
];
const gsFaqs = [
  { q: 'Do I need any experience?', a: 'None at all — most first-timers have never done parkour. A coach starts you with the basics at your own pace.' },
  { q: 'Do I have to book?', a: 'Open Gym and Group Classes need no reservation — just show up. Introduction and Private classes are reserved ahead.' },
  { q: 'Is it safe for kids?', a: 'Padded floors, a foam pit and trained coaches who scale every skill. Ages 3 and up welcome.' },
];

// ---- Camps ----
const campDay = [
  { time: '8:45–9:00', label: 'Arrival & check-in' },
  { time: '9:00–11:00', label: 'Activities' },
  { time: '11:00–11:30', label: 'Lunch' },
  { time: '11:30–12:00', label: 'Free time' },
  { time: '12:00–2:00', label: 'Activities' },
  { time: '2:00–4:00', label: 'Late pick-up (optional)' },
];

// ---- About ----
const aboutGallery = ['gym-01.jpg', 'gym-02.jpg', 'gym-03.jpg', 'gym-04.jpg', 'gym-05.jpg', 'gym-06.jpg'].map((f) => url(`assets/${f}`));
const aboutFacility = [
  { icon: 'bi-grid-3x3-gap-fill', title: 'Gymnastics floor', body: 'Sprung floor and tumbling space for flips and clean form.' },
  { icon: 'bi-box-seam', title: 'Foam pit & mats', body: 'Land big tricks safely — padded throughout.' },
  { icon: 'bi-bricks', title: 'Obstacles & rigs', body: 'Walls, bars, rails and vaults for parkour.' },
  { icon: 'bi-heart-pulse', title: 'Weight training', body: 'A strength-and-conditioning section too.' },
];

// ---- Groups ----
const eventFaqs = [
  { q: 'When do I pay?', a: 'Nothing upfront — the card on file is only for the cancellation policy. You pay in person on the day, based on final headcount.' },
  { q: 'Weekend slots full?', a: 'The availability online is all we have. Smaller groups can book a Mini party (3+ kids, $30 each).' },
  { q: 'Can we bring food?', a: 'Yes — cake, pizza, snacks, drinks, no fees. We provide the room, tables and a fridge/freezer.' },
  { q: 'Can we extend open gym?', a: 'Ask your instructor — $5 per participant for an extra hour (room time still ends at 2 hours).' },
];

// ---- Reviews (from the SSOT) ----
const reviewItems = reviews.items.map((r) => ({ name: r.name, role: r.context, text: r.quote }));

// ---- config passed to the client router / live-data script ----
const clientConfig = {
  cat,
  scheduleApi: 'https://us-central1-tmv-management.cloudfunctions.net/getPublicSchedule',
  priceApi: 'https://us-central1-tmv-management.cloudfunctions.net/getPublicPriceList',
};
---
<MobileLayout title={seo.home.title} description={seo.home.description}>
  <div class="m-app">
    <div class="m-safe"></div>

    <!-- sticky header -->
    <header class="m-head">
      <div class="m-head-main" data-head="main">
        <div class="m-brand">
          <img src={url('assets/tmvlogo.png')} alt="" />
          <span>The Monkey Vault</span>
        </div>
        <span class="m-status" data-status><span class="m-status-dot"></span><span class="m-status-label">Open now</span></span>
      </div>
      <div class="m-head-sub" data-head="sub" hidden>
        <button type="button" class="m-back" data-back><i class="bi bi-chevron-left" aria-hidden="true"></i><span data-subtitle>Back</span></button>
        <span class="m-status" data-status><span class="m-status-dot"></span><span class="m-status-label">Open now</span></span>
      </div>
    </header>

    <div class="app-scroll m-scroll">

      <!-- ============ HOME ============ -->
      <section data-screen="home" class="m-screen">
        <div class="m-pad">
          <div class="m-home-hero">
            <div class="mh-glow"></div>
            <div class="m-home-hero-inner">
              <div class="mh-eyebrow"><span class="mh-rule"></span>Parkour &amp; movement · Toronto</div>
              <h2 class="m-home-title">Move better.<br>Have more fun.</h2>
              <p class="m-home-lead">Drop in to play, book a class, train like an athlete, or throw a party — every age, every level, under one big roof.</p>
              <div class="m-home-stats">
                <div class="m-home-stat"><div class="m-home-statv">$25</div><div class="m-home-statl">day pass</div></div>
                <div class="m-home-stat mid"><div class="m-home-statv">7 days</div><div class="m-home-statl">11a – 10p</div></div>
                <div class="m-home-stat end"><div class="m-home-statv">Ages 3+</div><div class="m-home-statl">all levels</div></div>
              </div>
            </div>
          </div>

          <button type="button" class="rowpress m-newhere" data-goto="#getstarted">
            <span class="m-newhere-ic"><i class="bi bi-flag-fill" aria-hidden="true"></i></span>
            <div class="m-newhere-txt"><div class="m-newhere-t">New here?</div><div class="m-newhere-s">Start with the 3-step first-visit guide.</div></div>
            <i class="bi bi-chevron-right m-chev" aria-hidden="true"></i>
          </button>

          <h3 class="m-h3">Three ways to get moving</h3>
          <p class="m-sub">Pick where to start.</p>
          <div class="m-stack" style="margin-bottom:30px">
            {offerings.map((o) => <OfferingCard {...o} href={`#${o.key}`} {...OC} />)}
          </div>

          <div class="m-rowhead">
            <h3 class="m-h3" style="margin:0">Booking now</h3>
            <button type="button" class="m-alllink" data-goto="#book">All <i class="bi bi-arrow-right" style={`color:${cat.camps}`} aria-hidden="true"></i></button>
          </div>
          <div style="margin-bottom:30px">
            <BookingCard color={cat.camps} duration="9–2 daily" bookingTag="Register" title="Summer Camps 2026" description="A full week of parkour over the break — skills, flips, games and friends." pills="Ages 5+ | Mon–Fri | All levels" price="$350 / week" priceNote="booking now" actionLabel="Reserve" href={sq.home.summerCamps} target="_blank" />
          </div>

          <div class="m-revstrip">
            <div class="m-revstrip-top">
              <span class="m-revstrip-num">{reviews.ratingValue}</span>
              <div>
                <div class="m-revstrip-stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i></div>
                <div class="m-revstrip-count">{reviews.ratingCount.replace(/^Based on /, '')}</div>
              </div>
            </div>
            <p class="m-revstrip-quote">“{reviewItems[0].text.split('. ').slice(0, 2).join('. ')}.”</p>
          </div>
        </div>
      </section>

      <!-- ============ TRAIN ============ -->
      <section data-screen="train" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Train" title="Every way to move" desc="Open gym, coached classes and the Athletic Program — every age, every level, one big roof." stats={[{ v: '4', l: 'ways to train' }, { v: 'Ages 3+', l: 'all levels' }, { v: '7 days', l: 'a week' }]} />
          <div style="height:18px"></div>
          <BookingCard color={cat.openGym} bookingTag="Drop-in" duration="No limit" title="Open Gym" description="Drop in any day and stay as long as you like. Sign the waiver, grab a pass, the floor is yours." pills="All ages | 11 AM – 10 PM | No booking" price="From $25" priceNote="day pass" actionLabel="Get a pass" href={links.store} target="_blank" />

          <div class="m-rowhead" style="margin:26px 0 6px">
            <h3 class="m-h3" style="margin:0">Core programs</h3>
            <button type="button" class="m-alllink" data-goto="#schedule">Times <i class="bi bi-calendar3" style={`color:${cat.classes}`} aria-hidden="true"></i></button>
          </div>
          <p class="m-sub" style="margin-bottom:14px">Tap a card to flip it for level, ages, schedule &amp; price.</p>
          <div class="m-stack" style="margin-bottom:30px">
            {coreClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}
          </div>

          <h3 class="m-h3">Specialized classes</h3>
          <p class="m-sub" style="margin-bottom:14px">Focused, skill-specific sessions for one discipline.</p>
          <div class="m-stack" style="margin-bottom:30px">
            {specializedClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}
          </div>

          <h3 class="m-h3">Partnerships</h3>
          <p class="m-sub" style="margin-bottom:14px">Run by trusted partner coaches who share our space.</p>
          <div class="m-stack">
            {partnershipClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}
          </div>
        </div>
      </section>

      <!-- ============ BOOK ============ -->
      <section data-screen="book" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Book" title="Reserve your spot" desc="Drop by with no booking, or reserve a private lesson, camp or party online." />
          <div style="height:18px"></div>
          <div class="m-label">No booking — just show up</div>
          <div class="m-stack" style="margin-bottom:28px">
            {dropIns.map((d) => (
              <div class="m-dropin">
                <span class="m-dropin-strip" style={`background:${d.color}`}></span>
                <div class="m-dropin-body">
                  <div class="m-dropin-head">
                    <span class="m-dropin-tag" style={`background:${d.color}`}><i class="bi bi-door-open-fill" aria-hidden="true"></i>Drop-in</span>
                    <h3 class="m-dropin-title">{d.title}</h3>
                  </div>
                  <p class="m-dropin-desc">{d.desc}</p>
                  <div class="m-dropin-cta" style={`background:color-mix(in srgb,${d.color} 10%,#fff); border-color:color-mix(in srgb,${d.color} 22%,#fff)`}>
                    <i class="bi bi-check2-circle" style={`color:${d.color}`} aria-hidden="true"></i>
                    <div>
                      <div class="m-dropin-ctat" style={`color:color-mix(in srgb,${d.color} 58%,#000)`}>No booking required</div>
                      <div class="m-dropin-ctas">{d.sub}</div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="m-label">Reserve online</div>
          <p class="m-sub" style="margin-bottom:14px">Each opens its exact page on Square.</p>
          <div class="m-stack">
            {bookOptions.map((b) => <BookingCard {...b} target="_blank" />)}
          </div>
        </div>
      </section>

      <!-- ============ SCHEDULE ============ -->
      <section data-screen="schedule" class="m-screen" hidden>
        <div style="padding:18px 0 28px">
          <div style="padding:0 18px 18px"><MobileHero eyebrow="Schedule" title="This week at the gym" desc="Live class times you can filter by age — the same schedule our front desk runs from." /></div>
          <div class="app-scroll m-chips" data-sched-chips></div>
          <div class="m-pad-x" data-sched-body></div>
        </div>
      </section>

      <!-- ============ MORE ============ -->
      <section data-screen="more" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="More" title="Everything else" desc="Pricing, store, camps, parties, groups — and the details for planning your visit." />
          <div style="height:18px"></div>
          <div class="m-tiles">
            <button type="button" class="tile m-tile" data-goto="#pricing"><span class="m-tile-ic" style={`background:color-mix(in srgb,${cat.openGym} 14%,#fff)`}><i class="bi bi-tag-fill" style={`color:${cat.openGym}`}></i></span><div><div class="m-tile-t">Pricing</div><div class="m-tile-s">Passes, packs &amp; memberships</div></div></button>
            <button type="button" class="tile m-tile" data-goto="#store"><span class="m-tile-ic" style="background:#eceae4"><i class="bi bi-bag-fill" style="color:#211f1b"></i></span><div><div class="m-tile-t">Store</div><div class="m-tile-s">Buy passes &amp; memberships</div></div></button>
            <button type="button" class="tile m-tile" data-goto="#camps"><span class="m-tile-ic" style={`background:color-mix(in srgb,${cat.camps} 14%,#fff)`}><i class="bi bi-sun-fill" style={`color:${cat.camps}`}></i></span><div><div class="m-tile-t">Camps</div><div class="m-tile-s">School-break day camps</div></div></button>
            <button type="button" class="tile m-tile" data-goto="#events"><span class="m-tile-ic" style={`background:color-mix(in srgb,${cat.parties} 14%,#fff)`}><i class="bi bi-balloon-fill" style={`color:${cat.parties}`}></i></span><div><div class="m-tile-t">Events</div><div class="m-tile-s">Birthdays &amp; parties</div></div></button>
            <button type="button" class="tile m-tile" data-goto="#groups"><span class="m-tile-ic" style={`background:color-mix(in srgb,${cat.groups} 14%,#fff)`}><i class="bi bi-people-fill" style={`color:${cat.groups}`}></i></span><div><div class="m-tile-t">Groups</div><div class="m-tile-s">Schools, teams &amp; corporate</div></div></button>
            <button type="button" class="tile m-tile" data-goto="#about"><span class="m-tile-ic" style={`background:color-mix(in srgb,${cat.classes} 14%,#fff)`}><i class="bi bi-geo-alt-fill" style={`color:${cat.classes}`}></i></span><div><div class="m-tile-t">About</div><div class="m-tile-s">The space, hours &amp; contact</div></div></button>
            <button type="button" class="tile m-tile" data-goto="#reviews"><span class="m-tile-ic" style="background:#fbeecb"><i class="bi bi-star-fill" style="color:#e9a300"></i></span><div><div class="m-tile-t">Reviews</div><div class="m-tile-s">What members say</div></div></button>
            <button type="button" class="tile m-tile" data-goto="#getstarted"><span class="m-tile-ic" style={`background:color-mix(in srgb,${cat.openGym} 14%,#fff)`}><i class="bi bi-flag-fill" style={`color:${cat.openGym}`}></i></span><div><div class="m-tile-t">Get Started</div><div class="m-tile-s">First-visit guide</div></div></button>
          </div>

          <div class="m-visit">
            <div class="m-visit-eyebrow"><span class="mh-rule"></span>Visit us</div>
            <div class="m-visit-rows">
              <div class="m-visit-row"><i class="bi bi-geo-alt-fill" aria-hidden="true"></i><div><div class="m-visit-t">{site.address.street}</div><div class="m-visit-s">{site.address.neighbourhood}, {site.address.locality}</div></div></div>
              <div class="m-visit-row"><i class="bi bi-clock-fill" aria-hidden="true"></i><div><div class="m-visit-t">{site.hoursLabel}</div><div class="m-visit-s">Open gym to the public daily</div></div></div>
              <div class="m-visit-btns">
                <a href={site.mapUrl} target="_blank" rel="noopener" class="m-visit-btn"><i class="bi bi-geo-alt"></i> Directions</a>
                <a href={`tel:${site.phone}`} class="m-visit-btn"><i class="bi bi-telephone-fill"></i> Call us</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== SUB: PRICING ===== -->
      <section data-screen="pricing" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Pricing" title="Passes, packs & memberships" desc="One price list, live from our booking system. All prices in CAD, HST included." />
          <div style="height:18px"></div>
          <div data-price-body></div>
        </div>
      </section>

      <!-- ===== SUB: STORE ===== -->
      <section data-screen="store" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Store" title="Buy before you arrive" desc="Check out on Square — your passes are ready at the front desk when you get here." />
          <div style="height:18px"></div>
          <div class="m-stack" style="margin-bottom:16px">
            {forSurface(storeProducts, 'mobile').map((s) => <BookingCard {...s} actionLabel="Buy" target="_blank" />)}
          </div>
          <a href={links.giftCard} target="_blank" rel="noopener" class="m-gift">
            <span class="m-gift-ic"><i class="bi bi-gift-fill" aria-hidden="true"></i></span>
            <div class="m-gift-txt"><div class="m-gift-t">Gift cards</div><div class="m-gift-s">Any amount</div></div>
            <i class="bi bi-arrow-up-right" aria-hidden="true"></i>
          </a>
        </div>
      </section>

      <!-- ===== SUB: GET STARTED ===== -->
      <section data-screen="getstarted" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Get Started" title="Your first visit" desc="New here? Get set up in three steps — waiver, pick how to start, and what to know." />
          <div style="height:18px"></div>
          <div class="m-step"><span class="m-stepn">1</span><div><div class="m-step-t">Sign our waiver</div><p class="m-step-p">Everyone needs a signed waiver before their first session — a couple of minutes online.</p></div></div>
          <div class="m-note"><i class="bi bi-info-circle-fill" aria-hidden="true"></i><span>A parent or guardian must sign for anyone <strong>17 or younger</strong>.</span></div>
          <a href={links.getStartedWaiver} target="_blank" rel="noopener" class="m-darkbtn" style="margin-bottom:28px">Sign our waiver <i class="bi bi-box-arrow-up-right"></i></a>

          <div class="m-step"><span class="m-stepn">2</span><div><div class="m-step-t">Pick how to start</div><p class="m-step-p">Reserve an intro or private, or just drop into a group class or open gym.</p></div></div>
          <div class="m-stack" style="margin:4px 0 28px">
            {firstSessionOptions.map((o) => <BookingCard color={o.color} status={o.status} statusTone={o.statusTone} title={o.title} description={o.desc} actionLabel={o.cta} href={mFsHref[o.key]} target={mFsTarget(o.key)} />)}
          </div>

          <div class="m-step" style="margin-bottom:16px"><span class="m-stepn">3</span><div><div class="m-step-t">Things to know</div></div></div>
          <div class="m-card">
            <div class="m-card-title"><i class="bi bi-bag-check" style="color:#e0a800"></i>Before you get here</div>
            <div class="m-list">
              {gsBring.map((b) => <div class="m-li"><i class="bi bi-check-circle-fill" style={`color:${cat.openGym}`} aria-hidden="true"></i><span>{b}</span></div>)}
            </div>
          </div>
          <div class="m-card">
            <div class="m-card-title"><i class="bi bi-geo-alt" style="color:#e0a800"></i>When you arrive</div>
            <div class="m-list">
              {gsArrive.map((a) => <div class="m-li"><span class="m-lin">{a.n}</span><span>{a.text}</span></div>)}
            </div>
          </div>
          <div class="m-warn"><i class="bi bi-clock-history" aria-hidden="true"></i><span>Arrive <strong>15 minutes early</strong> to sign in. Anyone more than 15 minutes late can't be admitted to a class.</span></div>

          <div class="m-label" style="margin-top:28px">Common questions</div>
          <div class="m-faqbox">
            {gsFaqs.map((qa) => (
              <details class="faq">
                <summary class="m-faq-sum"><span>{qa.q}</span><i class="bi bi-chevron-down faq-chev" aria-hidden="true"></i></summary>
                <div class="m-faq-a">{qa.a}</div>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- ===== SUB: ABOUT ===== -->
      <section data-screen="about" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="About" title="Toronto's movement home" desc="A 10,000+ sq ft parkour and movement centre in Downsview Park, built for every level." />
          <div style="height:18px"></div>
          <p class="m-about-lead">Built around open gym — a home for dancers, athletes, fitness enthusiasts and anyone who just wants to jump around and have fun. 10,000+ sq ft under one roof.</p>
          <div class="m-gallery">
            {aboutGallery.map((g) => <div class="m-gitem"><img src={g} alt="Inside The Monkey Vault" loading="lazy" /></div>)}
          </div>
          <div class="m-label">The space</div>
          <div class="m-facility">
            {aboutFacility.map((f) => (
              <div class="m-fcard">
                <span class="m-fic"><i class={`bi ${f.icon}`} aria-hidden="true"></i></span>
                <div class="m-ft">{f.title}</div>
                <p class="m-fb">{f.body}</p>
              </div>
            ))}
          </div>
          <div class="m-hours">
            <div class="m-hours-label">Hours</div>
            <div class="m-hours-title">Open 7 days a week</div>
            {hours.map((h) => <div class="m-hrow"><span>{h.day}</span><span class="m-htime">{h.time}</span></div>)}
          </div>
          <div class="m-contact">
            <div class="m-contact-row"><span class="m-contact-ic"><i class="bi bi-geo-alt-fill" aria-hidden="true"></i></span><div>{site.address.street}<br>{site.address.locality}, {site.address.region} {site.address.postalCode}</div></div>
            <div class="m-contact-row"><span class="m-contact-ic"><i class="bi bi-telephone-fill" aria-hidden="true"></i></span><div><a href={`tel:${site.phone}`}>{site.phoneDisplay}</a><br><a href={`mailto:${site.email}`}>{site.email}</a></div></div>
            <a href={site.mapUrl} target="_blank" rel="noopener" class="m-brandbtn">Get directions <i class="bi bi-arrow-up-right"></i></a>
          </div>
          <div class="m-socials">
            <a href={social.instagram} target="_blank" rel="noopener" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
            <a href={social.youtube} target="_blank" rel="noopener" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
            <a href={social.facebook} target="_blank" rel="noopener" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
          </div>
        </div>
      </section>

      <!-- ===== SUB: CAMPS ===== -->
      <section data-screen="camps" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Camps" title="School-break day camps" desc="A full day of parkour, games and friends. Ages 5+ · 9 AM–2 PM, late pickup available." stats={[{ v: 'Ages 5+', l: 'welcome' }, { v: '9–2', l: 'daily' }, { v: '$350', l: 'per week' }]} />
          <div style="height:18px"></div>
          <div class="m-stack" style="margin-bottom:26px">
            {forSurface(camps, 'mobile').map((c) => <BookingCard color={cat.camps} bookingTag={c.bookingTag} title={c.title} description={c.desc} pills={c.pills} price={c.price} priceNote={c.priceNote} actionLabel={c.cta} href={c.href} target="_blank" />)}
          </div>
          <div class="m-hours">
            <div class="m-hours-label">A day at camp</div>
            <div class="m-hours-title" style="margin-bottom:16px">From drop-off to pick-up</div>
            {campDay.map((d) => <div class="m-hrow"><span class="m-camptime">{d.time}</span><span class="m-camplabel">{d.label}</span></div>)}
          </div>
          <p class="m-fine">Nut-free environment — please pack nut-free and tell us about any allergies. Cancellation: two weeks' written notice for weekly camps.</p>
        </div>
      </section>

      <!-- ===== SUB: EVENTS ===== -->
      <section data-screen="events" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Events" title="Parties & group events" desc="Birthdays, school trips and team days — coaches run the whole session while you relax." />
          <div style="height:18px"></div>
          <div class="m-ev-full">
            <div class="m-ev-full-head">
              <span class="m-ev-pop">Most popular</span>
              <h3 class="m-ev-title">Full Birthday Party</h3>
            </div>
            <p class="m-ev-desc">Coaches stay with your group the whole time — a private room, a coached session and free play.</p>
            <div class="m-ev-tl">
              <div class="m-ev-tlrow"><span class="m-ev-tlt">60′</span><span>Coached parkour session &amp; games</span></div>
              <div class="m-ev-tlrow"><span class="m-ev-tlt">30′</span><span>Private party room — food &amp; cake</span></div>
              <div class="m-ev-tlrow last"><span class="m-ev-tlt">30′</span><span>Open gym free play, supervised</span></div>
            </div>
            <div class="m-ev-price">
              <div><div class="m-ev-big">{eventPricing.fullBirthdayBase}</div><div class="m-ev-sub">base · up to 8 kids · +$25 each extra</div></div>
              <span class="m-ev-meta">2 hrs · Ages 5+</span>
            </div>
            <a href={sq.book.fullBirthday} target="_blank" rel="noopener" class="m-darkbtn">Book your party <i class="bi bi-arrow-up-right"></i></a>
          </div>

          <div class="m-ev-mini">
            <span class="m-ev-minitag">Smaller &amp; last-minute</span>
            <h3 class="m-ev-minititle">Mini Birthday Party</h3>
            <p class="m-ev-minidesc">The same one-hour coached parkour session — lower minimum, so smaller groups and last-minute plans still get in. All-day pass for every kid. No private room.</p>
            <div class="m-ev-minifoot">
              <div><div class="m-ev-minibig">{eventPricing.miniBirthdayPerKid}</div><div class="m-ev-minisub">per kid · 3–15 · ages 8+</div></div>
              <a href={sq.book.miniBirthday} target="_blank" rel="noopener" class="m-brandbtn-sm">Book mini <i class="bi bi-arrow-right"></i></a>
            </div>
          </div>

          <div class="m-hold"><i class="bi bi-shield-lock" aria-hidden="true"></i><span>Your card isn't charged at booking — it just holds the slot. You pay in person on the day, by final headcount.</span></div>

          <div class="m-label">Party FAQ</div>
          <div class="m-faqbox" style="margin-bottom:22px">
            {eventFaqs.map((qa) => (
              <details class="faq">
                <summary class="m-faq-sum"><span>{qa.q}</span><i class="bi bi-chevron-down faq-chev" aria-hidden="true"></i></summary>
                <div class="m-faq-a">{qa.a}</div>
              </details>
            ))}
          </div>

          <button type="button" class="m-groupslink" data-goto="#groups">
            <span class="m-groupslink-ic" style={`background:color-mix(in srgb,${cat.groups} 14%,#fff)`}><i class="bi bi-people-fill" style={`color:${cat.groups}`} aria-hidden="true"></i></span>
            <div class="m-groupslink-txt"><div class="m-groupslink-t">Groups &amp; team events</div><div class="m-groupslink-s">Schools, corporate &amp; early access</div></div>
            <i class="bi bi-chevron-right m-chev" aria-hidden="true"></i>
          </button>
        </div>
      </section>

      <!-- ===== SUB: GROUPS ===== -->
      <section data-screen="groups" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Groups & Teams" title="Bring your whole crew" desc="Schools, corporate teams and community events, plus private early-access bookings." />
          <div style="height:18px"></div>
          <div class="m-gcard">
            <div class="m-ghead">
              <span class="m-gic" style={`background:color-mix(in srgb,${cat.groups} 14%,#fff)`}><i class="bi bi-people-fill" style={`color:${cat.groups}`} aria-hidden="true"></i></span>
              <div><div class="m-geyebrow" style={`color:${cat.groups}`}>Group Events</div><div class="m-gtitle">Field trips &amp; team-building</div></div>
            </div>
            <p class="m-gdesc">Two hours — an hour of guided activities, then an hour of open gym. Great for field trips, teams and community events, all levels.</p>
            <div class="m-glabel">Price per participant</div>
            <div class="m-gtiers">
              {groupTiers.map((t) => <div class="m-gtier"><span>{t.label}</span><span class="m-gtier-v">{t.val}</span></div>)}
            </div>
            <p class="m-gfine">Minimum 10; smaller groups pay the $300 base. Final total is calculated on event day.</p>
            <a href={sq.book.groupEvents} target="_blank" rel="noopener" class="m-darkbtn">Plan an event <i class="bi bi-arrow-up-right"></i></a>
          </div>

          <div class="m-gcard">
            <div class="m-ghead">
              <span class="m-gic" style={`background:color-mix(in srgb,${cat.openGym} 14%,#fff)`}><i class="bi bi-sunrise" style={`color:${cat.openGym}`} aria-hidden="true"></i></span>
              <div><div class="m-geyebrow" style={`color:${cat.openGym}`}>Early Access</div><div class="m-gtitle">The gym, all to yourself</div></div>
            </div>
            <p class="m-gdesc">Reserve the gym before we open at 11 AM for exclusive access — perfect for small groups or focused training with no crowds.</p>
            <div class="m-gfoot2">
              <div><div class="m-gbig">{eventPricing.earlyAccessFrom}</div><div class="m-gsub">+ $25 / person open gym</div></div>
              <a href={sq.book.earlyGymAccess} target="_blank" rel="noopener" class="m-darkbtn-sm">Reserve <i class="bi bi-arrow-up-right"></i></a>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== SUB: REVIEWS ===== -->
      <section data-screen="reviews" class="m-screen" hidden>
        <div class="m-pad">
          <MobileHero eyebrow="Reviews" title="Loved by the community" desc={`${reviews.ratingValue} stars across 449 Google reviews from parents, members and first-timers.`} />
          <div style="height:16px"></div>
          <div class="m-revsum">
            <div class="m-revsum-score"><div class="m-revsum-num">{reviews.ratingValue}</div><div class="m-revsum-stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i></div></div>
            <div class="m-revsum-txt"><div class="m-revsum-t">{reviews.ratingCount.replace(/^Based on /, '')}</div><div class="m-revsum-s">From parents, open-gym members and first-timers alike.</div></div>
          </div>
          <div class="app-scroll m-revscroll">
            {reviewItems.map((r) => (
              <div class="m-revcard">
                <div class="m-revcard-stars"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i></div>
                <p class="m-revcard-text">“{r.text}”</p>
                <div class="m-revcard-by">{r.name} <span>· {r.role}</span></div>
              </div>
            ))}
          </div>
          <div class="m-revnav">
            <button type="button" class="m-revarrow" data-rev-prev aria-label="Previous review"><i class="bi bi-chevron-left" aria-hidden="true"></i></button>
            <div class="m-revdots">
              {reviewItems.map((_, i) => <button type="button" class="m-revdot" data-rev-dot={i} aria-label={`Review ${i + 1}`}></button>)}
            </div>
            <button type="button" class="m-revarrow" data-rev-next aria-label="Next review"><i class="bi bi-chevron-right" aria-hidden="true"></i></button>
          </div>
        </div>
      </section>

    </div>

    <!-- bottom nav -->
    <nav class="m-nav">
      <button type="button" class="navbtn m-navbtn" data-nav="home"><i class="bi bi-house-door-fill"></i><span>Home</span></button>
      <button type="button" class="navbtn m-navbtn" data-nav="train"><i class="bi bi-person-arms-up"></i><span>Train</span></button>
      <button type="button" class="navbtn m-navbtn m-navcenter" data-nav="book"><span class="m-navcenter-c"><i class="bi bi-calendar-check-fill"></i></span><span>Book</span></button>
      <button type="button" class="navbtn m-navbtn" data-nav="schedule"><i class="bi bi-calendar3"></i><span>Schedule</span></button>
      <button type="button" class="navbtn m-navbtn" data-nav="more"><i class="bi bi-grid-fill"></i><span>More</span></button>
    </nav>
  </div>

  <script type="application/json" id="m-config" set:html={JSON.stringify(clientConfig)}></script>
</MobileLayout>

<style>
  .m-app { height: 100dvh; background: #f5f4f1; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; color: #211f1b; display: flex; flex-direction: column; overflow: hidden; }
  .m-safe { flex: none; background: #211f1b; height: env(safe-area-inset-top, 0px); }
  .m-scroll { flex: 1; overflow-y: auto; overflow-x: hidden; position: relative; }
  .m-pad { padding: 16px 18px 28px; }
  .m-pad-x { padding: 0 18px; }
  .m-stack { display: flex; flex-direction: column; gap: 16px; }

  /* header */
  .m-head { position: sticky; top: 0; z-index: 15; background: #211f1b; border-bottom: 1px solid rgba(255,255,255,.08); padding: 16px 18px; }
  .m-head-main, .m-head-sub { display: flex; align-items: center; justify-content: space-between; }
  .m-brand { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .m-brand img { flex: none; width: 32px; height: 32px; object-fit: contain; }
  .m-brand span { font: 900 14.5px/1 'Archivo', sans-serif; letter-spacing: .01em; text-transform: uppercase; color: #fff; white-space: nowrap; }
  .m-back { cursor: pointer; background: none; border: 0; padding: 0; display: inline-flex; align-items: center; gap: 5px; font: 800 17px/1 'Archivo', sans-serif; letter-spacing: -.01em; color: #fff; white-space: nowrap; }
  .m-back i { font-size: 18px; color: #ffd400; }
  .m-status { flex: none; display: inline-flex; align-items: center; gap: 6px; font: 700 11px/1 'Archivo', sans-serif; letter-spacing: .04em; text-transform: uppercase; border-radius: 999px; padding: 7px 11px; white-space: nowrap; color: #5fd07f; background: rgba(95,208,127,.13); border: 1px solid rgba(95,208,127,.28); }
  .m-status-dot { flex: none; width: 7px; height: 7px; border-radius: 50%; background: #5fd07f; }

  .m-screen { }

  /* home hero */
  .m-home-hero { background: #211f1b; color: #fff; border-radius: 22px; padding: 26px 24px 24px; margin-bottom: 26px; position: relative; overflow: hidden; }
  .mh-glow { position: absolute; inset: 0; background: radial-gradient(360px 200px at 92% -20%, rgba(255,212,0,.16), transparent 70%); }
  .m-home-hero-inner { position: relative; }
  .mh-eyebrow { display: inline-flex; align-items: center; gap: 8px; font: 700 10.5px/1 'Archivo', sans-serif; letter-spacing: .12em; text-transform: uppercase; color: #ffd400; margin-bottom: 18px; }
  .mh-rule { width: 18px; height: 2px; background: #ffd400; }
  .m-home-title { font: 800 33px/1.02 'Archivo', sans-serif; letter-spacing: -.02em; margin: 0 0 14px; }
  .m-home-lead { font: 400 14px/1.55 inherit; color: rgba(255,255,255,.72); margin: 0 0 22px; }
  .m-home-stats { display: flex; border-top: 1px solid rgba(255,255,255,.12); padding-top: 16px; }
  .m-home-stat { flex: 1; border-right: 1px solid rgba(255,255,255,.12); }
  .m-home-stat.mid { text-align: center; }
  .m-home-stat.end { text-align: right; border-right: 0; }
  .m-home-statv { font: 800 19px/1 'Archivo', sans-serif; color: #ffd400; }
  .m-home-statl { font: 600 10.5px/1.3 inherit; color: rgba(255,255,255,.6); margin-top: 5px; }

  .m-newhere { cursor: pointer; width: 100%; text-align: left; background: #fff; border: 1px solid #ebe9e4; border-radius: 15px; box-shadow: 0 1px 3px rgba(28,25,23,.04), 0 14px 30px -24px rgba(28,25,23,.38); padding: 15px 16px; display: flex; align-items: center; gap: 13px; margin-bottom: 28px; }
  .m-newhere-ic { flex: none; width: 38px; height: 38px; border-radius: 11px; background: #fbf3cf; display: flex; align-items: center; justify-content: center; }
  .m-newhere-ic i { font-size: 16px; color: #b78900; }
  .m-newhere-txt { flex: 1; }
  .m-newhere-t { font: 800 14px/1.15 'Archivo', sans-serif; }
  .m-newhere-s { font: 500 12px/1.35 inherit; color: #8a877f; margin-top: 3px; }
  .m-chev { font-size: 13px; color: #c4c0b7; }

  .m-h3 { font: 800 18px/1 'Archivo', sans-serif; letter-spacing: -.01em; margin: 0 0 5px; }
  .m-sub { font: 500 13px/1.4 inherit; color: #8a877f; margin: 0 0 15px; }
  .m-rowhead { display: flex; align-items: center; justify-content: space-between; margin-bottom: 13px; }
  .m-alllink { cursor: pointer; background: none; border: 0; font: 800 11.5px/1 'Archivo', sans-serif; text-transform: uppercase; letter-spacing: .04em; color: #211f1b; display: inline-flex; align-items: center; gap: 5px; }
  .m-label { font: 800 12px/1 'Archivo', sans-serif; letter-spacing: .06em; text-transform: uppercase; color: #9b8e6a; margin: 0 0 12px; }

  .m-revstrip { background: #fff; border: 1px solid #ebe9e4; border-radius: 16px; box-shadow: 0 1px 3px rgba(28,25,23,.04), 0 14px 30px -24px rgba(28,25,23,.38); padding: 20px; margin-bottom: 26px; }
  .m-revstrip-top { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .m-revstrip-num { font: 900 24px/1 'Archivo', sans-serif; }
  .m-revstrip-stars { color: #e9a300; font-size: 12px; letter-spacing: 2px; }
  .m-revstrip-count { font: 600 11.5px/1 inherit; color: #8a877f; margin-top: 5px; }
  .m-revstrip-quote { font: 500 13.5px/1.5 inherit; color: #3a3833; margin: 0; }

  /* book drop-ins */
  .m-dropin { background: #fff; border: 1px solid #ebe9e4; border-radius: 16px; box-shadow: 0 1px 3px rgba(28,25,23,.04), 0 14px 30px -24px rgba(28,25,23,.38); overflow: hidden; }
  .m-dropin-strip { display: block; height: 4px; }
  .m-dropin-body { padding: 18px; }
  .m-dropin-head { display: flex; align-items: center; gap: 10px; margin-bottom: 11px; }
  .m-dropin-tag { display: inline-flex; align-items: center; gap: 6px; padding: 6px 11px; border-radius: 6px; color: #fff; font: 800 10.5px/1 'Archivo', sans-serif; letter-spacing: .07em; text-transform: uppercase; }
  .m-dropin-tag i { font-size: 12px; }
  .m-dropin-title { font: 800 20px/1.05 'Archivo', sans-serif; letter-spacing: -.01em; margin: 0; }
  .m-dropin-desc { font: 400 13px/1.5 inherit; color: #5b5853; margin: 0 0 14px; }
  .m-dropin-cta { display: flex; align-items: center; gap: 13px; border: 1px solid; border-radius: 12px; padding: 14px 15px; }
  .m-dropin-cta i { font-size: 24px; }
  .m-dropin-ctat { font: 800 17px/1.05 'Archivo', sans-serif; letter-spacing: -.01em; }
  .m-dropin-ctas { font: 600 12px/1.35 inherit; color: #6a6760; margin-top: 3px; }

  /* schedule */
  .m-chips { display: flex; gap: 8px; overflow-x: auto; padding: 0 18px 18px; }
  .m-chip { flex: none; cursor: pointer; font: 700 12.5px/1 'Archivo', sans-serif; border-radius: 999px; padding: 9px 15px; white-space: nowrap; }
  .m-sched-day { margin-bottom: 22px; }
  .m-sched-daylabel { font: 800 12px/1 'Archivo', sans-serif; letter-spacing: .06em; text-transform: uppercase; color: #9b8e6a; margin-bottom: 11px; }
  .m-sched-card { background: #fff; border: 1px solid #ebe9e4; border-radius: 16px; box-shadow: 0 1px 3px rgba(28,25,23,.04), 0 14px 30px -24px rgba(28,25,23,.38); overflow: hidden; }
  .m-sess { display: flex; gap: 13px; padding: 14px 16px; border-bottom: 1px solid #f0efea; }
  .m-sess:last-child { border-bottom: 0; }
  .m-sess-bar { flex: none; width: 4px; align-self: stretch; border-radius: 2px; }
  .m-sess-name { font: 800 14.5px/1.15 'Archivo', sans-serif; color: #211f1b; }
  .m-sess-meta { font: 500 12.5px/1.3 inherit; color: #8a877f; margin-top: 4px; }
  .m-sess-badge { font: 800 9px/1 'Archivo', sans-serif; letter-spacing: .06em; text-transform: uppercase; border-radius: 4px; padding: 3px 5px; margin-left: 8px; }
  .m-loading { display: flex; flex-direction: column; align-items: center; gap: 14px; padding: 60px 0; color: #9b8e6a; }
  .m-spin { width: 26px; height: 26px; border-radius: 50%; border: 3px solid #e6e4dd; border-top-color: #211f1b; animation: tmv-spin .8s linear infinite; }
  .m-err { text-align: center; padding: 50px 20px; }
  .m-err i { font-size: 26px; color: #c4c0b7; }
  .m-err p { font: 600 13.5px/1.5 inherit; color: #6a6760; margin: 14px 0 16px; }
  .m-retry { cursor: pointer; background: #211f1b; color: #fff; border: 0; border-radius: 11px; padding: 12px 20px; font: 800 12px/1 'Archivo', sans-serif; text-transform: uppercase; letter-spacing: .03em; }
  .m-autonote { display: flex; align-items: center; gap: 9px; background: #f3f2ee; border-radius: 12px; padding: 13px 15px; margin-top: 4px; }
  .m-autonote i { font-size: 14px; color: #9b8e6a; }
  .m-autonote span { font: 500 12px/1.4 inherit; color: #6a6760; }
