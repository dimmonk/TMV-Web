<!-- The schedule list, filter chips, loading/error states and the price "Buy
     passes" button are injected into the DOM at runtime via innerHTML, so they
     never carry Astro's scoped-style attribute. These rules must be global to
     reach them. All are `.m-*`-prefixed and this page is the only consumer. -->
<style is:global>
  .m-chip { flex: none; cursor: pointer; font: 700 12.5px/1 'Archivo', sans-serif; border-radius: 999px; padding: 9px 15px; white-space: nowrap; }
  .m-sched-day { margin-bottom: 22px; }
