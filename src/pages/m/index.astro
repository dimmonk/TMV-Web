  .m-tile-ic { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
  .m-tile-ic i { font-size: 19px; }
  .m-tile-t { font: 800 14.5px/1.1 'Archivo', sans-serif; letter-spacing: -.005em; }
  .m-tile-s { font: 500 11.5px/1.35 inherit; color: #8a877f; margin-top: 4px; }

  .m-visit { background: #211f1b; color: #fff; border-radius: 20px; padding: 24px; }
  .m-visit-eyebrow { display: flex; align-items: center; gap: 9px; font: 700 11px/1 'Archivo', sans-serif; letter-spacing: .12em; text-transform: uppercase; color: #ffd400; margin-bottom: 18px; }
  .m-visit-rows { display: flex; flex-direction: column; gap: 14px; }
  .m-visit-row { display: flex; align-items: flex-start; gap: 12px; }
  .m-visit-row i { font-size: 15px; color: #ffd400; margin-top: 2px; }
  .m-visit-t { font: 700 13.5px/1.3 'Archivo', sans-serif; }
  .m-visit-s { font: 500 12px/1.3 inherit; color: rgba(255,255,255,.6); margin-top: 3px; }
  .m-visit-btns { display: flex; gap: 10px; margin-top: 6px; }
  .m-visit-btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.14); border-radius: 11px; padding: 12px; color: #fff; text-decoration: none; font: 700 12px/1 'Archivo', sans-serif; }

  /* get started */
