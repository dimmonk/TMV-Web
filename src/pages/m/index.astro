  .m-autonote { display: flex; align-items: center; gap: 9px; background: #f3f2ee; border-radius: 12px; padding: 13px 15px; margin-top: 4px; }
  .m-autonote i { font-size: 14px; color: #9b8e6a; }
  .m-autonote span { font: 500 12px/1.4 inherit; color: #6a6760; }
  .m-darkbtn { display: flex; align-items: center; justify-content: center; gap: 9px; width: 100%; background: #211f1b; color: #fff; text-decoration: none; border: 0; cursor: pointer; border-radius: 12px; padding: 14px; font: 800 13px/1 'Archivo', sans-serif; text-transform: uppercase; letter-spacing: .03em; }
  @keyframes tmv-spin-g { to { transform: rotate(360deg); } }
</style>

<script>
  // The schedule/price helpers are dynamically imported when their screen first
  // opens (matching the original runtime). This also avoids a static-bundle
  // module-init ordering (TDZ) issue that only surfaced in the CI-minified build.
  let _matchesFilter: (c: any, f: string) => boolean;
  let _fmtRange: (s: string, e: string) => string;
  let _sections: any[], _footnotes: string[], _formatPrice: (v: any, s?: string) => string;

  const cfg = JSON.parse(document.getElementById('m-config')!.textContent || '{}');
  const CAT = cfg.cat || {};
  const SCHEDULE_API = cfg.scheduleApi;
  const PRICE_API = cfg.priceApi;

  const TABS = ['home', 'train', 'book', 'schedule', 'more'];
  const SUBS = ['pricing', 'store', 'about', 'reviews', 'getstarted', 'camps', 'events', 'groups'];
  const SUBTITLES: Record<string, string> = { pricing: 'Pricing', store: 'Store', getstarted: 'Get Started', about: 'About', camps: 'Camps', events: 'Events', groups: 'Groups & Teams', reviews: 'Reviews' };

  const screens = Array.from(document.querySelectorAll<HTMLElement>('[data-screen]'));
  const navBtns = Array.from(document.querySelectorAll<HTMLElement>('[data-nav]'));
  const scroll = document.querySelector<HTMLElement>('.m-scroll');
  const headMain = document.querySelector<HTMLElement>('[data-head="main"]');
  const headSub = document.querySelector<HTMLElement>('[data-head="sub"]');
  const subtitleEl = document.querySelector<HTMLElement>('[data-subtitle]');

  function currentHash() {
    return (location.hash || '').replace('#', '').toLowerCase().trim();
  }

  function render() {
    const h = currentHash();
    let screen = 'home';
    let tab = 'home';
    let isSub = false;
    if (TABS.indexOf(h) >= 0) { screen = h; tab = h; }
    else if (SUBS.indexOf(h) >= 0) { screen = h; tab = 'more'; isSub = true; }

    screens.forEach((s) => { s.hidden = s.dataset.screen !== screen; });
    navBtns.forEach((b) => b.classList.toggle('active', b.dataset.nav === tab));
    if (headMain && headSub) { headMain.hidden = isSub; headSub.hidden = !isSub; }
    if (isSub && subtitleEl) subtitleEl.textContent = SUBTITLES[screen] || '';
    if (scroll) scroll.scrollTop = 0;
    if (screen === 'schedule') ensureSchedule();
    if (screen === 'pricing') ensurePricing();
  }

  // ---- live status pill (gym timezone, 60s tick) ----
  function formatHour12(totalMinutes: number) {
    const h24 = Math.floor(totalMinutes / 60) % 24;
    const h12 = h24 % 12 === 0 ? 12 : h24 % 12;
    return h12 + ' ' + (h24 < 12 ? 'AM' : 'PM');
  }
  function openStatus() {
    let hour = 12, minute = 0, wd = 'Mon';
    try {
      const parts = new Intl.DateTimeFormat('en-US', { timeZone: 'America/Toronto', hour12: false, weekday: 'short', hour: '2-digit', minute: '2-digit' }).formatToParts(new Date());
      const m = Object.fromEntries(parts.map((p) => [p.type, p.value]));
      hour = parseInt(m.hour, 10) % 24; minute = parseInt(m.minute, 10) || 0; wd = m.weekday;
    } catch (e) { /* fall back to open */ }
    const mins = hour * 60 + minute;
    const closeAt = wd === 'Fri' ? 24 * 60 : 22 * 60;
    const isOpen = mins >= 11 * 60 && mins < closeAt;
    if (isOpen && closeAt - mins <= 120) return { label: 'Closes at ' + formatHour12(closeAt), fg: '#ffb84d', bg: 'rgba(255,184,77,.14)', bd: 'rgba(255,184,77,.3)', dot: '#ffb84d', pulse: false };
    if (isOpen) return { label: 'Open now', fg: '#5fd07f', bg: 'rgba(95,208,127,.13)', bd: 'rgba(95,208,127,.28)', dot: '#5fd07f', pulse: true };
    return { label: 'Opens 11 AM', fg: 'rgba(255,255,255,.6)', bg: 'rgba(255,255,255,.07)', bd: 'rgba(255,255,255,.15)', dot: 'rgba(255,255,255,.4)', pulse: false };
  }
  function paintStatus() {
    const s = openStatus();
    document.querySelectorAll<HTMLElement>('[data-status]').forEach((el) => {
      el.style.color = s.fg; el.style.background = s.bg; el.style.borderColor = s.bd;
      const dot = el.querySelector<HTMLElement>('.m-status-dot');
      const label = el.querySelector<HTMLElement>('.m-status-label');
      if (dot) { dot.style.background = s.dot; dot.classList.toggle('tmv-pulse', s.pulse); }
      if (label) label.textContent = s.label;
    });
  }
  paintStatus();
  setInterval(paintStatus, 60000);

  // ---- schedule (live SSOT via src/lib) ----
  const DAY_ORDER = [1, 2, 3, 4, 5, 6, 0];
  const DAY_LONG = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const FILTERS: [string, string][] = [['all', 'All'], ['kids', 'Kids'], ['teens', 'Teens'], ['adults', 'Adults'], ['athletic', 'Athletic'], ['open-gym', 'Open Gym']];
  let schedClasses: any[] | null = null;
  let schedErr = false;
  let schedFilter = 'all';
  let schedStarted = false;

  const chipsEl = document.querySelector<HTMLElement>('[data-sched-chips]');
  const schedBody = document.querySelector<HTMLElement>('[data-sched-body]');
  const escapeHtml = (s: string) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

  function openGymEntries() {
    const out: any[] = [];
    DAY_ORDER.forEach((d) => {
      out.push({ day: d, time: '11', endTime: '22', disciplineName: 'Open Gym', ageGroupName: 'All Ages', color: '#2e9e4f' });
      if (d === 5) out.push({ day: d, time: '22', endTime: '24', disciplineName: 'Open Gym', ageGroupName: 'Adults Only', color: '#2e7d32' });
    });
    return out;
  }
  function buildDays(filter: string) {
    const list = filter === 'open-gym' ? openGymEntries() : (schedClasses || []).filter((c) => _matchesFilter(c, filter));
    const today = new Date().getDay();
    const key = (t: string) => { const [h, m] = String(t || '').split(':'); return (parseInt(h, 10) || 0) * 60 + (parseInt(m || '0', 10) || 0); };
    const days: any[] = [];
    DAY_ORDER.forEach((d) => {
      const sessions = list.filter((c) => c.day === d).sort((a, b) => key(a.time) - key(b.time));
      if (!sessions.length) return;
      days.push({
        label: (d === today ? 'Today · ' : '') + DAY_LONG[d],
        sessions: sessions.map((c) => ({
          name: c.disciplineName || '', range: _fmtRange(c.time, c.endTime),
          age: c.ageGroupName || '', color: c.color || '#2196f3',
          isNew: !!c.isNew && !c.isCancelled, isCancelled: !!c.isCancelled,
        })),
      });
    });
    return days;
  }
  function renderChips() {
    if (!chipsEl) return;
    chipsEl.innerHTML = FILTERS.map(([k, l]) => {
      const on = k === schedFilter;
      return `<button type="button" class="m-chip" data-filter="${k}" style="color:${on ? '#fff' : '#3a3833'};background:${on ? '#211f1b' : '#fff'};border:1px solid ${on ? '#211f1b' : '#e6e4dd'}">${l}</button>`;
    }).join('');
    chipsEl.querySelectorAll<HTMLElement>('[data-filter]').forEach((b) => b.addEventListener('click', () => { schedFilter = b.dataset.filter || 'all'; renderChips(); renderSchedule(); }));
  }
  function renderSchedule() {
    if (!schedBody) return;
    if (schedErr) {
      schedBody.innerHTML = `<div class="m-err"><i class="bi bi-wifi-off"></i><p>Couldn't reach the booking system.</p><button type="button" class="m-retry" data-sched-retry>Try again</button></div>`;
      schedBody.querySelector('[data-sched-retry]')?.addEventListener('click', loadSchedule);
      return;
    }
    if (!schedClasses) { schedBody.innerHTML = `<div class="m-loading"><span class="m-spin"></span><span>Loading live schedule…</span></div>`; return; }
    const days = buildDays(schedFilter);
    if (!days.length) { schedBody.innerHTML = `<div style="text-align:center;padding:44px 20px;font:italic 500 13.5px/1.5 inherit;color:#8a877f">No classes match this filter.</div>`; return; }
    schedBody.innerHTML = days.map((day) => `
      <div class="m-sched-day">
        <div class="m-sched-daylabel">${escapeHtml(day.label)}</div>
        <div class="m-sched-card">
          ${day.sessions.map((s: any) => `
            <div class="m-sess" style="opacity:${s.isCancelled ? '.55' : '1'}">
              <span class="m-sess-bar" style="background:${s.color}"></span>
              <div style="flex:1;min-width:0">
                <div style="display:flex;align-items:center"><span class="m-sess-name" style="text-decoration:${s.isCancelled ? 'line-through' : 'none'}">${escapeHtml(s.name)}</span>${s.isNew ? '<span class="m-sess-badge" style="color:#1b6b2f;background:#e6f4ea;border:1px solid #c7e4cf">New</span>' : ''}${s.isCancelled ? '<span class="m-sess-badge" style="color:#8b1f1f;background:#fbeaea;border:1px solid #ecc6c6">Ending</span>' : ''}</div>
                <div class="m-sess-meta">${escapeHtml(s.range)} · ${escapeHtml(s.age)}</div>
              </div>
            </div>`).join('')}
        </div>
      </div>`).join('') + `<div class="m-autonote"><i class="bi bi-arrow-repeat"></i><span>Times update automatically — the same schedule our front desk runs from.</span></div>`;
  }
  function loadSchedule() {
    schedErr = false; schedClasses = null; renderSchedule();
    Promise.all([
      import('../../lib/print-schedule-sheet.js'),
      fetch(SCHEDULE_API).then((r) => r.json()),
    ])
      .then(([mod, json]) => {
        _matchesFilter = mod.matchesFilter;
        _fmtRange = (s: string, e: string) => mod.fmtClassTimeRange(s, e, { suffix: 'long', sep: ' – ' });
        schedClasses = (json && json.success && json.data && json.data.classes) || [];
        renderSchedule();
      })
      .catch((e) => { console.warn('[schedule] load failed', e); schedErr = true; renderSchedule(); });
  }
  function ensureSchedule() { if (schedStarted) return; schedStarted = true; renderChips(); loadSchedule(); }

  // ---- pricing (live SSOT via src/lib) ----
  const PRICE_COLORS: Record<string, string> = {
    classes: CAT.classes, private_classes: CAT.private, birthday_party: CAT.parties,
    camps: CAT.camps, open_gym: CAT.openGym, introduction_class: CAT.intro, athletic_program: CAT.athletic,
  };
  const PRICE_ICONS: Record<string, string> = {
    classes: 'bi-person-arms-up', private_classes: 'bi-person-fill', birthday_party: 'bi-balloon-fill',
    camps: 'bi-sun-fill', open_gym: 'bi-door-open', introduction_class: 'bi-flag-fill', athletic_program: 'bi-lightning-fill',
  };
  let priceList: any = null;
  let priceErr = false;
  let priceStarted = false;
  const priceBody = document.querySelector<HTMLElement>('[data-price-body]');

  function pickInk(hex: string) {
    const h = (hex || '').replace('#', '');
    if (h.length < 6) return '#fff';
    const r = parseInt(h.slice(0, 2), 16), g = parseInt(h.slice(2, 4), 16), b = parseInt(h.slice(4, 6), 16);
    return 0.299 * r + 0.587 * g + 0.114 * b > 150 ? '#211f1b' : '#fff';
  }
  function rowsForItems(items: any[]) {
    const rows: any[] = [];
    (items || []).forEach((it) => {
      if (it.priceKey !== undefined) rows.push({ t: 'normal', label: it.label, val: _formatPrice(priceList[it.priceKey], it.suffix) });
      else if (it.label) rows.push({ t: 'head', label: it.label });
      (it.bullets || []).forEach((b: any) => { if (b.priceKey) rows.push({ t: 'sub', label: b.label || b.priceKey, val: _formatPrice(priceList[b.priceKey], b.suffix) }); });
    });
    return rows;
  }
  function sectionRows(section: any) {
    if (section.groups) {
      const rows: any[] = [];
      section.groups.forEach((g: any) => { rows.push({ t: 'head', label: g.label }); rowsForItems(g.items).forEach((r) => rows.push(r)); });
      return rows;
    }
    return rowsForItems(section.items);
  }
  function renderPricing() {
    if (!priceBody) return;
    if (priceErr) {
      priceBody.innerHTML = `<div class="m-err"><i class="bi bi-wifi-off"></i><p>Couldn't reach the price list.</p><button type="button" class="m-retry" data-price-retry>Try again</button></div>`;
      priceBody.querySelector('[data-price-retry]')?.addEventListener('click', loadPrices);
      return;
    }
    if (!priceList) { priceBody.innerHTML = `<div class="m-loading"><span class="m-spin"></span><span>Loading live prices…</span></div>`; return; }
    const groups = _sections.map((s: any) => {
      const color = PRICE_COLORS[s.id] || '#211f1b';
      return { title: s.title, color, ink: pickInk(color), icon: PRICE_ICONS[s.id] || 'bi-tag-fill', rows: sectionRows(s) };
    });
    priceBody.innerHTML = groups.map((g) => `
      <div style="margin-bottom:20px;border-radius:14px;overflow:hidden;box-shadow:0 1px 3px rgba(28,25,23,.05),0 10px 26px -20px rgba(28,25,23,.4)">
        <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:${g.color}">
          <i class="bi ${g.icon}" style="font-size:14.5px;color:${g.ink}"></i>
          <div style="font:800 13.5px/1 'Archivo',sans-serif;letter-spacing:.04em;text-transform:uppercase;color:${g.ink}">${escapeHtml(g.title)}</div>
        </div>
        <div style="background:#fff">
          ${g.rows.map((r: any) => {
            if (r.t === 'head') return `<div style="padding:11px 16px 7px;font:800 10.5px/1 'Archivo',sans-serif;letter-spacing:.08em;text-transform:uppercase;color:#9b8e6a;background:#faf9f6;border-bottom:1px solid #f0efea">${escapeHtml(r.label)}</div>`;
            if (r.t === 'sub') return `<div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:10px 16px 10px 30px;border-bottom:1px solid #f0efea;background:#fcfbf9"><div style="font:500 13px/1.25 inherit;color:#6a6760;min-width:0">${escapeHtml(r.label)}</div><span style="flex:none;font:700 13.5px/1 'Archivo',sans-serif;color:#3a3833">${escapeHtml(r.val)}</span></div>`;
            return `<div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:13px 16px;border-bottom:1px solid #f0efea"><div style="font:600 14px/1.25 -apple-system,system-ui,sans-serif;color:#211f1b;min-width:0">${escapeHtml(r.label)}</div><span style="flex:none;font:800 15px/1 'Archivo',sans-serif;color:#211f1b">${escapeHtml(r.val)}</span></div>`;
          }).join('')}
        </div>
      </div>`).join('')
      + `<div class="m-autonote" style="margin-bottom:16px"><i class="bi bi-arrow-repeat"></i><span>Prices update automatically — the same list our front desk runs from.</span></div>`
      + `<div style="display:flex;flex-direction:column;gap:6px;margin-bottom:18px">${(_footnotes || []).map((f: string) => `<div style="display:flex;gap:8px;align-items:flex-start;font:500 12px/1.45 inherit;color:#9b9890"><span style="color:#c9c4b8">•</span>${escapeHtml(f)}</div>`).join('')}</div>`
      + `<button type="button" class="m-darkbtn" data-goto="#store">Buy passes online <i class="bi bi-arrow-right"></i></button>`;
    priceBody.querySelector('[data-goto]')?.addEventListener('click', () => { location.hash = 'store'; });
  }
  function loadPrices() {
    priceErr = false; priceList = null; renderPricing();
    Promise.all([
      import('../../lib/price-list-layout.js'),
      fetch(PRICE_API).then((r) => r.json()),
    ])
      .then(([mod, json]) => {
        _sections = mod.PRICE_LIST_SECTIONS;
        _footnotes = mod.PRICE_LIST_FOOTNOTES;
        _formatPrice = mod.formatPrice;
        priceList = (json && json.success && json.data && json.data.priceList) || {};
        renderPricing();
      })
      .catch((e) => { console.warn('[prices] load failed', e); priceErr = true; renderPricing(); });
  }
  function ensurePricing() { if (priceStarted) return; priceStarted = true; loadPrices(); }

  // ---- reviews carousel: explicit dot/arrow switching (swipe still works) ----
  const revScroll = document.querySelector<HTMLElement>('.m-revscroll');
  if (revScroll) {
    const revDots = Array.from(document.querySelectorAll<HTMLElement>('[data-rev-dot]'));
    const step = () => {
      const card = revScroll.querySelector<HTMLElement>('.m-revcard');
      return card ? card.getBoundingClientRect().width + 12 : revScroll.clientWidth;
    };
    const revIdx = () => Math.max(0, Math.min(revDots.length - 1, Math.round(revScroll.scrollLeft / step())));
    const paintDots = () => revDots.forEach((d, i) => d.classList.toggle('on', i === revIdx()));
    const goRev = (i: number) => revScroll.scrollTo({ left: Math.max(0, Math.min(revDots.length - 1, i)) * step(), behavior: 'smooth' });
    revDots.forEach((d, i) => d.addEventListener('click', () => goRev(i)));
    document.querySelector('[data-rev-prev]')?.addEventListener('click', () => goRev(revIdx() - 1));
    document.querySelector('[data-rev-next]')?.addEventListener('click', () => goRev(revIdx() + 1));
    revScroll.addEventListener('scroll', () => requestAnimationFrame(paintDots), { passive: true });
    paintDots();
  }

  // Wire events + do the first render LAST — a direct load of #schedule/#pricing
  // calls render() → ensureSchedule/ensurePricing synchronously, which reference
  // the module-level state above, so everything must be initialized first.
  navBtns.forEach((b) => b.addEventListener('click', () => { location.hash = b.dataset.nav || 'home'; }));
  document.querySelectorAll<HTMLElement>('[data-goto]').forEach((el) => {
    el.addEventListener('click', () => { location.hash = el.dataset.goto || ''; });
  });
  document.querySelector('[data-back]')?.addEventListener('click', () => {
    if (history.length > 1) history.back();
    else location.hash = 'more';
  });
  window.addEventListener('hashchange', render);
  render();
</script>
