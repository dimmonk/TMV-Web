---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import OfferingCard from '../components/OfferingCard.astro';
import Reviews from '../components/Reviews.astro';
import CtaBand from '../components/CtaBand.astro';
import { seo, links, cat, url, heroStats } from '../data/site';
import { sq } from '../data/square-links';
import { offerings } from '../data/offerings';

const heroPhotos = [
  'gym-01.jpg', 'gym-02.jpg', 'gym-03.jpg', 'gym-04.jpg',
  'gym-05.jpg', 'gym-06.jpg', 'gym-07.jpg', 'gym-08.jpg',
].map((f) => url(`assets/${f}`));

const camps = [
  {
    title: 'Summer Camps 2026', badge: 'Summer 2026', color: cat.camps, status: 'Booking now', statusColor: cat.openGym,
    price: '$350 / week', href: sq.home.summerCamps,
    rows: [
      { icon: 'bi-calendar-week', text: 'Weekly sessions · all summer — dates on the booking page' },
      { icon: 'bi-clock', text: '9 AM – 2 PM · late pickup to 4 PM' },
      { icon: 'bi-people', text: 'Ages 5+ · all levels' },
    ],
  },
  {
    title: 'P.A. Day Camps', badge: 'School year', color: cat.camps, status: 'Single days', statusColor: cat.classes,
    price: '$90 / day', href: sq.home.paDayCamps,
    rows: [
      { icon: 'bi-sun', text: 'Single days off school' },
      { icon: 'bi-clock', text: '9 AM – 2 PM · late pickup to 4 PM' },
      { icon: 'bi-unlock', text: 'Open to the public' },
    ],
  },
];
---
<BaseLayout title={seo.home.title} description={seo.home.description} active="">
  <!-- HERO -->
  <section class="hero" id="top">
    <div class="hero-glow"></div>
    <div class="hero-inner container">
      <div>
        <div class="hero-kicker"><span class="hero-kicker-rule"></span>Parkour &amp; Movement Training Centre · Toronto</div>
        <h1 class="hero-title">Move better.<br>Have more fun.</h1>
        <p class="hero-lead">Toronto's home for parkour, flips and movement. Drop in to play, book a class, train like an athlete, or throw a party — every age, every level, under one big roof.</p>
        <div class="hero-actions">
          <a href={links.booking} target="_blank" rel="noopener" class="btn btn-primary">Book a session <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
          <a href="#offerings" class="btn btn-ghost-light">Explore the gym</a>
        </div>
        <div class="hero-stats">
          {heroStats.map((st, i) => (
            <div class:list={['hero-stat', { last: i === heroStats.length - 1 }]}><div class="hero-statnum">{st.value}</div><div class="hero-statlabel">{st.label}</div></div>
          ))}
        </div>
        <p class="hero-new">New here? <a href={url('get-started')}>Start with our 3-step first-visit guide →</a></p>
      </div>
      <div class="hero-media">
        <div class="hero-frame" id="hero-carousel">
          {heroPhotos.map((src, i) => (
            i === 0
              ? <div class="hero-slide" style={`background-image:url('${src}'); opacity:1`}></div>
              : <div class="hero-slide" data-bg={src} style="opacity:0"></div>
          ))}
        </div>
        <div class="hero-badge">75 Carl Hall Rd<br>Downsview Park</div>
      </div>
    </div>
  </section>

  <!-- BOOK ONLINE STRIP -->
  <div class="bookstrip">
    <div class="container bookstrip-inner">
      <i class="bi bi-calendar-check" aria-hidden="true"></i>
      <span>Real-time availability for private lessons, parties and more — book online in a few clicks.</span>
      <a href={links.booking} target="_blank" rel="noopener">Book online <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
    </div>
  </div>

  <!-- OFFERINGS -->
  <section id="offerings" class="section container offerings">
    <div class="offerings-head">
      <SectionHeader num="01" eyebrow="Where to start" title="Three ways to get moving" description="Drop in to play, book a class, send the kids to camp, or throw a party. Tap a card for what's inside." />
    </div>
    <div class="grid-cards">
      {offerings.map((o) => <OfferingCard {...o} href={url(o.key)} />)}
    </div>
  </section>

  <!-- CAMPS BAND -->
  <section id="camps" class="camps-band">
    <div class="container">
      <div class="camps-head">
        <div>
          <div class="camps-eyebrow">02 — Dated &amp; filling up</div>
          <h2 class="camps-title">Camps booking now</h2>
          <p class="camps-lead">Dated sessions open for registration — Summer weeks and the next P.A. Day. 9 AM–2 PM with a late-pickup option. $350 a week or $90 a single day.</p>
        </div>
        <a href={url('camps')} class="camps-all">All camps <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
      </div>
      <div class="camps-grid">
        {camps.map((c) => (
          <div class="camp-card">
            <div class="camp-strip" style={`background:${c.color}`}></div>
            <div class="camp-body">
              <div class="camp-top">
                <span class="camp-badge" style={`background:${c.color}`}>{c.badge}</span>
                <span class="camp-status" style={`color:${c.statusColor}`}><span class="dot" style={`background:${c.statusColor}`}></span>{c.status}</span>
              </div>
              <h3 class="camp-title">{c.title}</h3>
              <div class="camp-rows">
                {c.rows.map((r) => (
                  <div class="camp-row"><i class={`bi ${r.icon}`} style={`color:${c.color}`} aria-hidden="true"></i>{r.text}</div>
                ))}
              </div>
              <div class="camp-foot">
                <span class="camp-price" style={`color:${c.color}`}>{c.price}</span>
                <a href={c.href} target="_blank" rel="noopener" class="camp-resv">Reserve <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Reviews eyebrow="03 — What people say" />

  <section class="section container final-cta">
    <CtaBand cards={[
      { theme: 'dark', eyebrow: 'Passes & memberships', title: 'See the Price List', icon: 'bi-tag-fill', href: url('pricing') },
      { theme: 'light', eyebrow: 'All classes, one view', title: 'Group Class Schedule', icon: 'bi-calendar3', href: url('schedule') },
    ]} />
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero { background: var(--ink); color: #fff; position: relative; overflow: hidden; }
  .hero-glow { position: absolute; inset: 0; background: radial-gradient(680px 360px at 90% -12%, rgba(255,212,0,.13), transparent 70%); }
  .hero-inner { padding-block: 66px 30px; display: grid; grid-template-columns: 1.05fr .95fr; gap: 50px; align-items: center; position: relative; }
  .hero-kicker { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--brand); margin-bottom: 22px; }
  .hero-kicker-rule { width: 22px; height: 2px; background: var(--brand); }
  .hero-title { font: 800 clamp(40px, 9.5vw, 60px)/1 var(--font-display); letter-spacing: -.022em; margin-bottom: 20px; text-wrap: balance; }
  .hero-lead { font: 400 16px/1.55 var(--font-body); color: rgba(255,255,255,.72); max-width: 470px; margin-bottom: 32px; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
  .hero-actions .btn { padding: 16px 26px; font-size: 15px; border-radius: 12px; }
  .hero-stats { display: flex; flex-wrap: wrap; margin-top: 36px; border-top: 1px solid rgba(255,255,255,.12); }
  .hero-stat { padding: 20px 28px 0 0; margin-right: 28px; border-right: 1px solid rgba(255,255,255,.12); }
  .hero-stat.last { border-right: 0; margin-right: 0; padding-right: 0; }
  .hero-statnum { font: 800 26px/1 var(--font-display); color: var(--brand); }
  .hero-statlabel { font: 600 12.5px/1.3 var(--font-body); color: rgba(255,255,255,.6); margin-top: 6px; }
  .hero-new { font: 500 14px/1.6 var(--font-body); color: rgba(255,255,255,.55); margin-top: 26px; }
  .hero-new a { color: var(--brand); text-decoration: none; font-weight: 700; }
  .hero-media { position: relative; }
  .hero-frame { position: relative; aspect-ratio: 5/4; border-radius: 18px; overflow: hidden; box-shadow: 0 30px 60px -25px rgba(0,0,0,.7); border: 3px solid rgba(255,255,255,.08); background: #2a2724; }
  .hero-slide { position: absolute; inset: 0; background-size: cover; background-position: center; transition: opacity 1s ease; }
  .hero-badge { position: absolute; bottom: -16px; right: -10px; background: var(--brand); color: var(--ink); font: 800 13px/1.2 var(--font-display); text-transform: uppercase; letter-spacing: .03em; padding: 13px 16px; border-radius: 12px; box-shadow: 0 12px 30px -10px rgba(0,0,0,.5); }

  /* BOOK STRIP */
  .bookstrip { background: var(--ink); }
  .bookstrip-inner { padding-bottom: 26px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .bookstrip-inner > i { font-size: 20px; color: var(--brand); }
  .bookstrip-inner span { font: 600 14px/1.6 var(--font-body); color: rgba(255,255,255,.7); }
  .bookstrip-inner a { margin-left: auto; font: 800 13px/1 var(--font-display); text-transform: uppercase; letter-spacing: .04em; color: var(--brand); text-decoration: none; display: inline-flex; align-items: center; gap: 7px; }

  /* OFFERINGS (flip cards live in OfferingCard.astro) */
  .offerings { scroll-margin-top: 80px; padding-block: 48px 56px; }
  .offerings-head { margin-bottom: 26px; }

  /* CAMPS BAND */
  .camps-band { background: var(--ink); color: #fff; }
  .camps-band .container { padding-block: 48px; }
  .camps-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-bottom: 26px; }
  .camps-eyebrow { font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--brand); margin-bottom: 12px; }
  .camps-title { font: 800 clamp(28px,5vw,36px)/1.04 var(--font-display); letter-spacing: -.018em; margin-bottom: 8px; }
  .camps-lead { font: 400 15px/1.55 var(--font-body); color: rgba(255,255,255,.66); max-width: 540px; }
  .camps-all { font: 800 13px/1 var(--font-display); text-transform: uppercase; letter-spacing: .04em; color: var(--brand); text-decoration: none; display: inline-flex; align-items: center; gap: 7px; white-space: nowrap; }
  .camps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 18px; }
  .camp-card { display: flex; flex-direction: column; background: #fff; color: var(--ink); border-radius: 16px; overflow: hidden; box-shadow: 0 18px 44px -28px rgba(0,0,0,.6); }
  .camp-strip { height: 5px; }
  .camp-body { padding: 24px 26px 26px; display: flex; flex-direction: column; flex: 1; }
  .camp-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 14px; }
  .camp-badge { font: 700 10px/1 var(--font-display); letter-spacing: .08em; text-transform: uppercase; color: #fff; padding: 6px 10px; border-radius: 999px; }
  .camp-status { display: inline-flex; align-items: center; gap: 6px; font: 700 11px/1 var(--font-display); letter-spacing: .04em; text-transform: uppercase; }
  .camp-status .dot { width: 7px; height: 7px; border-radius: 50%; }
  .camp-title { font: 800 22px/1.1 var(--font-display); letter-spacing: -.01em; margin-bottom: 16px; }
  .camp-rows { display: flex; flex-direction: column; gap: 10px; margin-bottom: 18px; }
  .camp-row { display: flex; align-items: flex-start; gap: 10px; font: 600 14px/1.6 var(--font-body); color: var(--text-2); }
  .camp-row i { margin-top: 2px; flex: none; }
  .camp-foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 16px; border-top: 1px solid var(--line-soft); }
  .camp-price { font: 800 18px/1 var(--font-display); }
  .camp-resv { display: inline-flex; align-items: center; gap: 8px; background: var(--ink); color: #fff; font: 800 12.5px/1 var(--font-display); text-transform: uppercase; letter-spacing: .03em; text-decoration: none; padding: 12px 18px; border-radius: 10px; transition: gap .18s ease; }
  .camp-resv:hover { gap: 11px; }

  .final-cta { padding-block: 32px 64px; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .hero-media { order: -1; }
  }
  @media (max-width: 520px) {
    .hero-stat { padding-right: 18px; margin-right: 18px; }
    .bookstrip-inner a { margin-left: 0; }
  }
</style>

<script>
  // Hero photo carousel: cross-fade every 4s. Only the first slide's photo is
  // in the initial HTML; the other seven hydrate after the page has loaded so
  // they never compete with the critical path.
  const carousel = document.getElementById('hero-carousel');
  if (carousel) {
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.hero-slide'));
    const hydrate = () => slides.forEach((s) => {
      const bg = s.getAttribute('data-bg');
      if (bg) { s.style.backgroundImage = `url('${bg}')`; s.removeAttribute('data-bg'); }
    });
    if (document.readyState === 'complete') hydrate();
    else window.addEventListener('load', hydrate, { once: true });

    let idx = 0;
    if (slides.length > 1) {
      setInterval(() => {
        slides[idx].style.opacity = '0';
        idx = (idx + 1) % slides.length;
        slides[idx].style.opacity = '1';
      }, 4000);
    }
  }
</script>
