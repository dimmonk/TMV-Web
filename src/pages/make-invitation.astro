---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo, links, site, url } from '../data/site';

const defaultAddress = `${site.address.street} · ${site.address.locality}`;
const defaultPhoto = url('assets/invite-default-photo.png');

/** 15-minute time options across the facility's operating hours — a closed
 * set of valid values so a party time can never be mistyped or malformed. */
function timeOptions(startHour: number, endHour: number) {
  const opts: { value: string; label: string }[] = [];
  for (let h = startHour; h <= endHour; h++) {
    for (let m = 0; m < 60; m += 15) {
      if (h === endHour && m > 0) break;
      const hour12 = ((h + 11) % 12) + 1;
      const ampm = h < 12 ? 'AM' : 'PM';
      opts.push({
        value: `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`,
        label: `${hour12}:${String(m).padStart(2, '0')} ${ampm}`,
      });
    }
  }
  return opts;
}
const timeOpts = timeOptions(11, 22);
---
<BaseLayout title={seo.makeInvitation.title} description={seo.makeInvitation.description} active="events" mobileRedirect={false}>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js" is:inline></script>

  <div class="inv-intro">
    <div class="container inv-intro-inner">
      <div class="inv-intro-text">
        <div class="inv-intro-kicker"><span class="rule"></span>Birthday parties</div>
        <h1 class="inv-intro-title">Invitation maker</h1>
        <p class="inv-intro-lead">Fill in your party details, pick a style, then download to text or post — or print at home.</p>
      </div>
      <a href={links.booking} target="_blank" rel="noopener" class="btn btn-dark"><i class="bi bi-calendar-check" aria-hidden="true"></i> Book a party</a>
    </div>
  </div>

  <div class="inv-grid container">
    <!-- CONTROLS -->
    <div class="inv-controls">
      <div class="inv-card">
        <div class="inv-steplabel"><span class="inv-stepnum">1</span><div>Pick a style</div></div>
        <div class="inv-stylegrid">
          <button type="button" class="inv-style active" data-style="portrait"><div class="inv-style-swatch inv-swatch-portrait"></div><div>Invite</div></button>
          <button type="button" class="inv-style" data-style="ticket"><div class="inv-style-swatch inv-swatch-ticket"></div><div>Ticket</div></button>
          <button type="button" class="inv-style" data-style="square"><div class="inv-style-swatch inv-swatch-square"></div><div>Square</div></button>
        </div>

        <div class="inv-label">Accent colour</div>
        <div class="inv-swatches">
          <button type="button" class="inv-sw active" data-color="#ffd400" style="background:#ffd400" title="#ffd400"></button>
          <button type="button" class="inv-sw" data-color="#ffb02a" style="background:#ffb02a" title="#ffb02a"></button>
          <button type="button" class="inv-sw" data-color="#ff8fae" style="background:#ff8fae" title="#ff8fae"></button>
          <button type="button" class="inv-sw" data-color="#7fc8f0" style="background:#7fc8f0" title="#7fc8f0"></button>
          <button type="button" class="inv-sw" data-color="#8fd6a8" style="background:#8fd6a8" title="#8fd6a8"></button>
        </div>

        <div class="inv-label">Finish</div>
        <div class="inv-fingrid">
          <button type="button" class="inv-fin active" data-finish="colour"><i class="bi bi-palette-fill" aria-hidden="true"></i><div><div class="inv-fin-t">Full colour</div><div class="inv-fin-s">Bold backgrounds</div></div></button>
          <button type="button" class="inv-fin" data-finish="ink"><i class="bi bi-droplet" aria-hidden="true"></i><div><div class="inv-fin-t">Ink-friendly</div><div class="inv-fin-s">Saves home ink</div></div></button>
        </div>
      </div>

      <div class="inv-card">
        <div class="inv-steplabel"><span class="inv-stepnum">2</span><div>Party details</div></div>
        <div class="inv-fields">
          <div class="inv-row2">
            <div><label class="inv-lab" for="inv-name">Birthday kid</label><input id="inv-name" class="inv-in" value="Maya" placeholder="Name"></div>
            <div><label class="inv-lab" for="inv-age">Turning</label><input id="inv-age" class="inv-in" type="number" min="1" max="18" value="8"></div>
          </div>
          <div><label class="inv-lab" for="inv-hype">Hype line</label><input id="inv-hype" class="inv-in" value="Come flip, climb & fly" placeholder="Come flip, climb & fly"></div>
          <div><label class="inv-lab" for="inv-date">Date</label><input id="inv-date" type="date" class="inv-in"></div>
          <div class="inv-row2-even">
            <div><label class="inv-lab" for="inv-time-start">Start time</label>
              <select id="inv-time-start" class="inv-in">
                {timeOpts.map((o) => <option value={o.value} selected={o.value === '14:00'}>{o.label}</option>)}
              </select>
            </div>
            <div><label class="inv-lab" for="inv-time-end">End time</label>
              <select id="inv-time-end" class="inv-in">
                {timeOpts.map((o) => <option value={o.value} selected={o.value === '16:00'}>{o.label}</option>)}
              </select>
            </div>
          </div>
          <div><label class="inv-lab" for="inv-bring">What to bring <span class="inv-lab-note">— separate with commas</span></label><input id="inv-bring" class="inv-in" value="Clean shoes, Lots of energy" placeholder="Clean shoes, Lots of energy"></div>
          <div><label class="inv-lab" for="inv-rsvp">RSVP contact</label><input id="inv-rsvp" class="inv-in" value="Text Alex · 416-555-0142" placeholder="Text Alex · 416-555-0142"></div>
        </div>
      </div>
    </div>

    <!-- PREVIEW -->
    <div class="inv-preview">
      <div class="inv-preview-head">
        <div class="inv-preview-title">Live preview <span id="inv-finish-label" class="inv-preview-sub">· Full colour</span></div>
        <button type="button" id="inv-download" class="btn btn-dark"><i class="bi bi-download" aria-hidden="true"></i> Download PNG</button>
      </div>

      <div class="inv-stage">
        <div class="inv-stage-row" id="inv-stage-row">
          <div id="inv-bg-col" class="inv-bg-col">
            <div class="inv-bg-label">BG</div>
            <button type="button" class="inv-bg-chip active" data-bg="1" title="Background 1">1</button>
          </div>

          <div id="inv-scale-wrap" class="inv-scale-wrap">
            <div id="inv-live-card">
              <!-- PORTRAIT -->
              <div id="inv-card-portrait" class="inv-p-card">
                <div id="inv-p-photohead" class="inv-p-photohead">
                  <img id="inv-p-photo" class="inv-p-photoimg" src={defaultPhoto} alt="" />
                  <div class="inv-p-badge">You're invited!</div>
                </div>
                <div id="inv-p-inkhead" class="inv-p-inkhead" hidden>
                  <div class="inv-p-badge">You're invited!</div>
                  <img src={url('assets/tmvlogo.png')} alt="The Monkey Vault" class="inv-p-inklogo" />
                </div>
                <div class="inv-p-body">
                  <div class="inv-p-eyebrow">A parkour birthday party for</div>
                  <h2 id="inv-p-name" class="inv-p-name">Maya</h2>
                  <div class="inv-p-turning">is turning <span id="inv-p-age" class="inv-p-age">8</span></div>
                  <div id="inv-p-hype" class="inv-p-hype">"Come flip, climb & fly"</div>
                  <div class="inv-p-meta">
                    <div class="inv-p-metarow"><i class="bi bi-calendar-event" aria-hidden="true"></i><div><div id="inv-p-date" class="inv-p-metamain">Saturday, August 16</div><div id="inv-p-time" class="inv-p-metasub">2:00 – 4:00 PM</div></div></div>
                    <div class="inv-p-metarow"><i class="bi bi-geo-alt" aria-hidden="true"></i><div><div class="inv-p-metamain">{site.name}</div><div class="inv-p-metasub">{defaultAddress}</div></div></div>
                  </div>
                  <div class="inv-p-bring">
                    <span class="inv-p-bringlabel">Bring</span>
                    <div id="inv-p-bringlist" class="inv-p-bringlist"></div>
                  </div>
                  <div class="inv-p-rsvprow">
                    <div class="inv-p-rsvpcol">
                      <div class="inv-p-rsvplabel">Please RSVP</div>
                      <div id="inv-p-rsvp" class="inv-p-rsvpval">Text Alex · 416-555-0142</div>
                      <div class="inv-p-scan"><i class="bi bi-qr-code-scan" aria-hidden="true"></i>Scan to sign the waiver first</div>
                    </div>
                    <div class="inv-p-qrbox"><img class="inv-qr-img" data-qr alt="Sign the waiver first" /></div>
                  </div>
                </div>
              </div>

              <!-- TICKET -->
              <div id="inv-card-ticket" class="inv-t-card" hidden>
                <div id="inv-t-body" class="inv-t-body">
                  <div id="inv-t-glow" class="inv-t-glow"></div>
                  <div class="inv-t-brand"><img src={url('assets/tmvlogo.png')} alt="" class="inv-t-logo" /><span id="inv-t-eyebrow" class="inv-t-eyebrow">Admit One · Birthday Bash</span></div>
                  <div class="inv-t-main">
                    <div id="inv-t-of" class="inv-t-of">The party of</div>
                    <h2 id="inv-t-name" class="inv-t-name">Maya</h2>
                    <div id="inv-t-turns" class="inv-t-turns">turns 8 — Come flip, climb & fly</div>
                    <div class="inv-t-chips">
                      <span id="inv-t-chip-date" class="inv-t-chip"><i class="bi bi-calendar-event" aria-hidden="true"></i><span id="inv-t-date">Saturday, August 16</span></span>
                      <span id="inv-t-chip-time" class="inv-t-chip"><i class="bi bi-clock" aria-hidden="true"></i><span id="inv-t-time">2:00 – 4:00 PM</span></span>
                      <span id="inv-t-chip-venue" class="inv-t-chip"><i class="bi bi-geo-alt" aria-hidden="true"></i><span>{site.name}</span></span>
                    </div>
                    <div id="inv-t-bring" class="inv-t-bring"><span id="inv-t-bringlabel" class="inv-t-bringlabel">Bring:</span> <span id="inv-t-bringline">Clean shoes, Lots of energy</span></div>
                  </div>
                </div>
                <div class="inv-t-perf"></div>
                <div id="inv-t-stub" class="inv-t-stub">
                  <div class="inv-t-stublabel">Your invite</div>
                  <div class="inv-t-qrbox"><img class="inv-qr-img" data-qr alt="Sign the waiver first" /></div>
                  <div class="inv-t-stubtitle">Sign the waiver first</div>
                  <div id="inv-t-rsvp" class="inv-t-stubrsvp">Text Alex · 416-555-0142</div>
                  <div class="inv-t-stubaddr">{defaultAddress}</div>
                </div>
              </div>

              <!-- SQUARE -->
              <div id="inv-card-square" class="inv-sq-card" hidden>
                <div id="inv-sq-stripe" class="inv-sq-stripe" hidden></div>
                <div id="inv-sq-agebg" class="inv-sq-agebg">8</div>
                <div class="inv-sq-flag">You're invited!</div>
                <div class="inv-sq-brand"><img src={url('assets/tmvlogo.png')} alt="" class="inv-sq-logo" /><span>{site.name}</span></div>
                <div class="inv-sq-main">
                  <div class="inv-sq-tag">It's a parkour party!</div>
                  <h2 class="inv-sq-name">Maya<br>turns <span id="inv-sq-age">8</span></h2>
                  <div id="inv-sq-hype" class="inv-sq-hype">Come flip, climb & fly</div>
                  <div class="inv-sq-rows">
                    <div class="inv-sq-row"><i class="bi bi-calendar-event" aria-hidden="true"></i><span id="inv-sq-datetime">Saturday, August 16 · 2:00 – 4:00 PM</span></div>
                    <div class="inv-sq-row"><i class="bi bi-geo-alt" aria-hidden="true"></i><span id="inv-sq-venueaddr">{site.name} · {defaultAddress}</span></div>
                    <div class="inv-sq-row"><i class="bi bi-bag-check" aria-hidden="true"></i><span id="inv-sq-bring">Bring Clean shoes, Lots of energy</span></div>
                  </div>
                </div>
                <div class="inv-sq-foot">
                  <div class="inv-sq-qrbox"><img class="inv-qr-img" data-qr alt="Sign the waiver first" /></div>
                  <div>
                    <div class="inv-sq-footlabel">Sign the waiver first</div>
                    <div id="inv-sq-rsvp" class="inv-sq-footrsvp">Text Alex · 416-555-0142</div>
                  </div>
                  <span class="inv-sq-handle">@themonkeyvault</span>
                </div>
              </div>
            </div>
          </div>

          <div id="inv-photo-col" class="inv-photo-col">
            <button type="button" id="inv-replace-photo" class="inv-photobtn inv-photobtn-dark"><i class="bi bi-upload" aria-hidden="true"></i>Replace</button>
            <button type="button" id="inv-remove-photo" class="inv-photobtn"><i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>Remove</button>
          </div>
          <input type="file" id="inv-photo-input" accept="image/*" hidden />
        </div>
      </div>
      <p class="inv-hint"><i class="bi bi-info-circle" aria-hidden="true"></i><span id="inv-hint-text">Download a high-res PNG to text or post to your story, or print it. In the print dialog you can scale it or fit several per page.</span></p>
    </div>
  </div>
</BaseLayout>

<style>
  .inv-intro { background: #fff; border-bottom: 1px solid var(--line); }
  .inv-intro-inner { padding-block: 26px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .inv-intro-text { flex: 1; min-width: 240px; }
  .inv-intro-kicker { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin-bottom: 10px; }
  .inv-intro-kicker .rule { width: 22px; height: 2px; background: var(--brand); }
  .inv-intro-title { font: 800 30px/1.02 var(--font-display); letter-spacing: -.02em; margin: 0 0 6px; }
  .inv-intro-lead { font: 400 14px/1.5 var(--font-body); color: var(--muted); margin: 0; max-width: 520px; }

  .inv-grid { display: grid; grid-template-columns: 396px minmax(0, 1fr); gap: 32px; align-items: start; padding-block: 28px 60px; }
  .inv-controls { display: flex; flex-direction: column; gap: 24px; }
  .inv-card { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 20px; }
  .inv-steplabel { display: flex; align-items: center; gap: 9px; margin-bottom: 14px; font: 800 14px/1 var(--font-display); }
  .inv-stepnum { flex: none; width: 22px; height: 22px; border-radius: 7px; background: var(--ink); color: var(--brand); font: 800 12px/22px var(--font-display); text-align: center; }
  .inv-stylegrid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 18px; }
  .inv-style { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; height: 74px; cursor: pointer; border-radius: 12px; transition: all .12s; background: #fff; color: #a29e95; border: 1px solid var(--line); font: 800 11px/1 var(--font-display); }
  .inv-style.active { background: #fffbe6; color: var(--ink); border: 2px solid var(--brand); }
  .inv-style-swatch { border-radius: 4px; background: currentColor; opacity: .9; }
  .inv-swatch-portrait { width: 26px; height: 34px; }
  .inv-swatch-ticket { width: 38px; height: 22px; }
  .inv-swatch-square { width: 28px; height: 28px; }
  .inv-label { font: 700 11px/1 var(--font-display); letter-spacing: .05em; text-transform: uppercase; color: var(--muted-3); margin-bottom: 10px; }
  .inv-swatches { display: flex; gap: 10px; margin-bottom: 18px; }
  .inv-sw { width: 34px; height: 34px; border-radius: 9px; cursor: pointer; border: 1px solid rgba(0,0,0,.1); }
  .inv-sw.active { border: 2px solid var(--ink); box-shadow: 0 0 0 2px #fff inset; }
  .inv-fingrid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .inv-fin { display: flex; align-items: center; gap: 10px; cursor: pointer; padding: 13px 14px; border-radius: 12px; transition: all .12s; text-align: left; background: #fff; color: var(--ink); border: 1px solid var(--line); font-size: 16px; }
  .inv-fin.active { background: var(--ink); color: #fff; border: 1px solid var(--ink); }
  .inv-fin-t { font: 800 12.5px/1 var(--font-display); }
  .inv-fin-s { font: 600 10px/1.2 var(--font-body); opacity: .7; margin-top: 3px; }

  .inv-fields { display: flex; flex-direction: column; gap: 15px; }
  .inv-row2 { display: grid; grid-template-columns: 1fr 96px; gap: 12px; }
  .inv-row2-even { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .inv-lab { display: block; font: 700 11px/1 var(--font-display); letter-spacing: .05em; text-transform: uppercase; color: var(--muted-3); margin-bottom: 7px; }
  .inv-lab-note { text-transform: none; letter-spacing: 0; color: #b3b0a8; font-weight: 600; }
  .inv-in { width: 100%; font: 600 14px/1.3 -apple-system, system-ui, sans-serif; color: var(--ink); background: #fff; border: 1px solid var(--line); border-radius: 10px; padding: 11px 12px; outline: none; transition: border-color .12s, box-shadow .12s; }
  .inv-in:focus { border-color: var(--ink); box-shadow: 0 0 0 3px rgba(33,31,27,.08); }

  .inv-preview { position: sticky; top: 20px; display: flex; flex-direction: column; gap: 16px; min-width: 0; }
  .inv-preview-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .inv-preview-title { font: 800 15px/1 var(--font-display); }
  .inv-preview-sub { font: 600 12.5px/1 var(--font-body); color: var(--muted-3); }
  .inv-stage { background: #eceae5; border: 1px solid #e3e0d8; border-radius: 18px; padding: 44px 36px; min-height: 680px; display: flex; align-items: center; justify-content: center; background-image: radial-gradient(rgba(33,31,27,.05) 1px, transparent 1px); background-size: 16px 16px; overflow: hidden; }
  .inv-stage-row { display: flex; align-items: center; gap: 20px; max-width: 100%; }
  .inv-hint { display: flex; align-items: flex-start; gap: 9px; font: 500 12.5px/1.5 var(--font-body); color: var(--muted-3); }
  .inv-hint i { margin-top: 2px; color: #b3b0a8; }

  /* [hidden] must always win, full stop. Several elements on this page set
     an explicit `display` (flex/block) at the same specificity tier as the
     browser's own [hidden]{display:none} UA rule, so source order (not the
     hidden state) decides which one applies — every one of those toggles
     silently stayed visible until this was added. !important removes the
     specificity race entirely instead of chasing it element by element. */
  [hidden] { display: none !important; }

  /* Scale the whole card down to fit the available stage width instead of
     letting the fixed-px cards (440/660/470) force horizontal scroll on
     narrower viewports — set via JS as a CSS custom property. */
  .inv-scale-wrap { transform: scale(var(--inv-scale, 1)); transform-origin: center; transition: transform .15s ease; }

  /* BG picker (Invite style only) — aligned to the top of the card, level
     with the photo it controls, instead of centered on the whole row. */
  .inv-bg-col { display: flex; flex-direction: column; align-items: center; gap: 10px; flex: none; align-self: flex-start; margin-top: 4px; }
  .inv-bg-label { font: 700 9px/1 var(--font-display); letter-spacing: .08em; text-transform: uppercase; color: #a29e95; margin-bottom: 2px; }
  .inv-bg-chip { width: 44px; height: 44px; border-radius: 10px; cursor: pointer; font: 800 14px/1 var(--font-display); background: #fffbe6; color: var(--ink); border: 2px solid var(--brand); }

  /* Replace / Remove photo (Invite style only) — same top alignment, same reason. */
  .inv-photo-col { display: flex; flex-direction: column; gap: 10px; width: 104px; flex: none; align-self: flex-start; margin-top: 4px; }
  .inv-photobtn { display: flex; flex-direction: column; align-items: center; gap: 5px; cursor: pointer; font: 800 11px/1 var(--font-display); text-transform: uppercase; letter-spacing: .03em; padding: 13px 8px; border-radius: 10px; background: #fff; color: var(--ink); border: 1px solid #d8d4cc; }
  .inv-photobtn i { font-size: 16px; }
  .inv-photobtn-dark { background: var(--ink); color: #fff; border: 0; }
  .inv-photobtn-dark i { color: var(--brand); }

  /* PORTRAIT */
  .inv-p-card { width: 440px; min-height: 616px; background: #fff; border: 0; border-radius: 20px; overflow: hidden; box-shadow: 0 2px 4px rgba(28,25,23,.06), 0 40px 70px -40px rgba(28,25,23,.55); display: flex; flex-direction: column; }
  .inv-p-photohead { position: relative; height: 240px; background: var(--ink); flex: none; }
  .inv-p-photoimg { width: 100%; height: 100%; object-fit: cover; display: block; }
  .inv-p-badge { position: absolute; top: 16px; left: 16px; display: inline-flex; align-items: center; gap: 8px; background: var(--inv-accent, #ffd400); color: var(--ink); font: 900 12px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; padding: 9px 13px; border-radius: 8px; box-shadow: 0 8px 20px -10px rgba(0,0,0,.5); }
  .inv-p-inkhead { flex: none; background: #fff; border-bottom: 2px solid var(--inv-accent, #ffd400); padding: 18px 22px; display: flex; align-items: center; justify-content: space-between; }
  .inv-p-inkhead .inv-p-badge { position: static; box-shadow: none; }
  .inv-p-inklogo { width: 38px; height: 38px; object-fit: contain; }
  .inv-p-body { flex: 1; padding: 24px 26px 20px; display: flex; flex-direction: column; }
  .inv-p-eyebrow { font: 700 11px/1 var(--font-display); letter-spacing: .16em; text-transform: uppercase; color: #a29e95; margin-bottom: 9px; }
  .inv-p-name { font: 900 40px/.92 var(--font-display); letter-spacing: -.03em; margin: 0 0 6px; }
  .inv-p-turning { font: 800 19px/1 var(--font-display); letter-spacing: -.01em; margin: 0 0 12px; color: var(--ink); }
  .inv-p-age { background: var(--inv-accent, #ffd400); padding: 2px 9px; border-radius: 7px; }
  .inv-p-hype { font: 600 13px/1.4 -apple-system, system-ui, sans-serif; font-style: italic; color: var(--muted); margin: 0 0 16px; }
  .inv-p-meta { display: flex; flex-direction: column; gap: 11px; margin-bottom: 16px; }
  .inv-p-metarow { display: flex; align-items: flex-start; gap: 11px; }
  .inv-p-metarow i { color: var(--ink); font-size: 15px; margin-top: 1px; }
  .inv-p-metamain { font: 800 13.5px/1.15 var(--font-display); }
  .inv-p-metasub { font: 600 12.5px/1.2 var(--font-body); color: var(--muted); margin-top: 3px; }
  .inv-p-bring { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: auto; }
  .inv-p-bringlist { display: flex; flex-wrap: wrap; gap: 6px; }
  .inv-p-bringlabel { font: 700 10px/1 var(--font-display); letter-spacing: .06em; text-transform: uppercase; color: #a29e95; width: 100%; margin-bottom: 2px; }
  .inv-p-rsvprow { display: flex; align-items: center; gap: 14px; margin-top: 18px; padding-top: 16px; border-top: 1px dashed #d8d4cc; }
  .inv-p-rsvpcol { flex: 1; min-width: 0; }
  .inv-p-rsvplabel { font: 800 11px/1 var(--font-display); letter-spacing: .08em; text-transform: uppercase; color: var(--ink); margin-bottom: 5px; }
  .inv-p-rsvpval { font: 600 12.5px/1.35 var(--font-body); color: var(--muted); margin-bottom: 9px; }
  .inv-p-scan { display: inline-flex; align-items: center; gap: 6px; font: 700 10px/1.1 var(--font-display); letter-spacing: .05em; text-transform: uppercase; color: #a29e95; }
  .inv-p-scan i { font-size: 12px; color: var(--ink); }
  .inv-p-qrbox { flex: none; width: 88px; height: 88px; border-radius: 10px; overflow: hidden; background: #fff; border: 1px solid var(--line); padding: 6px; }
  .inv-qr-img { width: 100%; height: 100%; display: block; }

  /* TICKET */
  .inv-t-card { width: 660px; height: 300px; display: flex; border-radius: 18px; overflow: hidden; box-shadow: 0 2px 4px rgba(28,25,23,.06), 0 40px 70px -40px rgba(28,25,23,.55); position: relative; }
  .inv-t-body { flex: 1; background: var(--ink); color: #fff; padding: 26px 28px; display: flex; flex-direction: column; position: relative; overflow: hidden; }
  .inv-t-glow { position: absolute; inset: 0; }
  .inv-t-brand { position: relative; display: flex; align-items: center; gap: 10px; margin-bottom: auto; }
  .inv-t-logo { width: 30px; height: 30px; object-fit: contain; }
  .inv-t-eyebrow { font: 900 11px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--inv-accent, #ffd400); }
  .inv-t-main { position: relative; }
  .inv-t-of { font: 700 11px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.5); margin-bottom: 7px; }
  .inv-t-name { font: 900 38px/.9 var(--font-display); letter-spacing: -.03em; margin: 0 0 4px; }
  .inv-t-turns { font: 800 16px/1 var(--font-display); margin-bottom: 16px; }
  .inv-t-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .inv-t-chip { display: inline-flex; align-items: center; gap: 6px; font: 700 11px/1 var(--font-body); border-radius: 8px; padding: 8px 11px; }
  .inv-t-bring { font: 600 11.5px/1.4 var(--font-body); margin-top: 12px; }
  .inv-t-bringlabel { font-weight: 800; }
  .inv-t-perf { width: 2px; flex: none; background-image: radial-gradient(circle at center, transparent 5px, #eceae5 5px, #eceae5 6.5px, transparent 6.5px); background-size: 100% 15px; background-repeat: repeat-y; }
  .inv-t-stub { flex: none; width: 186px; background: var(--inv-accent, #ffd400); color: var(--ink); padding: 22px 20px; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .inv-t-stublabel { font: 900 10px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; margin-bottom: 14px; }
  .inv-t-qrbox { width: 104px; height: 104px; border-radius: 11px; overflow: hidden; background: #fff; box-shadow: 0 8px 18px -10px rgba(0,0,0,.4); padding: 7px; }
  .inv-t-stubtitle { font: 800 11px/1.1 var(--font-display); letter-spacing: .04em; text-transform: uppercase; margin-top: 11px; }
  .inv-t-stubrsvp { font: 600 11px/1.35 var(--font-body); margin-top: 8px; opacity: .8; }
  .inv-t-stubaddr { margin-top: auto; padding-top: 12px; font: 700 9px/1.3 var(--font-display); letter-spacing: .06em; text-transform: uppercase; opacity: .65; }

  /* SQUARE */
  .inv-sq-card { width: 470px; height: 470px; background: var(--inv-accent, #ffd400); color: var(--ink); border: 0; border-radius: 20px; overflow: hidden; position: relative; box-shadow: 0 2px 4px rgba(28,25,23,.06), 0 40px 70px -40px rgba(28,25,23,.55); padding: 30px 32px; display: flex; flex-direction: column; }
  .inv-sq-stripe { position: absolute; top: 0; left: 0; right: 0; height: 8px; background: var(--inv-accent, #ffd400); }
  .inv-sq-agebg { position: absolute; right: -24px; bottom: -70px; font: 900 340px/.7 var(--font-display); color: var(--ink); opacity: .07; pointer-events: none; letter-spacing: -.05em; }
  .inv-sq-flag { position: absolute; top: 96px; right: 26px; transform: rotate(9deg); background: var(--ink); color: var(--inv-accent, #ffd400); font: 900 12px/1 var(--font-display); letter-spacing: .08em; text-transform: uppercase; padding: 9px 13px; border-radius: 9px; }
  .inv-sq-brand { position: relative; display: flex; align-items: center; gap: 9px; margin-bottom: auto; }
  .inv-sq-logo { width: 34px; height: 34px; object-fit: contain; }
  .inv-sq-brand span { font: 900 12px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; }
  .inv-sq-main { position: relative; }
  .inv-sq-tag { font: 800 15px/1 var(--font-display); letter-spacing: .02em; margin-bottom: 2px; }
  .inv-sq-name { font: 900 58px/.86 var(--font-display); letter-spacing: -.035em; margin: 0 0 6px; }
  .inv-sq-hype { font: 700 14px/1.35 var(--font-body); margin: 0 0 18px; max-width: 300px; }
  .inv-sq-rows { display: flex; flex-direction: column; gap: 6px; font: 700 13px/1.3 var(--font-body); }
  .inv-sq-row { display: flex; align-items: center; gap: 9px; }
  .inv-sq-foot { position: relative; display: flex; align-items: center; gap: 12px; margin-top: 20px; padding-top: 16px; border-top: 2px solid rgba(33,31,27,.15); }
  .inv-sq-qrbox { width: 58px; height: 58px; border-radius: 9px; overflow: hidden; background: #fff; border: 1px solid var(--line); padding: 5px; flex: none; }
  .inv-sq-footlabel { font: 900 12px/1 var(--font-display); letter-spacing: .04em; text-transform: uppercase; }
  .inv-sq-footrsvp { font: 700 12px/1.35 var(--font-body); margin-top: 4px; }
  .inv-sq-handle { margin-left: auto; font: 800 12px/1 var(--font-display); }

  @media (max-width: 1080px) {
    .inv-grid { grid-template-columns: minmax(0, 1fr); }
    .inv-preview { position: static; }
  }
  @media (max-width: 520px) {
    .inv-stage { padding: 24px 16px; }
  }
</style>

<!-- The bring pills are injected at runtime via innerHTML, so they never get
     Astro's data-astro-cid attribute and scoped rules can't match them. These
     two rules must be global; the #inv-p-bringlist anchor keeps them from
     leaking anywhere else. -->
<style is:global>
  #inv-p-bringlist .inv-p-bringitem { display: inline-flex; align-items: center; gap: 5px; font: 700 11px/1 var(--font-body); color: var(--ink); background: #f3f2ee; border: 1px solid var(--line); border-radius: 999px; padding: 6px 11px; }
  #inv-p-bringlist .inv-p-bringitem i { font-size: 12px; color: #1b6b2f; }
</style>

<script define:vars={{ FIXED_VENUE: site.name, FIXED_ADDRESS: defaultAddress, DEFAULT_PHOTO: defaultPhoto, FIXED_WAIVER_URL: links.waiver }}>
  const $ = (id) => document.getElementById(id);
  const root = document.documentElement;

  const state = {
    style: 'portrait',
    ink: false,
    accent: '#ffd400',
    photoSrc: DEFAULT_PHOTO,
  };

  function qrUrl(data) {
    return 'https://api.qrserver.com/v1/create-qr-code/?size=240x240&margin=0&data=' +
      encodeURIComponent(data) + '&color=211f1b&bgcolor=ffffff';
  }

  function applyQr() {
    const qrTarget = qrUrl(FIXED_WAIVER_URL);
    document.querySelectorAll('#inv-live-card img[data-qr]').forEach((img) => {
      if (img.src !== qrTarget) img.src = qrTarget;
    });
  }

  function fieldVal(id) {
    return $(id)?.value ?? '';
  }

  function bringList() {
    return fieldVal('inv-bring').split(',').map((s) => s.trim()).filter(Boolean);
  }

  function formatDate(iso) {
    if (!iso) return '';
    const [y, m, d] = iso.split('-').map(Number);
    return new Date(y, m - 1, d).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
  }

  function formatTimeLabel(hhmm) {
    const [h, m] = hhmm.split(':').map(Number);
    const hour12 = ((h + 11) % 12) + 1;
    const ampm = h < 12 ? 'AM' : 'PM';
    return `${hour12}:${String(m).padStart(2, '0')} ${ampm}`;
  }

  function formatTimeRange(startVal, endVal) {
    if (!startVal || !endVal) return '';
    const startAmpm = Number(startVal.split(':')[0]) < 12 ? 'AM' : 'PM';
    const endAmpm = Number(endVal.split(':')[0]) < 12 ? 'AM' : 'PM';
    const startLabel = formatTimeLabel(startVal);
    const endLabel = formatTimeLabel(endVal);
    return startAmpm === endAmpm
      ? `${startLabel.replace(/ (AM|PM)$/, '')} – ${endLabel}`
      : `${startLabel} – ${endLabel}`;
  }

  function nextSaturdayISO() {
    const d = new Date();
    d.setDate(d.getDate() + ((6 - d.getDay() + 7) % 7));
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function render() {
    const name = fieldVal('inv-name') || 'Maya';
    const age = fieldVal('inv-age') || '8';
    const date = formatDate(fieldVal('inv-date'));
    const time = formatTimeRange(fieldVal('inv-time-start'), fieldVal('inv-time-end'));
    const venue = FIXED_VENUE;
    const address = FIXED_ADDRESS;
    const rsvp = fieldVal('inv-rsvp');
    const hype = fieldVal('inv-hype');
    const bring = bringList();
    const bringLine = bring.join(', ');

    root.style.setProperty('--inv-accent', state.accent);
    $('inv-p-photo').src = state.photoSrc;

    // Portrait
    $('inv-p-name').textContent = name;
    $('inv-p-age').textContent = age;
    $('inv-p-hype').textContent = `"${hype}"`;
    $('inv-p-date').textContent = date;
    $('inv-p-time').textContent = time;
    $('inv-p-rsvp').textContent = rsvp;
    $('inv-p-bringlist').innerHTML = bring.map((b) => `<span class="inv-p-bringitem"><i class="bi bi-check2"></i>${b}</span>`).join('');

    // Ticket
    $('inv-t-name').textContent = name;
    $('inv-t-turns').textContent = `turns ${age} — ${hype}`;
    $('inv-t-date').textContent = date;
    $('inv-t-time').textContent = time;
    $('inv-t-bringline').textContent = bringLine;
    $('inv-t-rsvp').textContent = rsvp;

    // Square
    $('inv-sq-age').textContent = age;
    $('inv-sq-hype').textContent = hype;
    $('inv-sq-datetime').textContent = `${date} · ${time}`;
    $('inv-sq-venueaddr').textContent = `${venue} · ${address}`;
    $('inv-sq-bring').textContent = `Bring ${bringLine}`;
    $('inv-sq-rsvp').textContent = rsvp;
    $('inv-sq-agebg').textContent = age;
    const sqNameH2 = document.querySelector('.inv-sq-name');
    if (sqNameH2) sqNameH2.innerHTML = `${name}<br>turns <span id="inv-sq-age">${age}</span>`;

    applyQr();
    applyFinish();
    applyStyle();
    fitScale();
  }

  function applyStyle() {
    $('inv-card-portrait').hidden = state.style !== 'portrait';
    $('inv-card-ticket').hidden = state.style !== 'ticket';
    $('inv-card-square').hidden = state.style !== 'square';
    $('inv-bg-col').hidden = state.style !== 'portrait';
    $('inv-photo-col').hidden = state.style !== 'portrait';
    document.querySelectorAll('.inv-style').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.style === state.style);
    });
  }

  function applyFinish() {
    const ink = state.ink;
    const accent = state.accent;
    document.querySelectorAll('.inv-fin').forEach((btn) => {
      btn.classList.toggle('active', (btn.dataset.finish === 'ink') === ink);
    });
    $('inv-finish-label').textContent = ink ? '· Ink-friendly' : '· Full colour';
    $('inv-hint-text').textContent = ink
      ? 'Ink-friendly swaps the heavy backgrounds for white with accent detailing — far less ink at home. Download a PNG to text or post, or print and arrange as many per page as you like in your print dialog.'
      : 'Download a high-res PNG to text or post to your story, or print it. In the print dialog you can scale it or fit several per page. Drop a photo into the Invite style first.';

    // portrait
    $('inv-p-photohead').hidden = ink;
    $('inv-p-inkhead').hidden = !ink;
    $('inv-card-portrait').style.border = ink ? '1px solid #e6e4dd' : '0';

    // ticket
    const tkBodyBg = ink ? '#ffffff' : '#211f1b';
    const tkBodyText = ink ? '#211f1b' : '#ffffff';
    const tkEyebrow = ink ? '#211f1b' : accent;
    const tkMuted = ink ? '#a29e95' : 'rgba(255,255,255,.5)';
    const tkChipBg = ink ? '#f3f2ee' : 'rgba(255,255,255,.09)';
    const tkChipBorder = ink ? '#e6e4dd' : 'rgba(255,255,255,.14)';
    const tkIcon = ink ? '#211f1b' : accent;
    const tkBring = ink ? '#6a6760' : 'rgba(255,255,255,.6)';
    const tkStubBg = ink ? '#ffffff' : accent;

    const tBody = $('inv-t-body');
    tBody.style.background = tkBodyBg;
    tBody.style.color = tkBodyText;
    tBody.style.border = ink ? '1px solid #e0ddd5' : '0';
    tBody.style.borderRight = ink ? '0' : '';
    $('inv-t-glow').style.background = ink ? 'transparent'
      : `radial-gradient(460px 220px at 100% -20%, color-mix(in srgb, ${accent} 22%, transparent), transparent 70%)`;
    $('inv-t-eyebrow').style.color = tkEyebrow;
    $('inv-t-of').style.color = tkMuted;
    $('inv-t-name').style.color = tkBodyText;
    $('inv-t-turns').style.color = tkBodyText;
    $('inv-t-bringlabel').style.color = tkBodyText;
    $('inv-t-bring').style.color = tkBring;
    document.querySelectorAll('.inv-t-chip').forEach((chip) => {
      chip.style.color = tkBodyText;
      chip.style.background = tkChipBg;
      chip.style.borderColor = tkChipBorder;
      chip.style.borderWidth = '1px';
      chip.style.borderStyle = 'solid';
    });
    document.querySelectorAll('.inv-t-chip i').forEach((ic) => { ic.style.color = tkIcon; });
    const stub = $('inv-t-stub');
    stub.style.background = tkStubBg;
    stub.style.border = ink ? '1px solid #e0ddd5' : '0';
    stub.style.borderLeft = ink ? `3px solid ${accent}` : '';
    stub.querySelector('.inv-t-qrbox').style.boxShadow = ink ? 'none' : '0 8px 18px -10px rgba(0,0,0,.4)';
    stub.querySelector('.inv-t-qrbox').style.border = ink ? '1px solid #e6e4dd' : '0';

    // square
    const sqCard = $('inv-card-square');
    sqCard.style.background = ink ? '#ffffff' : accent;
    sqCard.style.border = ink ? '1px solid #e6e4dd' : '0';
    $('inv-sq-stripe').hidden = !ink;
  }

  // Scale the whole preview card down to fit the stage without ever needing
  // horizontal scroll (the ticket layout, at 660px plus the BG/photo side
  // columns, is wider than the available column on laptop-size viewports).
  function fitScale() {
    const stageRow = $('inv-stage-row');
    const wrap = $('inv-scale-wrap');
    if (!stageRow || !wrap) return;
    wrap.style.setProperty('--inv-scale', '1');
    // measure natural (unscaled) width of the whole row against the stage's content box
    const stage = stageRow.parentElement;
    const available = stage.clientWidth - 72; // minus .inv-stage's own horizontal padding
    const natural = stageRow.scrollWidth;
    const scale = natural > available ? Math.max(0.5, available / natural) : 1;
    wrap.style.setProperty('--inv-scale', String(scale));
  }

  // ---- wiring ----
  document.querySelectorAll('.inv-style').forEach((btn) => {
    btn.addEventListener('click', () => { state.style = btn.dataset.style || 'portrait'; render(); });
  });
  document.querySelectorAll('.inv-sw').forEach((btn) => {
    btn.addEventListener('click', () => {
      state.accent = btn.dataset.color || '#ffd400';
      document.querySelectorAll('.inv-sw').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      render();
    });
  });
  document.querySelectorAll('.inv-fin').forEach((btn) => {
    btn.addEventListener('click', () => { state.ink = btn.dataset.finish === 'ink'; render(); });
  });
  ['inv-name', 'inv-age', 'inv-hype', 'inv-bring', 'inv-rsvp'].forEach((id) => {
    $(id)?.addEventListener('input', render);
  });
  ['inv-date', 'inv-time-start', 'inv-time-end'].forEach((id) => {
    $(id)?.addEventListener('change', render);
  });

  if (!$('inv-date').value) $('inv-date').value = nextSaturdayISO();

  // Photo replace / remove
  $('inv-replace-photo')?.addEventListener('click', () => $('inv-photo-input')?.click());
  $('inv-photo-input')?.addEventListener('change', (e) => {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => { state.photoSrc = String(reader.result); render(); };
    reader.readAsDataURL(file);
  });
  $('inv-remove-photo')?.addEventListener('click', () => { state.photoSrc = DEFAULT_PHOTO; render(); });

  window.addEventListener('resize', fitScale);

  $('inv-download')?.addEventListener('click', () => {
    const el = $('inv-live-card');
    if (!el || !window.htmlToImage) return;
    const wrap = $('inv-scale-wrap');
    const prevScale = wrap.style.getPropertyValue('--inv-scale');
    wrap.style.setProperty('--inv-scale', '1'); // export at full resolution, not the fitted-to-screen scale
    window.htmlToImage.toPng(el, { pixelRatio: 2, cacheBust: true })
      .then((dataUrl) => {
        const a = document.createElement('a');
        a.download = 'monkey-vault-invitation.png';
        a.href = dataUrl;
        a.click();
      })
      .catch((err) => console.warn('PNG export failed', err))
      .finally(() => wrap.style.setProperty('--inv-scale', prevScale));
  });

  render();
</script>
