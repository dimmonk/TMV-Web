---
/**
 * Invitation maker — desktop surface. The feature itself is the shared
 * <InvitationMaker /> component + src/lib/invitation-maker.ts; this page only
 * supplies the desktop shell (BaseLayout's SiteHeader/SiteFooter).
 *
 * Phones are redirected to /m/#invitation (mobileHash below) so they get the
 * app shell with its header + bottom nav instead of this desktop-chrome page —
 * the same split camp-registration uses.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import InvitationMaker from '../components/InvitationMaker.astro';
import { seo } from '../data/site';
---
<BaseLayout
  title={seo.makeInvitation.title}
  description={seo.makeInvitation.description}
  active="events"
  mobileHash="invitation"
>
  <InvitationMaker />

  <script>
    import { mountInvitationMaker } from '../lib/invitation-maker';
    import { links, site, url } from '../data/site';
    const root = document.querySelector<HTMLElement>('.inv-root');
    if (root) {
      mountInvitationMaker(root, {
        venue: site.name,
        address: `${site.address.street} · ${site.address.locality}`,
        defaultPhoto: url('assets/invite-default-photo.png'),
        waiverUrl: links.waiver,
      });
    }
  </script>
</BaseLayout>
