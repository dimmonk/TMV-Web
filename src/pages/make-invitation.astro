---
/**
 * Design Your Invite. The feature is the shared <InvitationMaker /> +
 * src/lib/invitation-maker.ts — a SINGLE mount, rendered once and shared by both
 * chromes. Only the hero switches: MobileHero below md (data-chrome=app); the
 * maker's own intro band is tagged data-chrome=site inside the component, so the
 * md handoff in global.css hides it below md and shows it at md and up.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MobileHero from '../components/MobileHero.astro';
import InvitationMaker from '../components/InvitationMaker.astro';
import { seo } from '../data/site';
---
<BaseLayout
  title={seo.makeInvitation.title}
  description={seo.makeInvitation.description}
  active="events"
  mobileTab="more"
  appHeader="back"
  appTitle="Design Your Invite"
>
  <div class="mapp" data-chrome="app">
    <MobileHero eyebrow="Birthday parties" title="Design Your Invite" desc="Fill in your party details, pick a style, then download to text, post or print — right from your phone." />
  </div>

  <InvitationMaker contained={true} />

  <script>
    import { mountInvitationMaker } from '../lib/invitation-maker';
    import { links, site, url } from '../data/site';
    document.addEventListener('astro:page-load', () => {
      const root = document.querySelector<HTMLElement>('.inv-root');
      if (!root || root.dataset.mounted) return;
      root.dataset.mounted = '1';
      mountInvitationMaker(root, {
        venue: site.name,
        address: `${site.address.street} · ${site.address.locality}`,
        defaultPhoto: url('assets/invite-default-photo.png'),
        waiverUrl: links.waiver,
      });
    });
  </script>
</BaseLayout>
