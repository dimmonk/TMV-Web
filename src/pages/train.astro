---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrainScreen from '../components/mobile/TrainScreen.astro';
import JumpNav from '../components/JumpNav.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ClassCard from '../components/ClassCard.astro';
import Pill from '../components/Pill.astro';
import CtaBand from '../components/CtaBand.astro';
import { seo, links, url, cat } from '../data/site';
import { coreClasses, specializedClasses, partnershipClasses } from '../data/classes';
import type { ClassItem } from '../data/classes';

/** Resolve a class's action href for the desktop site (its own routes). */
const classHref = (c: ClassItem) => ('external' in c.link ? c.link.external : url(c.link.screen));

const jumpItems = [
  { label: 'Open Gym', id: 'opengym' }, { label: 'Core Programs', id: 'core' },
  { label: 'Specialized', id: 'specialized' }, { label: 'Partnerships', id: 'partnership' },
];
---
<BaseLayout title={seo.train.title} description={seo.train.description} active="train" mobileTab="train">
  <div class="mapp" data-chrome="app"><TrainScreen /></div>

  <div data-chrome="site">
  <section class="pagehero">
    <div class="pagehero-glow"></div>
    <div class="container hero2">
      <div>
        <div class="pagehero-kicker"><span class="rule"></span>Open Gym · Core Programs · Specialized · Partnerships</div>
        <h1 class="hero2-title">Train your<br>way.</h1>
        <p class="hero2-lead">Drop in for <strong>Open Gym</strong>, join a <strong>Group Class</strong>, step up to the <strong>Athletic Program</strong>, or go one-on-one with a <strong>Private</strong>. Open Gym and group classes are where most people start — every age, every level, your own pace.</p>
        <div class="hero2-actions">
          <a href={links.booking} target="_blank" rel="noopener" class="btn btn-primary">Book a class <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
          <a href={url('schedule')} class="btn btn-ghost-light">See full schedule</a>
        </div>
        <p class="hero2-new">New here? <a href={url('get-started')}>Start with our first-visit guide →</a></p>
      </div>
      <div class="hero2-media">
        <div class="hero2-frame">
          <div class="hero2-ph">
            <i class="bi bi-camera-reels" aria-hidden="true"></i>
            <span class="hero2-ph-tag">New media needed</span>
            <span class="hero2-ph-desc">Updated hero clip or action shot — athletes training across the floor and foam pit.</span>
          </div>
        </div>
        <div class="hero2-badge">Every age<br>every level</div>
      </div>
    </div>
  </section>

  <JumpNav items={jumpItems} actions={[{ label: 'Price List', href: url('pricing'), icon: 'bi bi-tag' }, { label: 'Full Schedule', href: url('schedule'), icon: 'bi bi-calendar3' }]} top={66} />

  <div class="trainwrap">
    <section id="opengym" class="trainsec">
      <div class="trainsec-head"><SectionHeader num="00" eyebrow="No commitment" title="Open Gym" description="The simplest way in. Open to the public every day — no class, no booking, no time limit. Just come move." color={cat.openGym} /></div>
      <div class="og">
        <div class="og-body">
          <div class="og-eyebrow"><span class="rule"></span>Open Gym · Drop-in, all ages</div>
          <h3 class="og-title">Come whenever. Stay as long as you want.</h3>
          <p class="og-lead">Full run of the gymnastics floor, foam pit, mats, weight-training section and obstacles. Dancers, athletes, families, first-timers — everyone's welcome, all ages mixed.</p>
          <div class="og-pills"><Pill variant="dark" gap={9} items="From $25 / day | No time limit | 11 AM – 10 PM daily | All ages · no prerequisites" /></div>
          <div class="og-actions">
            <a href={`${url('store')}#opengym`} class="btn btn-primary">Get a day pass <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
            <a href={links.getStartedWaiver} target="_blank" rel="noopener" class="btn btn-ghost-light">Sign the waiver</a>
          </div>
          <p class="og-fine">Kids under 7 must be actively supervised — supervising parents move for free. Day passes, pre-paid visit packs and unlimited memberships all on the <a href={url('pricing')}>Pricing page</a>.</p>
        </div>
        <div class="og-media">
          <div class="og-ph">
            <i class="bi bi-camera" aria-hidden="true"></i>
            <span class="hero2-ph-tag">New media needed</span>
            <span class="og-ph-desc">Open gym in action — a wide shot of the floor, foam pit and people training.</span>
          </div>
        </div>
      </div>
    </section>

    <section id="core" class="trainsec">
      <div class="trainsec-head"><SectionHeader num="01" eyebrow="The Foundation" title="Core Programs" description="Where everyone starts. Pick your pace — relaxed and recreational, fully personal, or athlete-level training." /></div>
      <div class="cc-grid wide">{coreClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}</div>
    </section>

    <section id="specialized" class="trainsec trainsec-specialized">
      <div class="trainsec-head"><SectionHeader num="02" eyebrow="Go Deeper" title="Specialized Classes" description="Focused, skill-specific sessions for when you want to chase one discipline hard." color={cat.classes} /></div>
      <div class="cc-grid">{specializedClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}</div>

      <div class="membership">
        <div class="membership-body">
          <div class="membership-eyebrow"><span class="rule"></span>One membership · all access</div>
          <h3 class="membership-title">Every blue class, unlimited — open gym included.</h3>
          <p class="membership-lead">One Class Membership unlocks <strong>every recreational and specialized class on this page</strong> — plus unlimited open gym. No per-class fees, no reservations, just show up.</p>
          <div class="membership-actions">
            <a href={`${url('store')}#classes`} class="btn btn-primary">Get the membership <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
            <a href={url('pricing')} class="btn btn-ghost-light">See the price list</a>
          </div>
          <p class="membership-fine">Private lessons, the Athletic Program and partner classes are billed separately.</p>
        </div>
        <div class="membership-price">
          <span class="membership-num">$180</span>
          <span class="membership-term">30 days · unlimited</span>
          <span class="membership-note">90 / 180 / 360-day terms save more</span>
        </div>
      </div>
    </section>

    <section id="partnership" class="trainsec trainsec-partnership">
      <div class="trainsec-head"><SectionHeader num="03" eyebrow="With Our Partners" title="Partnership Classes" description="Run by trusted partner coaches who share our space. Booked directly with them." color={cat.partner} /></div>
      <div class="cc-grid two">{partnershipClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}</div>
    </section>
  </div>

  <section class="section container train-final-cta">
    <CtaBand cards={[
      { theme: 'dark', eyebrow: 'Passes & Drop-ins', title: 'See the Price List', icon: 'bi-tag-fill', href: url('pricing') },
      { theme: 'light', eyebrow: 'All classes, one view', title: 'Group Class Schedule', icon: 'bi-calendar3', href: url('schedule') },
    ]} />
  </section>
  </div>
</BaseLayout>

<style>
  .hero2 { padding-block: 64px 72px; display: grid; grid-template-columns: 1.05fr .95fr; gap: 48px; align-items: center; position: relative; }
  .hero2-title { font: 800 clamp(38px,9vw,58px)/1.02 var(--font-display); letter-spacing: -.02em; margin-bottom: 18px; }
  .hero2-lead { font: 400 16px/1.55 var(--font-body); color: rgba(255,255,255,.72); max-width: 480px; margin-bottom: 30px; }
  .hero2-lead strong { color: #fff; }
  .hero2-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
  .hero2-new { font: 500 14px/1 var(--font-body); color: rgba(255,255,255,.5); margin-top: 26px; }
  .hero2-new a { color: var(--brand); text-decoration: none; font-weight: 700; }
  .hero2-media { position: relative; }
  .hero2-frame { aspect-ratio: 5/4; border-radius: 18px; overflow: hidden; box-shadow: 0 30px 60px -25px rgba(0,0,0,.7); border: 3px solid rgba(255,255,255,.08); }
  .hero2-ph { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 11px; text-align: center; padding: 26px; background: repeating-linear-gradient(45deg,#2a2724,#2a2724 14px,#252220 14px,#252220 28px); }
  .hero2-ph i { font-size: 32px; color: var(--brand); }
  .hero2-ph-tag { font: 700 10px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--brand); }
  .hero2-ph-desc { font: 500 14px/1.6 var(--font-body); color: rgba(255,255,255,.66); max-width: 250px; }
  .hero2-badge { position: absolute; bottom: -16px; right: -10px; background: var(--brand); color: var(--ink); font: 800 13px/1.2 var(--font-display); text-transform: uppercase; letter-spacing: .03em; padding: 13px 16px; border-radius: 12px; box-shadow: 0 12px 30px -10px rgba(0,0,0,.5); }

  .trainwrap { max-width: 1200px; margin-inline: auto; padding: 64px 24px 24px; }
  .trainsec { scroll-margin-top: 120px; margin-bottom: 72px; }
  .trainsec-specialized { margin-bottom: 48px; }
  .trainsec-partnership { margin-bottom: 40px; }
  .trainsec-head { margin-bottom: 30px; }
  .cc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 24px; }
  .cc-grid.wide { grid-template-columns: repeat(auto-fit, minmax(310px, 1fr)); }
  .cc-grid.two { grid-template-columns: repeat(auto-fit, minmax(330px, 1fr)); }

  .og { background: var(--ink); color: #fff; border-radius: 18px; overflow: hidden; display: grid; grid-template-columns: 1.05fr .95fr; box-shadow: var(--shadow-md); }
  .og-body { padding: 42px 44px; }
  .og-eyebrow { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: #4caf6a; margin-bottom: 16px; }
  .og-eyebrow .rule { width: 22px; height: 2px; background: #4caf6a; }
  .og-title { font: 800 27px/1.08 var(--font-display); letter-spacing: -.012em; margin-bottom: 14px; }
  .og-lead { font: 400 14px/1.6 var(--font-body); color: rgba(255,255,255,.7); margin-bottom: 22px; max-width: 430px; }
  .og-pills { margin-bottom: 26px; }
  .og-actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .og-fine { font: 500 12.5px/1.5 var(--font-body); color: rgba(255,255,255,.45); margin-top: 20px; max-width: 420px; }
  .og-fine a { color: var(--brand); text-decoration: none; font-weight: 700; }
  .og-media { position: relative; min-height: 320px; background: #1a1815; }
  .og-ph { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 9px; text-align: center; padding: 24px; background: repeating-linear-gradient(45deg,#262320,#262320 14px,#211e1c 14px,#211e1c 28px); }
  .og-ph i { font-size: 26px; color: var(--brand); }
  .og-ph-desc { font: 500 13px/1.5 var(--font-body); color: rgba(255,255,255,.6); max-width: 260px; }

  .membership { margin-top: 28px; background: var(--ink); color: #fff; border-radius: 18px; overflow: hidden; display: grid; grid-template-columns: 1.35fr .65fr; box-shadow: 0 1px 3px rgba(28,25,23,.05), 0 22px 50px -36px rgba(28,25,23,.5); }
  .membership-body { padding: 40px 44px; }
  .membership-eyebrow { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: #4aa3f0; margin-bottom: 16px; }
  .membership-eyebrow .rule { width: 22px; height: 2px; background: #4aa3f0; }
  .membership-title { font: 800 clamp(24px,3.4vw,30px)/1.08 var(--font-display); letter-spacing: -.015em; margin-bottom: 12px; }
  .membership-lead { font: 400 14px/1.6 var(--font-body); color: rgba(255,255,255,.7); margin-bottom: 20px; max-width: 480px; }
  .membership-lead strong { color: #fff; }
  .membership-actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .membership-fine { font: 500 12px/1.5 var(--font-body); color: rgba(255,255,255,.42); margin-top: 18px; max-width: 460px; }
  .membership-price { position: relative; background: #1a1815; border-left: 1px solid rgba(255,255,255,.08); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; text-align: center; padding: 36px 24px; }
  .membership-num { font: 900 46px/1 var(--font-display); letter-spacing: -.02em; color: #4aa3f0; }
  .membership-term { font: 700 12px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.6); }
  .membership-note { font: 500 12.5px/1.5 var(--font-body); color: rgba(255,255,255,.45); margin-top: 4px; }
  .train-final-cta { padding-block: 24px 72px; }

  @media (max-width: 900px) {
    .hero2 { grid-template-columns: 1fr; gap: 40px; }
    .hero2-media { order: -1; }
    .og { grid-template-columns: 1fr; }
    .og-media { min-height: 220px; }
    .og-body { padding: 32px; }
    .membership { grid-template-columns: 1fr; }
  }
</style>
