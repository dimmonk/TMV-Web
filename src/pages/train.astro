---
import BaseLayout from '../layouts/BaseLayout.astro';
import JumpNav from '../components/JumpNav.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ClassCard from '../components/ClassCard.astro';
import Pill from '../components/Pill.astro';
import CtaBand from '../components/CtaBand.astro';
import { seo, links, url } from '../data/site';

const core = [
  {
    category: 'Parkour', tag: 'Parkour', title: 'Recreational', image: 'assets/recreational.gif',
    description: 'Parkour & acrobatics at your own pace. All fun, zero pressure.', bookingTag: 'Drop-in',
    pills: 'All ages | All levels', actionLabel: 'View schedule', href: url('schedule'),
    backEyebrow: 'Recreational · Parkour', backHeadline: 'At your own pace, zero pressure',
    backBody: 'Relaxed, drop-in parkour and acrobatics. Coaches meet you exactly where you are — no commitment, no pressure.',
    specs: 'Level: All levels || Ages: All ages — Parent & Child (3+) to Adults || Booking: Drop-in · no reservation needed || Price: $30 single · 10-pack $275',
  },
  {
    category: 'Private', tag: 'Private', title: 'Private Lessons', image: 'assets/private.gif',
    description: 'Three ways in: a discounted intro, ongoing 1-on-1 at standard rates, or your own specific coach to follow your whole progress.', bookingTag: 'By appointment',
    pills: '1-on-1 | All ages', actionLabel: 'See private options', href: url('private-lessons'),
    backEyebrow: 'Private · 1-on-1', backHeadline: 'Three ways to train privately',
    backBody: "Start with a one-time Introduction, continue one-on-one at standard rates with whoever's on, or pick a specific coach who follows your whole progress — on your schedule.",
    specs: 'Level: All levels · built around you || Ages: Kids ≤17 & Adults 18+ || Booking: By appointment · reserve online || Price: Intro $45 · Kids from $65 · Adults from $85',
  },
  {
    category: 'Athletic', tag: 'Athletic', title: 'Athletic Program', image: 'assets/athletic.gif',
    description: 'Train like an athlete with structured coaching and progress tracking.', bookingTag: 'Membership',
    pills: 'Ages 9+ | 90 min', mediaBadge: 'Serious students only', actionLabel: 'View program', href: url('athletic-program'),
    backEyebrow: 'Athletic · Program', backHeadline: 'Build a well-rounded athlete',
    backBody: 'Train several times a week to build strength, speed and all-round athleticism. Monthly check-ins track your progress.',
    specs: 'Level: Prerequisite required || Ages: 9+ || Schedule: 2 × 90 min / week || Booking: Membership · join any time || Price: $150 / month · $5 class add-on',
  },
];

const specialized = [
  { category: 'Flips', tag: 'Flips', title: 'Flip Class', image: 'assets/flips.gif', description: 'Master your flips, safely — from first roll to backflip.', bookingTag: 'Drop-in', pills: 'Ages 7+ | Levels 1–2', actionLabel: 'View schedule', href: url('schedule'), backEyebrow: 'Flips', backHeadline: 'From first roll to backflip', backBody: 'A safe, levelled path from first roll to standing backflip. Always spotted and matted.', specs: 'Level: Levels 1–2 · backflip-only track || Ages: 7+ || Booking: Drop-in · no reservation needed || Price: $30 single · 10-pack $275' },
  { category: 'Strength', tag: 'Strength', title: 'Calisthenics', image: 'assets/calisthenics.gif', description: 'Build serious bodyweight strength and control.', bookingTag: 'Drop-in', pills: 'Teens & Adults (13+) | Weekday evenings', actionLabel: 'View schedule', href: url('schedule'), backEyebrow: 'Strength', backHeadline: 'Bodyweight strength & control', backBody: 'Bodyweight strength, control and mobility. Stands alone or powers up everything else you train.', specs: 'Level: All levels || Ages: Teens & Adults (13+) || Schedule: Weekday evenings || Booking: Drop-in · no reservation needed || Price: $30 single · 10-pack $275' },
  { category: 'Tricking', tag: 'Tricking', title: 'Tricking', image: 'assets/tricking.gif', description: 'Kicks, flips and twists — martial arts meets acrobatics.', bookingTag: 'Drop-in', pills: 'Teens & Adults (13+) | Tue & Thu — 7 PM', actionLabel: 'View schedule', href: url('schedule'), backEyebrow: 'Tricking', backHeadline: 'Martial arts meets acrobatics', backBody: 'Kicks, flips and twists chained into flowing combos. High-energy — and you build your own style.', specs: 'Level: All levels || Ages: Teens & Adults (13+) || Schedule: Tue · Thu — 7 PM || Booking: Drop-in · no reservation needed || Price: $30 single · 10-pack $275' },
  { category: 'Gymnastics', tag: 'Gymnastics', title: 'Gymnastics', image: 'assets/gymnastics.gif', description: 'Strength, flexibility and clean form — the base for everything.', bookingTag: 'Drop-in', pills: 'Teens & Adults (13+) | Tue & Fri — 6 PM', actionLabel: 'View schedule', href: url('schedule'), backEyebrow: 'Gymnastics', backHeadline: 'The foundation under everything', backBody: 'Strength, flexibility and clean form — the fundamentals that make everything else safer and sharper.', specs: 'Level: All levels || Ages: Teens & Adults (13+) || Schedule: Tue · Fri — 6 PM || Booking: Drop-in · no reservation needed || Price: $30 single · 10-pack $275' },
];

const partnership = [
  { category: 'Partner', tag: 'Partner', title: 'Stick Fighting Toronto', image: 'assets/stickfighting.gif', description: 'Filipino stick fighting with our partner, coach Peter.', bookingTag: 'Direct with coach', pills: 'Adults (18+) | Saturdays', actionLabel: 'Contact coach', href: 'mailto:coachpeter@stickfightingtoronto.com', backEyebrow: 'Partner · Adults', backHeadline: 'Filipino stick fighting', backBody: 'Footwork, timing and weapon flow with coach Peter. Welcoming adult class — booked directly with the coach.', specs: 'Level: All levels || Ages: Adults (18+) || Schedule: Sat — 10 AM to 12 PM || Booking: Direct with coach Peter || Price: $30 drop-in · $100 / month', backActionLabel: 'Contact coach Peter' },
  { category: 'Partner', tag: 'Partner', title: 'Martial Arts', image: 'assets/martialarts.gif', description: 'Jiu Jitsu, Wrestling, Boxing & Muay Thai.', bookingTag: 'Direct with coach', pills: 'Ages 16+ | Grappling | Striking', actionLabel: 'Get in touch', href: 'mailto:info@themonkeyvault.com?subject=Martial%20Arts%20classes%20(for%20Ryan)', backEyebrow: 'Partner · Teens 16+ & Adults', backHeadline: 'Grappling & striking', backBody: 'Jiu Jitsu, Wrestling, Boxing and Muay Thai under partner coaches. Beginner to competitor — booked directly via WhatsApp.', specs: 'Level: All levels · beginner to competitor || Ages: 16+ || Booking: Direct via WhatsApp · ask for Ryan || Disciplines: BJJ · Wrestling · Boxing · Muay Thai' },
];

const jumpItems = [
  { label: 'Open Gym', id: 'opengym' }, { label: 'Core Programs', id: 'core' },
  { label: 'Specialized', id: 'specialized' }, { label: 'Partnerships', id: 'partnership' },
];
---
<BaseLayout title={seo.train.title} description={seo.train.description} active="train">
  <section class="pagehero">
    <div class="pagehero-glow"></div>
    <div class="container hero2">
      <div>
        <div class="pagehero-kicker"><span class="rule"></span>Open Gym · Core Programs · Specialized · Partnerships</div>
        <h1 class="hero2-title">Train your<br>way.</h1>
        <p class="hero2-lead">Drop in for <strong>Open Gym</strong>, join a <strong>Group Class</strong>, step up to the <strong>Athletic Program</strong>, or go one-on-one with a <strong>Private</strong>. Open Gym and group classes are where most people start — every age, every level, your own pace.</p>
        <div class="hero2-actions">
          <a href={links.booking} target="_blank" rel="noopener" class="btn btn-primary">Book a class <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
          <a href={url('schedule')} class="btn btn-ghost-light">See full schedule</a>
        </div>
        <p class="hero2-new">New here? <a href={url('get-started')}>Start with our first-visit guide →</a></p>
      </div>
      <div class="hero2-media">
        <div class="hero2-frame">
          <div class="hero2-ph">
            <i class="bi bi-camera-reels" aria-hidden="true"></i>
            <span class="hero2-ph-tag">New media needed</span>
            <span class="hero2-ph-desc">Updated hero clip or action shot — athletes training across the floor and foam pit.</span>
          </div>
        </div>
        <div class="hero2-badge">Every age<br>every level</div>
      </div>
    </div>
  </section>

  <JumpNav items={jumpItems} top={66} />

  <div class="trainwrap">
    <section id="opengym" class="trainsec">
      <div class="trainsec-head"><SectionHeader num="00" eyebrow="No commitment" title="Open Gym" description="The simplest way in. Open to the public every day — no class, no booking, no time limit. Just come move." /></div>
      <div class="og">
        <div class="og-body">
          <h3 class="og-title">Come whenever. Stay as long as you want.</h3>
          <p class="og-lead">Full run of the gymnastics floor, foam pit, mats, weight-training section and obstacles. Dancers, athletes, families, first-timers — everyone's welcome, all ages mixed.</p>
          <div class="og-pills"><Pill variant="dark" gap={9} items="From $25 / day | No time limit | 11 AM – 10 PM daily | All ages · no prerequisites" /></div>
          <div class="og-actions">
            <a href={`${url('store')}#opengym`} class="btn btn-primary">Get a day pass <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
            <a href={links.getStartedWaiver} target="_blank" rel="noopener" class="btn btn-ghost-light">Sign the waiver</a>
          </div>
          <p class="og-fine">Kids under 7 must be actively supervised — supervising parents move for free. Day passes, pre-paid visit packs and unlimited memberships all on the <a href={url('pricing')}>Pricing page</a>.</p>
        </div>
        <div class="og-media">
          <div class="og-ph">
            <i class="bi bi-camera" aria-hidden="true"></i>
            <span class="hero2-ph-tag">New media needed</span>
            <span class="og-ph-desc">Open gym in action — a wide shot of the floor, foam pit and people training.</span>
          </div>
        </div>
      </div>
    </section>

    <section id="core" class="trainsec">
      <div class="trainsec-head"><SectionHeader num="01" eyebrow="The Foundation" title="Core Programs" description="Where everyone starts. Pick your pace — relaxed and recreational, fully personal, or athlete-level training." /></div>
      <div class="cc-grid wide">{core.map((c) => <ClassCard {...c} />)}</div>
    </section>

    <section id="specialized" class="trainsec">
      <div class="trainsec-head"><SectionHeader num="02" eyebrow="Go Deeper" title="Specialized Classes" description="Focused, skill-specific sessions for when you want to chase one discipline hard." /></div>
      <div class="cc-grid">{specialized.map((c) => <ClassCard {...c} />)}</div>
    </section>

    <section id="partnership" class="trainsec">
      <div class="trainsec-head"><SectionHeader num="03" eyebrow="With Our Partners" title="Partnership Classes" description="Run by trusted partner coaches who share our space. Booked directly with them." /></div>
      <div class="cc-grid two">{partnership.map((c) => <ClassCard {...c} />)}</div>
    </section>
  </div>

  <section class="section container">
    <CtaBand cards={[
      { theme: 'dark', eyebrow: 'Passes & Drop-ins', title: 'See the Price List', icon: 'bi-tag-fill', href: url('pricing') },
      { theme: 'light', eyebrow: 'All classes, one view', title: 'Group Class Schedule', icon: 'bi-calendar3', href: url('schedule') },
    ]} />
  </section>
</BaseLayout>

<style>
  .pagehero { background: var(--ink); color: #fff; position: relative; overflow: hidden; }
  .pagehero-glow { position: absolute; inset: 0; background: radial-gradient(680px 360px at 90% -12%, rgba(255,212,0,.13), transparent 70%); }
  .pagehero-kicker { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--brand); margin-bottom: 20px; }
  .pagehero-kicker .rule { width: 22px; height: 2px; background: var(--brand); }
  .hero2 { padding-block: 64px 72px; display: grid; grid-template-columns: 1.05fr .95fr; gap: 48px; align-items: center; position: relative; }
  .hero2-title { font: 800 clamp(38px,9vw,58px)/1.02 var(--font-display); letter-spacing: -.02em; margin-bottom: 18px; }
  .hero2-lead { font: 400 16px/1.55 var(--font-body); color: rgba(255,255,255,.72); max-width: 480px; margin-bottom: 30px; }
  .hero2-lead strong { color: #fff; }
  .hero2-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
  .hero2-new { font: 500 14px/1 var(--font-body); color: rgba(255,255,255,.5); margin-top: 26px; }
  .hero2-new a { color: var(--brand); text-decoration: none; font-weight: 700; }
  .hero2-media { position: relative; }
  .hero2-frame { aspect-ratio: 5/4; border-radius: 18px; overflow: hidden; box-shadow: 0 30px 60px -25px rgba(0,0,0,.7); border: 3px solid rgba(255,255,255,.08); }
  .hero2-ph { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 11px; text-align: center; padding: 26px; background: repeating-linear-gradient(45deg,#2a2724,#2a2724 14px,#252220 14px,#252220 28px); }
  .hero2-ph i { font-size: 32px; color: var(--brand); }
  .hero2-ph-tag { font: 700 10px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--brand); }
  .hero2-ph-desc { font: 500 14px/1.6 var(--font-body); color: rgba(255,255,255,.66); max-width: 250px; }
  .hero2-badge { position: absolute; bottom: -16px; right: -10px; background: var(--brand); color: var(--ink); font: 800 13px/1.2 var(--font-display); text-transform: uppercase; letter-spacing: .03em; padding: 13px 16px; border-radius: 12px; box-shadow: 0 12px 30px -10px rgba(0,0,0,.5); }

  .trainwrap { max-width: 1200px; margin-inline: auto; padding: 64px 24px 24px; }
  .trainsec { scroll-margin-top: 130px; margin-bottom: 72px; }
  .trainsec-head { margin-bottom: 30px; }
  .cc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 24px; }
  .cc-grid.wide { grid-template-columns: repeat(auto-fit, minmax(310px, 1fr)); }
  .cc-grid.two { grid-template-columns: repeat(auto-fit, minmax(330px, 1fr)); }

  .og { background: var(--ink); color: #fff; border-radius: 18px; overflow: hidden; display: grid; grid-template-columns: 1.05fr .95fr; box-shadow: var(--shadow-md); }
  .og-body { padding: 42px 44px; }
  .og-title { font: 800 27px/1.08 var(--font-display); letter-spacing: -.012em; margin-bottom: 14px; }
  .og-lead { font: 400 14px/1.6 var(--font-body); color: rgba(255,255,255,.7); margin-bottom: 22px; max-width: 430px; }
  .og-pills { margin-bottom: 26px; }
  .og-actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .og-fine { font: 500 12.5px/1.5 var(--font-body); color: rgba(255,255,255,.45); margin-top: 20px; max-width: 420px; }
  .og-fine a { color: var(--brand); text-decoration: none; font-weight: 700; }
  .og-media { position: relative; min-height: 320px; background: #1a1815; }
  .og-ph { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 9px; text-align: center; padding: 24px; background: repeating-linear-gradient(45deg,#262320,#262320 14px,#211e1c 14px,#211e1c 28px); }
  .og-ph i { font-size: 26px; color: var(--brand); }
  .og-ph-desc { font: 500 13px/1.5 var(--font-body); color: rgba(255,255,255,.6); max-width: 260px; }

  @media (max-width: 900px) {
    .hero2 { grid-template-columns: 1fr; gap: 40px; }
    .hero2-media { order: -1; }
    .og { grid-template-columns: 1fr; }
    .og-media { min-height: 220px; }
    .og-body { padding: 32px; }
  }
</style>
