---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import { seo, links, url } from '../data/site';
import '../styles/price-list-sheet.css';
---
<BaseLayout title={seo.pricing.title} description={seo.pricing.description} active="pricing">
  <section class="pagehero">
    <div class="pagehero-glow"></div>
    <div class="container pagehero-inner">
      <div class="pagehero-kicker"><span class="rule"></span>Passes, packs &amp; memberships</div>
      <h1 class="pagehero-title">One price list. Buy before you arrive.</h1>
      <p class="pagehero-lead">Every option below is live from our booking system and checks out securely in our online store. Set up your pass before you get to the gym and skip the front-desk line.</p>
      <div style="margin-top:24px; display:flex; gap:12px; flex-wrap:wrap">
        <a href={url('store')} class="btn btn-primary">Buy passes &amp; memberships <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
        <a href={url('book')} class="btn btn-ghost-light">Book a session instead</a>
      </div>
      <p class="pagehero-fine">All prices in CAD, HST included. Pre-paid packs are valid 10–20 months depending on size.</p>
    </div>
  </section>

  <!-- LIVE PRICE LIST — production renderer running natively (no iframe).
       Same price-list-renderer.js + price-list-sheet.css the members app
       uses; data from getPublicPriceList (SSOT). -->
  <main class="pl-main">
    <div class="pl-embed-shell">
      <div class="pl-embed-desktop">
        <div id="pl-embed-root"></div>
      </div>
    </div>

    <p class="pl-foot">
      <i class="bi bi-arrow-repeat" aria-hidden="true"></i>&nbsp; Prices update automatically from our booking system — this is the same list our front desk prints.
    </p>

    <!-- STORE CTA — where purchase intent peaks -->
    <section class="pl-cta">
      <CtaBand cards={[
        { theme: 'dark', eyebrow: 'Buy before you arrive', title: 'Passes & memberships — online store', icon: 'bi-bag-check-fill', href: url('store') },
        { theme: 'light', eyebrow: 'Booking a time instead?', title: 'Book a session', icon: 'bi-calendar-check', href: url('book') },
      ]} />
    </section>

    <!-- GIFT CARDS -->
    <section class="pl-gift-wrap">
      <a href={links.giftCard} target="_blank" rel="noopener" class="pl-gift">
        <div class="pl-gift-lead">
          <span class="pl-gift-icon"><i class="bi bi-gift-fill" aria-hidden="true"></i></span>
          <div>
            <div class="pl-gift-eyebrow">The easy gift</div>
            <div class="pl-gift-title">Gift cards — any amount</div>
          </div>
        </div>
        <span class="btn btn-primary pl-gift-btn">Buy a gift card <i class="bi bi-arrow-up-right" aria-hidden="true"></i></span>
      </a>
    </section>
  </main>
</BaseLayout>

<style>
  .pagehero { background: var(--ink); color: #fff; position: relative; overflow: hidden; }
  .pagehero-glow { position: absolute; inset: 0; background: radial-gradient(680px 360px at 88% -15%, rgba(255,212,0,.13), transparent 70%); }
  .pagehero-inner { padding-block: 58px 56px; position: relative; }
  .pagehero-kicker { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--brand); margin-bottom: 18px; }
  .pagehero-kicker .rule { width: 22px; height: 2px; background: var(--brand); }
  .pagehero-title { font: 800 clamp(34px,8vw,54px)/1.02 var(--font-display); letter-spacing: -.02em; margin-bottom: 16px; max-width: 760px; }
  .pagehero-lead { font: 400 16px/1.55 var(--font-body); color: rgba(255,255,255,.72); max-width: 560px; margin-bottom: 8px; }
  .pagehero-fine { font: 500 13px/1.5 var(--font-body); color: rgba(255,255,255,.5); margin-top: 18px; }

  .pl-main { max-width: 1440px; margin: 0 auto; padding: 44px 20px 24px; }
  .pl-foot { font: 500 12.5px/1.5 var(--font-body); color: #9b9890; text-align: center; margin: 16px 0 44px; }
  .pl-foot i { color: var(--brand); }
  .pl-cta { max-width: 1120px; margin: 0 auto 44px; }

  .pl-gift-wrap { max-width: 1120px; margin: 0 auto 8px; }
  .pl-gift {
    text-decoration: none; display: flex; align-items: center; justify-content: space-between; gap: 20px;
    flex-wrap: wrap; background: var(--ink); color: #fff; border-radius: 18px; padding: 34px 38px;
  }
  .pl-gift-lead { display: flex; align-items: center; gap: 18px; }
  .pl-gift-icon {
    flex: none; width: 52px; height: 52px; border-radius: 14px; background: rgba(255,255,255,.1);
    display: flex; align-items: center; justify-content: center; font-size: 24px; color: var(--brand);
  }
  .pl-gift-eyebrow { font: 700 11px/1 var(--font-display); letter-spacing: .13em; text-transform: uppercase; color: var(--brand); margin-bottom: 8px; }
  .pl-gift-title { font: 800 24px/1.05 var(--font-display); letter-spacing: -.012em; }
  .pl-gift-btn { flex: none; }
</style>

<script>
  import { renderPriceListSheet } from '../lib/price-list-renderer.js';
  const root = document.getElementById('pl-embed-root');
  try {
    await renderPriceListSheet(root);
  } catch (err) {
    console.error('[pricing] render failed', err);
  }
</script>
