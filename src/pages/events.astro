---
import BaseLayout from '../layouts/BaseLayout.astro';
import JumpNav from '../components/JumpNav.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Pill from '../components/Pill.astro';
import { seo, links, site } from '../data/site';

const partyImg = 'https://97c4ca0509b4c38d26ba.cdn6.editmysite.com/uploads/b/97c4ca0509b4c38d26ba323484b80b964616e1d4454eb6debcf2c66267495c04/045A1402%203_1671609291.JPG?width=1200&optimize=medium';

const steps = [
  { n: '1', title: 'Pick the age range', body: 'Select the average age of the group.' },
  { n: '2', title: 'Pick group size', body: 'You can update the headcount later if it changes.' },
  { n: '3', title: 'Pick date & time', body: 'Weekend slots fill fast — the times you see online are all we have.' },
  { n: '4', title: 'Enter payment info', body: 'Your card is not charged — it only holds the slot per our policy.' },
  { n: '5', title: 'Check your email', body: "A confirmation lands in your inbox. Peek in spam if you don't see it." },
];
const faqGroups = [
  { title: 'Booking', items: [
    { q: 'When do I pay?', a: "You don't pay anything upfront. The credit card collected during booking is only for our cancellation policy and won't be charged. Payment is made in person on the day of the party, based on the final count of participants — so you only pay for who actually shows up." },
    { q: 'What is the cancellation policy?', a: "A cancellation fee applies if the booking is canceled within 24 hours of the appointment or if there's a no-show. Full details are provided during the booking process." },
    { q: 'What if weekend slots are fully booked?', a: "The availability you see online is all we have. If you have a smaller group, consider the Mini Birthday Party: the same one-hour coached parkour session, minimum 3 participants ($30 each, max 15), ages 8+. Each kid gets an all-day pass, but it doesn't include a private room." },
  ] },
  { title: 'Day of the party', items: [
    { q: 'When should we arrive?', a: "The host is welcome to arrive 15 minutes before the scheduled party time. Depending on availability, the room may be ready a little earlier." },
    { q: 'Are there age requirements?', a: "We ask that the group be similar in age. Our coaches tailor activities and difficulty to the group, so mixing very different ages doesn't work well." },
  ] },
  { title: 'Food & drinks', items: [
    { q: 'What are the food options?', a: "We don't provide food or catering, but you're welcome to bring whatever you'd like (cake, pizza, snacks, drinks) with no fees. You can order delivery too. We provide a fridge/freezer to store your items during the party." },
    { q: 'What supplies do you provide?', a: "We provide the party room, tables, and a fridge/freezer. We don't provide plates, cups, utensils or napkins — the host brings catering items. You're welcome to bring decorations." },
  ] },
  { title: 'During the party', items: [
    { q: 'Can we extend the open gym time?', a: "Yes — ask the instructor assigned to your party. It's $5 per participant for an extra hour. Extending gym time does not extend party-room time: the room must be vacated at the 2-hour mark." },
  ] },
];
const tiers = [
  { label: 'Up to 10', val: '$300 base' }, { label: '11–30', val: '$27.50 each' },
  { label: '31–50', val: '$25.00 each' }, { label: '51+', val: '$22.50 each' },
];
---
<BaseLayout title={seo.events.title} description={seo.events.description} active="events">
  <section class="pagehero">
    <div class="pagehero-glow"></div>
    <div class="container hero2">
      <div>
        <div class="pagehero-kicker"><span class="rule"></span>Birthdays · Groups · Team events</div>
        <h1 class="hero2-title">Parties &amp; events,<br>they'll flip over.</h1>
        <p class="hero2-lead">Expert-led, adrenaline-packed fun under one big roof — from kids' birthdays to corporate team-building. Pick the format that fits your crew.</p>
        <div class="hero2-actions">
          <a href="#birthdays" class="btn btn-primary">Birthday parties <i class="bi bi-arrow-down" aria-hidden="true"></i></a>
          <a href="#groups" class="btn btn-ghost-light">Groups &amp; teams</a>
        </div>
      </div>
      <div class="hero2-media">
        <div class="ev-video"><iframe src="https://www.youtube.com/embed/DH5Clt4pO3o?rel=0" title="Birthday parties at The Monkey Vault" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
        <div class="hero2-badge">Weekends<br>fill fast</div>
      </div>
    </div>
  </section>

  <JumpNav items={[{ label: 'Birthdays', id: 'birthdays' }, { label: 'Birthday FAQ', id: 'faq' }, { label: 'Groups & Teams', id: 'groups' }]} top={66} />

  <section id="birthdays" class="section container" style="scroll-margin-top:140px">
    <div style="margin-bottom:34px"><SectionHeader num="01" eyebrow="Birthdays" title="Two ways to celebrate" description="Go all-in with the full package, or keep it nimble with a Mini party for smaller groups and last-minute plans." /></div>
    <div class="ev-parties">
      <div class="ev-full">
        <div class="ev-full-media"><img src={partyImg} alt="Kids and coaches mid-session on the gym floor" loading="lazy" /><span class="ev-popular">Most popular</span></div>
        <div class="ev-full-body">
          <h3 class="ev-full-title">Full Birthday Party</h3>
          <p class="ev-full-desc">Coaches stay with your group the whole time. A private party room, a coached session, and free play — the full experience.</p>
          <div class="ev-timeline">
            <div class="ev-tl"><span class="ev-tl-t">60′</span><span>Activities — parkour intro lesson, movement games &amp; requested skills</span></div>
            <div class="ev-tl"><span class="ev-tl-t">30′</span><span>Private party room — food, drinks &amp; celebration</span></div>
            <div class="ev-tl last"><span class="ev-tl-t">30′</span><span>Open gym — free play under instructor supervision</span></div>
          </div>
          <div style="margin-bottom:22px"><Pill variant="light" gap={8} items="Ages 5+ | 2 hrs total | Private room" /></div>
          <div class="ev-full-foot">
            <div class="ev-full-price">
              <div><div class="ev-big">$350</div><div class="ev-sub">base price · up to 8 participants</div></div>
              <div class="ev-extra">+$25 per additional participant<br>+$5 / participant for an extra hour</div>
            </div>
            <div class="ev-full-actions">
              <a href={links.booking} target="_blank" rel="noopener" class="btn btn-dark">Book your party <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
              <a href="https://www.themonkeyvault.com/invitations" target="_blank" rel="noopener" class="btn btn-ghost">Make an invitation</a>
            </div>
          </div>
        </div>
      </div>

      <div class="ev-mini">
        <span class="ev-mini-tag">Smaller &amp; last-minute</span>
        <h3 class="ev-mini-title">Mini Birthday Party</h3>
        <p class="ev-mini-desc">Booked solid for the full package? The Mini is the same action-packed one-hour coached parkour session of games and challenges — just a lower minimum so smaller groups and last-minute plans still get in.</p>
        <div class="ev-mini-label">What's included</div>
        <div class="ev-mini-list">
          <div class="ev-mini-li yes"><i class="bi bi-check-circle-fill" aria-hidden="true"></i>One-hour coached parkour session — games &amp; challenges</div>
          <div class="ev-mini-li yes"><i class="bi bi-check-circle-fill" aria-hidden="true"></i>3 participants minimum, up to 15 · ages 8+</div>
          <div class="ev-mini-li yes"><i class="bi bi-check-circle-fill" aria-hidden="true"></i>All-day pass for every kid — open gym after, leave to eat, come back</div>
        </div>
        <div class="ev-mini-label">Good to know</div>
        <div class="ev-mini-list">
          <div class="ev-mini-li no"><i class="bi bi-dash-circle" aria-hidden="true"></i>Coaches lead the session, then kids are on their own in open gym</div>
          <div class="ev-mini-li no"><i class="bi bi-dash-circle" aria-hidden="true"></i>No private room — common-area tables are shared, not guaranteed</div>
        </div>
        <div class="ev-mini-foot">
          <div><div class="ev-mini-price">$30</div><div class="ev-mini-per">per participant</div></div>
          <a href={links.booking} target="_blank" rel="noopener" class="btn btn-primary">Book mini <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section container" style="padding-block:56px 12px">
    <div class="ev-how">
      <div class="ev-how-head"><h3>How booking works</h3><p>Your card is never charged at booking — it just holds the slot. You pay in person on the day, based on final headcount.</p></div>
      <div class="ev-steps">{steps.map((s) => <div class="ev-step"><span class="ev-step-n">{s.n}</span><div class="ev-step-t">{s.title}</div><p>{s.body}</p></div>)}</div>
    </div>
  </section>

  <section id="faq" class="section container" style="scroll-margin-top:140px">
    <div class="ev-faq">
      <div class="ev-faq-left">
        <div class="ev-faq-eyebrow">Birthday FAQ</div>
        <h2 class="ev-faq-title">Good to know before you book</h2>
        <p class="ev-faq-lead">Everything parents ask us most — payment, food, timing and the day-of details. Still stuck? We're happy to help.</p>
        <div class="ev-faq-contact">
          <a href={`mailto:${site.email}`}><i class="bi bi-envelope" aria-hidden="true"></i> {site.email}</a>
          <a href={`tel:${site.phone}`}><i class="bi bi-telephone" aria-hidden="true"></i> {site.phoneDisplay}</a>
        </div>
      </div>
      <div class="ev-faq-right">
        {faqGroups.map((g) => (
          <div class="ev-faq-group">
            <div class="ev-faq-gtitle">{g.title}</div>
            <div class="ev-faq-box">
              {g.items.map((qa) => (
                <details class="ev-faq-item">
                  <summary><span>{qa.q}</span><i class="bi bi-chevron-down" aria-hidden="true"></i></summary>
                  <div class="ev-faq-a">{qa.a}</div>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="groups" class="section container" style="scroll-margin-top:140px; padding-bottom:80px">
    <div style="margin-bottom:34px"><SectionHeader num="02" eyebrow="Groups & organizations" title="Bring your whole group" description="Schools, corporate teams, youth organizations and sports teams — a fun, active way to build teamwork, confidence and skills." /></div>
    <div class="ev-groups">
      <div class="ev-gcard">
        <div class="ev-ghead"><span class="ev-gic" style="background:color-mix(in srgb,#8c52ff 14%,#fff)"><i class="bi bi-people-fill" style="color:#8c52ff" aria-hidden="true"></i></span><div><div class="ev-geyebrow" style="color:#8c52ff">Group Events</div><div class="ev-gtitle">Field trips &amp; team-building</div></div></div>
        <p class="ev-gdesc">Two hours total — an hour of guided activities, then an hour of open gym. Intro parkour workshops, team-building obstacle courses, games and skill development for all levels.</p>
        <div class="ev-gfoot">
          <div class="ev-glabel">Price per participant</div>
          <div class="ev-tiers">{tiers.map((t) => <div class="ev-tier"><span>{t.label}</span><span class="ev-tier-v">{t.val}</span></div>)}</div>
          <p class="ev-gfine">Minimum 10 participants; smaller groups pay the $300 base. Final total is calculated on event day.</p>
          <a href={links.booking} target="_blank" rel="noopener" class="btn btn-dark">Plan an event <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
        </div>
      </div>
      <div class="ev-gcard">
        <div class="ev-ghead"><span class="ev-gic" style="background:color-mix(in srgb,#2e9e4f 14%,#fff)"><i class="bi bi-sunrise" style="color:#2e9e4f" aria-hidden="true"></i></span><div><div class="ev-geyebrow" style="color:#2e9e4f">Early Gym Access</div><div class="ev-gtitle">The gym, all to yourself</div></div></div>
        <p class="ev-gdesc">Reserve The Monkey Vault before we open at 11 AM for exclusive access. Perfect for small groups or focused training with no crowds.</p>
        <div class="ev-gfoot2">
          <div><div class="ev-big2">From $50/hr</div><div class="ev-sub">+ $25 / person open gym</div></div>
          <a href={links.booking} target="_blank" rel="noopener" class="btn btn-dark">Reserve time <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
        </div>
      </div>
    </div>
    <p class="ev-note">Booking &amp; cancellation: your card isn't charged at booking — payment is made in person based on final headcount. A fee applies for cancellations within 24 hours or no-shows.</p>
  </section>
</BaseLayout>

<style>
  .pagehero { background: var(--ink); color: #fff; position: relative; overflow: hidden; }
  .pagehero-glow { position: absolute; inset: 0; background: radial-gradient(680px 360px at 90% -12%, rgba(255,212,0,.13), transparent 70%); }
  .pagehero-kicker { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--brand); margin-bottom: 20px; }
  .pagehero-kicker .rule { width: 22px; height: 2px; background: var(--brand); }
  .hero2 { padding-block: 60px 66px; display: grid; grid-template-columns: 1.05fr .95fr; gap: 48px; align-items: center; position: relative; }
  .hero2-title { font: 800 clamp(38px,9vw,56px)/1 var(--font-display); letter-spacing: -.02em; margin-bottom: 18px; }
  .hero2-lead { font: 400 16px/1.55 var(--font-body); color: rgba(255,255,255,.72); max-width: 470px; margin-bottom: 30px; }
  .hero2-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
  .hero2-media { position: relative; }
  .ev-video { aspect-ratio: 16/9; border-radius: 18px; overflow: hidden; box-shadow: 0 30px 60px -25px rgba(0,0,0,.7); border: 3px solid rgba(255,255,255,.08); background: #000; }
  .ev-video iframe { width: 100%; height: 100%; border: 0; }
  .hero2-badge { position: absolute; bottom: -16px; right: -10px; background: var(--brand); color: var(--ink); font: 800 13px/1.2 var(--font-display); text-transform: uppercase; letter-spacing: .03em; padding: 13px 16px; border-radius: 12px; box-shadow: 0 12px 30px -10px rgba(0,0,0,.5); }

  .ev-parties { display: grid; grid-template-columns: 1.15fr .85fr; gap: 22px; }
  .ev-full { display: flex; flex-direction: column; background: #fff; border: 2px solid var(--brand); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-sm); }
  .ev-full-media { position: relative; aspect-ratio: 16/8; overflow: hidden; background: #1a1815; }
  .ev-full-media img { width: 100%; height: 100%; object-fit: cover; }
  .ev-popular { position: absolute; top: 14px; left: 14px; font: 700 10px/1 var(--font-display); letter-spacing: .08em; text-transform: uppercase; color: var(--ink); background: var(--brand); padding: 7px 11px; border-radius: 999px; box-shadow: 0 4px 14px rgba(0,0,0,.3); }
  .ev-full-body { padding: 28px 30px 30px; display: flex; flex-direction: column; flex: 1; }
  .ev-full-title { font: 800 26px/1.08 var(--font-display); letter-spacing: -.012em; margin: 0 0 8px; }
  .ev-full-desc { font: 400 13px/1.5 var(--font-body); color: var(--muted); margin: 0 0 20px; }
  .ev-timeline { display: flex; flex-direction: column; margin-bottom: 22px; }
  .ev-tl { display: flex; align-items: center; gap: 14px; padding: 13px 0; border-bottom: 1px solid var(--line-soft); font: 600 14px/1.3 var(--font-body); color: var(--text-2); }
  .ev-tl.last { border-bottom: 0; }
  .ev-tl-t { flex: none; width: 40px; font: 800 15px/1 var(--font-display); color: #e0a800; }
  .ev-full-foot { margin-top: auto; padding-top: 20px; border-top: 1px solid var(--line-soft); }
  .ev-full-price { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 20px; }
  .ev-big { font: 800 30px/1 var(--font-display); color: var(--ink); }
  .ev-sub { font: 600 12.5px/1.3 var(--font-body); color: var(--muted-3); margin-top: 6px; }
  .ev-extra { text-align: right; font: 600 12.5px/1.5 var(--font-body); color: var(--muted); }
  .ev-full-actions { display: flex; flex-wrap: wrap; gap: 12px; }

  .ev-mini { display: flex; flex-direction: column; background: var(--ink); color: #fff; border-radius: 20px; padding: 28px 30px 30px; box-shadow: 0 18px 40px -28px rgba(0,0,0,.6); }
  .ev-mini-tag { align-self: flex-start; font: 700 10px/1 var(--font-display); letter-spacing: .08em; text-transform: uppercase; color: var(--brand); background: rgba(255,255,255,.08); padding: 7px 11px; border-radius: 999px; margin-bottom: 16px; }
  .ev-mini-title { font: 800 24px/1.08 var(--font-display); letter-spacing: -.012em; margin: 0 0 8px; }
  .ev-mini-desc { font: 400 13px/1.5 var(--font-body); color: rgba(255,255,255,.7); margin: 0 0 20px; }
  .ev-mini-label { font: 700 10px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.45); margin-bottom: 12px; }
  .ev-mini-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 18px; }
  .ev-mini-li { display: flex; align-items: flex-start; gap: 10px; font: 600 14px/1.6 var(--font-body); }
  .ev-mini-li.yes { color: rgba(255,255,255,.88); } .ev-mini-li.yes i { color: var(--brand); margin-top: 2px; flex: none; }
  .ev-mini-li.no { color: rgba(255,255,255,.7); } .ev-mini-li.no i { color: rgba(255,255,255,.4); margin-top: 2px; flex: none; }
  .ev-mini-foot { margin-top: auto; padding-top: 18px; border-top: 1px solid rgba(255,255,255,.12); display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; }
  .ev-mini-price { font: 800 28px/1 var(--font-display); color: var(--brand); }
  .ev-mini-per { font: 600 12.5px/1.3 var(--font-body); color: rgba(255,255,255,.55); margin-top: 5px; }

  .ev-how { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 38px 40px; box-shadow: var(--shadow-sm); }
  .ev-how-head { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; margin-bottom: 26px; }
  .ev-how-head h3 { font: 800 22px/1.1 var(--font-display); letter-spacing: -.01em; }
  .ev-how-head p { font: 400 13px/1.5 var(--font-body); color: var(--muted); margin: 0; }
  .ev-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; }
  .ev-step { display: flex; flex-direction: column; gap: 9px; }
  .ev-step-n { width: 34px; height: 34px; border-radius: 10px; background: #f3f2ee; display: flex; align-items: center; justify-content: center; font: 800 14px/1 var(--font-display); }
  .ev-step-t { font: 800 14px/1.2 var(--font-display); }
  .ev-step p { font: 400 12.5px/1.5 var(--font-body); color: var(--muted); margin: 0; }

  .ev-faq { display: grid; grid-template-columns: .85fr 1.15fr; gap: 40px; align-items: start; }
  .ev-faq-left { position: sticky; top: 90px; }
  .ev-faq-eyebrow { font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin-bottom: 10px; }
  .ev-faq-title { font: 800 clamp(26px,4.5vw,34px)/1.04 var(--font-display); letter-spacing: -.018em; margin-bottom: 14px; }
  .ev-faq-lead { font: 400 15px/1.55 var(--font-body); color: var(--muted); margin-bottom: 22px; }
  .ev-faq-contact { display: flex; flex-direction: column; gap: 10px; }
  .ev-faq-contact a { display: inline-flex; align-items: center; gap: 9px; font: 700 14px/1 var(--font-display); color: var(--ink); text-decoration: none; }
  .ev-faq-contact i { color: var(--muted-3); }
  .ev-faq-group { margin-bottom: 26px; }
  .ev-faq-gtitle { font: 700 11px/1 var(--font-display); letter-spacing: .12em; text-transform: uppercase; color: #e0a800; margin-bottom: 10px; }
  .ev-faq-box { background: #fff; border: 1px solid var(--line); border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-sm); }
  .ev-faq-item { border-top: 1px solid var(--line-soft); }
  .ev-faq-item:first-child { border-top: 0; }
  .ev-faq-item summary { display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; padding: 17px 20px; font: 700 15px/1.35 var(--font-display); color: var(--ink); list-style: none; }
  .ev-faq-item summary::-webkit-details-marker { display: none; }
  .ev-faq-item summary:hover { background: #faf9f6; }
  .ev-faq-item summary i { font-size: 13px; color: var(--faint); flex: none; transition: transform .25s ease; }
  .ev-faq-item[open] summary i { transform: rotate(180deg); }
  .ev-faq-a { padding: 0 20px 18px; font: 400 14px/1.6 var(--font-body); color: var(--muted); }

  .ev-groups { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .ev-gcard { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 32px 34px; box-shadow: var(--shadow-sm); }
  .ev-ghead { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .ev-gic { flex: none; width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 21px; }
  .ev-geyebrow { font: 700 11px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; }
  .ev-gtitle { font: 800 21px/1.1 var(--font-display); letter-spacing: -.01em; margin-top: 5px; }
  .ev-gdesc { font: 400 13px/1.5 var(--font-body); color: var(--muted); margin: 0 0 18px; }
  .ev-gfoot { margin-top: auto; padding-top: 18px; border-top: 1px solid var(--line-soft); }
  .ev-glabel { font: 700 11px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; color: var(--muted-3); margin-bottom: 12px; }
  .ev-tiers { display: flex; flex-direction: column; margin-bottom: 14px; }
  .ev-tier { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--line-soft); font: 600 14px/1 var(--font-body); color: var(--text-2); }
  .ev-tier:last-child { border-bottom: 0; }
  .ev-tier-v { font: 800 13.5px/1 var(--font-display); color: var(--ink); }
  .ev-gfine { font: 400 12.5px/1.5 var(--font-body); color: var(--muted-3); margin: 0 0 18px; }
  .ev-gfoot2 { margin-top: auto; padding-top: 18px; border-top: 1px solid var(--line-soft); display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; }
  .ev-big2 { font: 800 22px/1 var(--font-display); color: var(--ink); }
  .ev-note { font: 400 12.5px/1.5 var(--font-body); color: var(--muted-3); max-width: 760px; margin: 22px auto 0; text-align: center; }

  @media (max-width: 900px) {
    .hero2 { grid-template-columns: 1fr; gap: 40px; }
    .hero2-media { order: -1; }
    .ev-parties, .ev-faq, .ev-groups { grid-template-columns: 1fr; }
    .ev-faq-left { position: static; }
  }
</style>
