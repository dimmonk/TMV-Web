---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo } from '../data/site';
import '../styles/camp-reg-form.css';

// Standalone desktop/tablet camp-registration page. The interactive form itself
// is the shared module src/lib/camp-reg-form.ts — the SAME component the /m/
// mobile app mounts on its "Register" screen (single source of truth). Phones
// are redirected to /m/#register (mobileHash below) so they get the app shell
// with its header + bottom nav instead of this desktop-chrome page.
---
<BaseLayout
  title={seo.campRegistration.title}
  description={seo.campRegistration.description}
  active="camps"
  mobileHash="register"
>
  <div id="reg-root" class="reg-root" style="min-height:100vh; background:#f5f4f1;"></div>

  <script>
    import { mountCampRegForm } from '../lib/camp-reg-form';
    import { links, site } from '../data/site';
    const root = document.getElementById('reg-root');
    if (root) {
      mountCampRegForm(root, {
        waiverUrl: links.waiver,
        bookingUrl: links.booking,
        address: `${site.name} · ${site.address.street}, ${site.address.locality} (Downsview Park)`,
        showHero: true,
      });
    }
  </script>
</BaseLayout>
