---
/**
 * Camp registration. The form is the shared module src/lib/camp-reg-form.ts — a
 * SINGLE mount (#reg-root), rendered once and shared by both chromes. Its own
 * hero is turned off (showHero:false); the hero above it switches instead:
 * MobileHero below md (data-chrome=app), a desktop pagehero at md and up
 * (data-chrome=site).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MobileHero from '../components/MobileHero.astro';
import { seo, cat } from '../data/site';
import '../styles/camp-reg-form.css';
---
<BaseLayout
  title={seo.campRegistration.title}
  description={seo.campRegistration.description}
  active="camps"
  mobileTab="more"
  appHeader="back"
  appTitle="Registration"
>
  <div class="mapp" data-chrome="app">
    <MobileHero eyebrow="Camps" title="Register for camp" desc="Pick your camp days, add each child, and check out — all in one place." />
  </div>

  <section class="pagehero" data-chrome="site" style={`--cat:${cat.camps}`}>
    <div class="pagehero-glow"></div>
    <div class="container pagehero-inner">
      <div class="pagehero-kicker"><span class="rule"></span>Camps · Registration</div>
      <h1 class="pagehero-title">Register for camp.</h1>
      <p class="pagehero-lead">Pick your camp days, add each child, and check out — all in one place.</p>
    </div>
  </section>

  <div id="reg-root" class="reg-root" style="background:#f5f4f1;"></div>

  <script>
    import { mountCampRegForm } from '../lib/camp-reg-form';
    import { links, site } from '../data/site';
    const root = document.getElementById('reg-root');
    if (root) {
      mountCampRegForm(root, {
        waiverUrl: links.waiver,
        bookingUrl: links.booking,
        address: `${site.name} · ${site.address.street}, ${site.address.locality} (Downsview Park)`,
        showHero: false,
      });
    }
  </script>
</BaseLayout>

<style>
  .pagehero { background: var(--ink); color: #fff; position: relative; overflow: hidden; }
  .pagehero-glow { position: absolute; inset: 0; background: radial-gradient(680px 360px at 88% -15%, color-mix(in srgb, var(--cat) 14%, transparent), transparent 70%); }
  .pagehero-inner { padding-block: 58px 52px; position: relative; }
  .pagehero-kicker { display: inline-flex; align-items: center; gap: 9px; font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--cat); margin-bottom: 18px; }
  .pagehero-kicker .rule { width: 22px; height: 2px; background: var(--cat); }
  .pagehero-title { font: 800 clamp(34px,8vw,54px)/1.02 var(--font-display); letter-spacing: -.02em; margin-bottom: 16px; }
  .pagehero-lead { font: 400 16px/1.55 var(--font-body); color: rgba(255,255,255,.72); max-width: 560px; }
</style>
