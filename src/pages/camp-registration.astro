---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo } from '../data/site';
import '../styles/camp-reg-form.css';

// Camp registration. The interactive form is the shared module
// src/lib/camp-reg-form.ts; this page mounts it and lets the layout supply
// whichever chrome the viewport calls for.
---
<BaseLayout
  title={seo.campRegistration.title}
  description={seo.campRegistration.description}
  active="camps"
  mobileTab="more"
  appHeader="back"
  appTitle="Registration"
>
  <div id="reg-root" class="reg-root" style="min-height:100vh; background:#f5f4f1;"></div>

  <script>
    import { mountCampRegForm } from '../lib/camp-reg-form';
    import { links, site } from '../data/site';
    const root = document.getElementById('reg-root');
    if (root) {
      mountCampRegForm(root, {
        waiverUrl: links.waiver,
        bookingUrl: links.booking,
        address: `${site.name} · ${site.address.street}, ${site.address.locality} (Downsview Park)`,
        showHero: true,
      });
    }
  </script>
</BaseLayout>
