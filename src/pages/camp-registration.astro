---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo, links, site } from '../data/site';

// Ported from the "Camp Registration" design handoff (.dc.html prototype).
// The prototype was authored in an in-house React-like runtime (DCLogic); here
// it's re-implemented as a self-contained client-side state machine so it runs
// on the static Astro site. All layout uses the prototype's inline styles
// verbatim; only the handful of interactive class rules live in the scoped
// <style> below (Astro's scoped styles don't reach JS-generated DOM, so they're
// namespaced under #reg-root instead).
//
// Prices are the documented camp defaults (the .dc.html's offline fallbacks).
// The prototype's live members-app price fetch (tmv-data.js) is intentionally
// not wired here — this is a standalone preview page, not the paid cart. Square
// checkout is likewise stubbed: "Register & pay" advances to the printable
// confirmation view without charging.
const accent = '#e27902';
const address = `${site.name} · ${site.address.street}, ${site.address.locality} (Downsview Park)`;
---
<BaseLayout
  title={seo.campRegistration.title}
  description={seo.campRegistration.description}
  active="camps"
  mobileRedirect={false}
>
  <div id="reg-root" style={`--acc:${accent}; min-height:100vh; background:#f5f4f1; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif; color:#211f1b;`}></div>

  <style is:global>
    #reg-root ::selection { background:#ffd400; color:#211f1b; }
    #reg-root a { color:#a2601f; }
    #reg-root a:hover { color:#e27902; }
    #reg-root .reg-in { width:100%; font:600 14px/1.2 -apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif; color:#211f1b; background:#f6f5f1; border:1px solid #e3e0d8; border-radius:10px; padding:11px 13px; outline:none; transition:border-color .15s, background .15s; }
    #reg-root .reg-in:focus { border-color:#e27902; background:#fff; }
    #reg-root .reg-in::placeholder { color:#a8a49b; font-weight:500; }
    #reg-root textarea.reg-in { resize:vertical; min-height:60px; }
    #reg-root .reg-grid { display:grid; grid-template-columns:minmax(0,1fr) 340px; gap:26px; align-items:start; }
    #reg-root .reg-side { position:sticky; top:20px; }
    #reg-root .reg-mbar { display:none; }
    #reg-root .chip { cursor:pointer; transition:border-color .15s, background .15s, transform .1s; }
    #reg-root .chip:active { transform:scale(.97); }
    #reg-root .pill { cursor:pointer; transition:background .12s, color .12s, border-color .12s; }
    #reg-root .khead { cursor:pointer; }
    #reg-root .reg-x { cursor:pointer; transition:background .15s, color .15s; }
    #reg-root .reg-x:hover { background:#f4d3d0 !important; color:#b3261e !important; }
    #reg-root .reg-cta { cursor:pointer; transition:filter .15s, transform .1s; }
    #reg-root .reg-cta:hover { filter:brightness(1.05); }
    #reg-root .reg-cta:active { transform:translateY(1px); }
    @media (max-width:920px) {
      #reg-root .reg-grid { grid-template-columns:1fr; }
      #reg-root .reg-side { display:none; }
      #reg-root .reg-mbar { display:flex; position:sticky; bottom:0; z-index:40; margin:0 -16px; }
      #reg-root .reg-wrap { padding-bottom:12px !important; }
    }
    @media print {
      .sh, footer, #reg-root [data-noprint] { display:none !important; }
      html, body { background:#fff; }
      #reg-root .reg-doc { box-shadow:none !important; border:none !important; border-radius:0 !important; padding:0 !important; }
      #reg-root .reg-doc-inner { max-width:none !important; }
    }
  </style>

  <script define:vars={{ WAIVER_URL: links.waiver, BOOKING_URL: links.booking, ADDRESS: address }}>
    const root = document.getElementById('reg-root');

    // ---- pricing model (documented camp defaults) ----
    const PL = {
      campWeekly: 350, campDaily: 90, camp2Days: 170, camp3Days: 240, camp4Days: 300,
      campPADay: 90, campPrivateDay: 90, latePickupPerDay: 20, latePickupBulk: 75,
    };
    const DYC = true; // day-camp late-pickup add-on enabled

    // `start` = the week's first camp day (ISO, local). Registration for a week
    // closes once that day arrives (weekExpired) — an expired week renders as a
    // non-interactive "Closed" row and can't be added to the cart. To close a
    // week at a different time (e.g. end of the week, or an early-bird cutoff),
    // change its `start` value.
    const WEEKS = [
      { id:'w1', n:'Week 1', dates:'Jun 29 – Jul 3', start:'2026-06-29', days:['Mon','Tue','Thu','Fri'], partial:true },
      { id:'w2', n:'Week 2', dates:'Jul 6 – 10', start:'2026-07-06', days:['Mon','Tue','Wed','Thu','Fri'] },
      { id:'w3', n:'Week 3', dates:'Jul 13 – 17', start:'2026-07-13', days:['Mon','Tue','Wed','Thu','Fri'] },
      { id:'w4', n:'Week 4', dates:'Jul 20 – 24', start:'2026-07-20', days:['Mon','Tue','Wed','Thu','Fri'] },
      { id:'w5', n:'Week 5', dates:'Jul 27 – 31', start:'2026-07-27', days:['Mon','Tue','Wed','Thu','Fri'] },
      { id:'w6', n:'Week 6', dates:'Aug 4 – 7', start:'2026-08-04', days:['Tue','Wed','Thu','Fri'], partial:true },
      { id:'w7', n:'Week 7', dates:'Aug 10 – 14', start:'2026-08-10', days:['Mon','Tue','Wed','Thu','Fri'] },
      { id:'w8', n:'Week 8', dates:'Aug 17 – 21', start:'2026-08-17', days:['Mon','Tue','Wed','Thu','Fri'] },
      { id:'w9', n:'Week 9', dates:'Aug 24 – 28', start:'2026-08-24', days:['Mon','Tue','Wed','Thu','Fri'] },
    ];
    // A week is closed once its start day has arrived (local time).
    const weekExpired = (w) => Date.now() >= new Date(w.start + 'T00:00:00').getTime();
    const PADATES = [
      { id:'pa1', label:'Fri · Oct 10' },
      { id:'pa2', label:'Fri · Nov 21' },
      { id:'pa3', label:'Fri · Jan 16' },
    ];
    const DAY_LABELS = ['Mon','Tue','Wed','Thu','Fri'];

    const daysPrice = (n) => { if (n <= 0) return 0; const key = ['campDaily','camp2Days','camp3Days','camp4Days','campWeekly'][Math.min(n,5)-1]; return PL[key]; };
    const weekFull = (w) => daysPrice(w.days.length);
    const lateCost = (n) => { if (n <= 0) return 0; return n >= 4 ? PL.latePickupBulk : n * PL.latePickupPerDay; };
    const waiverOk = (k) => k.waiver === 'yes' || (k.waiver === 'no' && k.waiverDone);
    const money = (n) => '$' + n.toLocaleString('en-US');
    const esc = (s) => String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

    // ---- state ----
    let seq = 1;
    const blankKid = (id) => ({ id, name:'', age:'', allergies:'', notes:'', waiver:'unset', waiverDone:false, camp:'weekly', weeks:{}, paDates:{} });
    const state = { stage:'build', kids:[ blankKid('k1') ], expanded:'k1', parent:{ name:'', email:'', phone:'' }, error:'', ref:'' };

    const kidById = (id) => state.kids.find((k) => k.id === id);

    // ---- pricing per child ----
    function computeKid(k) {
      const lines = []; let total = 0;
      if (k.camp === 'weekly') {
        WEEKS.forEach((w) => {
          const e = k.weeks[w.id]; if (!e) return;
          const attend = w.days.filter((d) => e.mode === 'full' || e.days[d]);
          if (attend.length === 0) return;
          const base = e.mode === 'full' ? weekFull(w) : daysPrice(attend.length);
          const detail = e.mode === 'full' ? 'full week' : attend.join(', ');
          lines.push({ title:w.n, dates:w.dates, days:detail, amount:base }); total += base;
          const lateDays = attend.filter((d) => e.late[d]);
          if (lateDays.length > 0) { const lc = lateCost(lateDays.length); lines.push({ title:'Late pickup', days:lateDays.join(', '), amount:lc, sub:true }); total += lc; }
        });
      } else if (k.camp === 'paday') {
        PADATES.forEach((p) => {
          const e = k.paDates[p.id]; if (!e) return;
          lines.push({ label:'P.A. Day · ' + p.label, amount:PL.campPADay }); total += PL.campPADay;
          if (DYC && e.late) { lines.push({ label:'· late pickup to 4 PM', amount:PL.latePickupPerDay, sub:true }); total += PL.latePickupPerDay; }
        });
      }
      return { lines, total };
    }

    const grandTotal = () => state.kids.reduce((a,k) => a + computeKid(k).total, 0);

    // ---- summary line items (shared by live summary + receipt) ----
    function summaryKidsHTML() {
      const rows = state.kids
        .map((k, ki) => ({ k, ki, comp: computeKid(k) }))
        .filter((x) => x.comp.lines.length > 0);
      if (rows.length === 0) return '';
      return rows.map((x) => {
        const name = x.k.name.trim() || ('Camper ' + (x.ki + 1));
        const lines = x.comp.lines.map((l, li) => {
          const color = l.sub ? '#9b9890' : '#3a3833';
          const mt = li === 0 ? '0px' : (l.sub ? '3px' : '13px');
          const left = l.title
            ? `<strong style="font-weight:800;">${esc(l.title)}</strong>${l.dates ? ' · ' + esc(l.dates) : ''}`
            : esc(l.label);
          const daysLine = l.days ? `<div style="color:#9b9890; font-size:11.5px; margin-top:1px;">${esc(l.days)}</div>` : '';
          return `<div style="font:600 12.5px/1.5 inherit; color:${color}; margin-top:${mt};">
            <div style="display:flex; justify-content:space-between; gap:12px;"><span>${left}</span><span style="white-space:nowrap;">${money(l.amount)}</span></div>
            ${daysLine}
          </div>`;
        }).join('');
        return `<div>
          <div style="font:800 12px/1 'Archivo',sans-serif; color:#a2601f; margin-bottom:8px; text-transform:uppercase; letter-spacing:.03em;">${esc(name)}</div>
          ${lines}
        </div>`;
      }).join('');
    }

    // ---- one child card ----
    function kidCardHTML(k, ki) {
      const comp = computeKid(k);
      const isExp = state.expanded === k.id;
      const isPrivate = k.camp === 'private';
      const initial = (k.name.trim()[0] || (ki + 1)).toString().toUpperCase();
      const displayName = k.name.trim() || ('Camper ' + (ki + 1));
      let summaryLine;
      if (isPrivate) summaryLine = 'Private day · booked by appointment';
      else if (k.camp === 'weekly') { const n = Object.keys(k.weeks).length; summaryLine = n ? ('Weekly Camp · ' + n + ' week' + (n>1?'s':'')) : 'Weekly Camp — pick weeks'; }
      else { const n = Object.keys(k.paDates).length; summaryLine = n ? ('P.A. Day · ' + n + ' day' + (n>1?'s':'')) : 'P.A. Day — pick dates'; }
      const priceLabel = isPrivate ? '' : money(comp.total);
      const cardBorder = isExp ? 'var(--acc)' : '#eae7df';
      const headBg = isExp ? '#fffdf9' : '#fff';

      const removeBtn = state.kids.length > 1
        ? `<span class="reg-x" data-act="removeKid" data-kid="${k.id}" title="Remove" style="flex:none; width:28px; height:28px; border-radius:8px; background:#f3f2ee; color:#9b9890; display:flex; align-items:center; justify-content:center; font-size:13px;"><i class="bi bi-trash"></i></span>`
        : '';

      const head = `<div class="khead" data-act="toggleExpand" data-kid="${k.id}" style="display:flex; align-items:center; gap:12px; padding:14px 16px; background:${headBg};">
        <span style="flex:none; width:36px; height:36px; border-radius:10px; background:var(--acc); color:#fff; display:flex; align-items:center; justify-content:center; font:900 15px/1 'Archivo',sans-serif;">${esc(initial)}</span>
        <div style="flex:1; min-width:0;">
          <div style="font:800 15.5px/1.1 'Archivo',sans-serif;">${esc(displayName)}</div>
          <div style="font:600 12px/1.3 inherit; color:#8a877f; margin-top:3px;">${esc(summaryLine)}</div>
        </div>
        <span style="flex:none; font:900 16px/1 'Archivo',sans-serif; color:var(--acc);">${priceLabel}</span>
        ${removeBtn}
        <i class="bi ${isExp ? 'bi-chevron-up' : 'bi-chevron-down'}" style="flex:none; color:#b0aca3;"></i>
      </div>`;

      if (!isExp) return `<div style="background:#fff; border:1.5px solid ${cardBorder}; border-radius:16px; overflow:hidden; box-shadow:0 1px 3px rgba(28,25,23,.05),0 14px 30px -26px rgba(28,25,23,.4);">${head}</div>`;

      const campChips = [['weekly','Weekly'],['paday','P.A. Day'],['private','Private Day']].map(([val,label]) => {
        if (k.camp === val) return `<span class="chip" data-act="setCamp" data-kid="${k.id}" data-camp="${val}" style="display:inline-flex; align-items:center; gap:7px; padding:10px 14px; border-radius:11px; border:1.5px solid var(--acc); background:#fff7ef; font:800 13px/1 'Archivo',sans-serif;"><i class="bi bi-check-circle-fill" style="color:var(--acc);"></i>${label}</span>`;
        return `<span class="chip" data-act="setCamp" data-kid="${k.id}" data-camp="${val}" style="display:inline-flex; align-items:center; padding:10px 14px; border-radius:11px; border:1.5px solid #e5e2db; background:#fff; font:700 13px/1 'Archivo',sans-serif; color:#5b5853;">${label}</span>`;
      }).join('');
      const campBlock = `<div>
        <div style="font:700 10.5px/1 'Archivo',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:#9b9890; margin:12px 0 9px;">Camp</div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">${campChips}</div>
      </div>`;

      let flow = '';
      if (k.camp === 'weekly') flow = weeklyFlowHTML(k);
      else if (k.camp === 'paday') flow = padayFlowHTML(k);
      else flow = privateFlowHTML();

      const details = isPrivate ? '' : camperDetailsHTML(k);

      return `<div style="background:#fff; border:1.5px solid ${cardBorder}; border-radius:16px; overflow:hidden; box-shadow:0 1px 3px rgba(28,25,23,.05),0 14px 30px -26px rgba(28,25,23,.4);">
        ${head}
        <div style="padding:6px 16px 18px; display:flex; flex-direction:column; gap:18px;">
          ${campBlock}
          ${flow}
          ${details}
        </div>
      </div>`;
    }

    // ---- weekly flow ----
    function weeklyFlowHTML(k) {
      const dayTierHint = [1,2,3,4].map((n) => n + 'd $' + daysPrice(n)).join(' · ');
      const rows = WEEKS.map((w) => {
        if (weekExpired(w)) {
          return `<div style="border:1px solid #ece9e2; border-radius:12px; overflow:hidden; opacity:.6;">
            <div style="display:flex; align-items:center; gap:12px; padding:11px 13px; cursor:not-allowed;">
              <span style="flex:none; width:20px; height:20px; border-radius:6px; border:1.5px solid #d5d1c8; background:#f3f2ee;"></span>
              <div style="flex:1; min-width:0;">
                <div style="font:800 13.5px/1.1 'Archivo',sans-serif; color:#8a877f;">${w.n}</div>
                <div style="font:600 11.5px/1.3 inherit; color:#b0aca3; margin-top:2px;">${w.dates}</div>
              </div>
              <span style="flex:none; font:700 9px/1 'Archivo',sans-serif; letter-spacing:.05em; text-transform:uppercase; color:#8a877f; background:#eeece7; padding:5px 8px; border-radius:6px;">Closed</span>
            </div>
          </div>`;
        }
        const e = k.weeks[w.id];
        const sel = !!e;
        let priceLabel = money(weekFull(w));
        if (sel) priceLabel = money(computeKid({ ...k, camp:'weekly', weeks:{ [w.id]:e } }).total);
        const rowBorder = sel ? 'var(--acc)' : '#ece9e2';
        const check = sel
          ? `<span style="flex:none; width:20px; height:20px; border-radius:6px; background:var(--acc); display:flex; align-items:center; justify-content:center;"><i class="bi bi-check-lg" style="color:#fff; font-size:13px;"></i></span>`
          : `<span style="flex:none; width:20px; height:20px; border-radius:6px; border:1.5px solid #d5d1c8;"></span>`;
        const fourDay = w.partial ? `<span style="flex:none; font:700 9px/1 'Archivo',sans-serif; letter-spacing:.05em; text-transform:uppercase; color:#a2601f; background:#fff2e2; padding:5px 7px; border-radius:6px;">4-day</span>` : '';
        const header = `<div class="pill" data-act="toggleWeek" data-kid="${k.id}" data-week="${w.id}" style="display:flex; align-items:center; gap:12px; padding:11px 13px;">
          ${check}
          <div style="flex:1; min-width:0;">
            <div style="font:800 13.5px/1.1 'Archivo',sans-serif;">${w.n}</div>
            <div style="font:600 11.5px/1.3 inherit; color:#8a877f; margin-top:2px;">${w.dates}</div>
          </div>
          ${fourDay}
          <span style="flex:none; font:800 13.5px/1 'Archivo',sans-serif; color:#211f1b;">${priceLabel}</span>
        </div>`;

        let panel = '';
        if (sel) {
          const lateN = w.days.filter((d) => (e.mode === 'full' || e.days[d]) && e.late[d]).length;
          const lateLabel = lateN > 0 ? ('+' + money(lateCost(lateN))) : '';
          const seg = e.mode === 'full'
            ? `<span class="pill" style="padding:6px 13px; border-radius:7px; background:#fff; color:#211f1b; font:800 11.5px/1 'Archivo',sans-serif; box-shadow:0 1px 2px rgba(0,0,0,.08);">Full week</span>
               <span class="pill" data-act="weekMode" data-kid="${k.id}" data-week="${w.id}" data-mode="days" style="padding:6px 13px; border-radius:7px; color:#8a877f; font:700 11.5px/1 'Archivo',sans-serif;">Pick days</span>`
            : `<span class="pill" data-act="weekMode" data-kid="${k.id}" data-week="${w.id}" data-mode="full" style="padding:6px 13px; border-radius:7px; color:#8a877f; font:700 11.5px/1 'Archivo',sans-serif;">Full week</span>
               <span class="pill" style="padding:6px 13px; border-radius:7px; background:#fff; color:#211f1b; font:800 11.5px/1 'Archivo',sans-serif; box-shadow:0 1px 2px rgba(0,0,0,.08);">Pick days</span>`;

          let dayBlock = '';
          if (e.mode === 'days') {
            const dayPills = w.days.map((d) => {
              const on = !!e.days[d];
              return on
                ? `<span class="pill" data-act="weekDay" data-kid="${k.id}" data-week="${w.id}" data-day="${d}" style="min-width:44px; text-align:center; padding:9px 8px; border-radius:9px; background:var(--acc); color:#fff; font:800 12px/1 'Archivo',sans-serif;">${d}</span>`
                : `<span class="pill" data-act="weekDay" data-kid="${k.id}" data-week="${w.id}" data-day="${d}" style="min-width:44px; text-align:center; padding:9px 8px; border-radius:9px; background:#fff; border:1.5px solid #e0dcd3; color:#8a877f; font:700 12px/1 'Archivo',sans-serif;">${d}</span>`;
            }).join('');
            dayBlock = `<div style="margin-bottom:12px;">
              <div style="font:600 10px/1 inherit; color:#9b9890; margin-bottom:7px;">Days attending · ${dayTierHint}</div>
              <div style="display:flex; gap:6px; flex-wrap:wrap;">${dayPills}</div>
            </div>`;
          }

          const latePills = w.days.filter((d) => e.mode === 'full' || e.days[d]).map((d) => {
            const on = !!e.late[d];
            return on
              ? `<span class="pill" data-act="weekLate" data-kid="${k.id}" data-week="${w.id}" data-day="${d}" style="min-width:44px; text-align:center; padding:8px; border-radius:9px; background:#211f1b; color:#ffd400; font:800 12px/1 'Archivo',sans-serif;">${d}</span>`
              : `<span class="pill" data-act="weekLate" data-kid="${k.id}" data-week="${w.id}" data-day="${d}" style="min-width:44px; text-align:center; padding:8px; border-radius:9px; background:#fff; border:1.5px solid #e0dcd3; color:#8a877f; font:700 12px/1 'Archivo',sans-serif;">${d}</span>`;
          }).join('');

          panel = `<div style="background:#fbf9f4; border-top:1px solid #efece4; padding:12px 13px 13px;">
            <div style="display:inline-flex; padding:3px; background:#efece4; border-radius:9px; margin-bottom:12px;">${seg}</div>
            ${dayBlock}
            <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:7px;">
              <div style="font:600 10px/1 inherit; color:#9b9890;">Late pickup to 4 PM · $20/day (max $75)</div>
              <span style="font:800 11.5px/1 'Archivo',sans-serif; color:var(--acc);">${lateLabel}</span>
            </div>
            <div style="display:flex; gap:6px; flex-wrap:wrap;">${latePills}</div>
          </div>`;
        }

        return `<div style="border:1px solid ${rowBorder}; border-radius:12px; overflow:hidden;">${header}${panel}</div>`;
      }).join('');

      return `<div>
        <div style="font:700 10.5px/1 'Archivo',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:#9b9890; margin-bottom:9px;">Pick weeks — tap a week for day-by-day</div>
        <div style="display:flex; flex-direction:column; gap:8px;">${rows}</div>
      </div>`;
    }

    // ---- P.A. Day flow ----
    function padayFlowHTML(k) {
      const rows = PADATES.map((p) => {
        const e = k.paDates[p.id];
        const sel = !!e;
        const rowBorder = sel ? 'var(--acc)' : '#ece9e2';
        const check = sel
          ? `<span style="flex:none; width:20px; height:20px; border-radius:6px; background:var(--acc); display:flex; align-items:center; justify-content:center;"><i class="bi bi-check-lg" style="color:#fff; font-size:13px;"></i></span>`
          : `<span style="flex:none; width:20px; height:20px; border-radius:6px; border:1.5px solid #d5d1c8;"></span>`;
        const header = `<div class="pill" data-act="togglePa" data-kid="${k.id}" data-pa="${p.id}" style="display:flex; align-items:center; gap:12px; padding:12px 13px;">
          ${check}
          <div style="flex:1;"><div style="font:800 13.5px/1.1 'Archivo',sans-serif;">${p.label}</div><div style="font:600 11.5px/1.3 inherit; color:#8a877f; margin-top:2px;">9 AM – 2 PM</div></div>
          <span style="flex:none; font:800 13.5px/1 'Archivo',sans-serif;">$90</span>
        </div>`;
        let lateRow = '';
        if (sel && DYC) {
          const on = !!e.late;
          const box = on
            ? `<span style="flex:none; width:18px; height:18px; border-radius:5px; background:#211f1b; display:flex; align-items:center; justify-content:center;"><i class="bi bi-check-lg" style="color:#ffd400; font-size:12px;"></i></span>`
            : `<span style="flex:none; width:18px; height:18px; border-radius:5px; border:1.5px solid #d5d1c8;"></span>`;
          lateRow = `<div class="pill" data-act="paLate" data-kid="${k.id}" data-pa="${p.id}" style="background:#fbf9f4; border-top:1px solid #efece4; padding:11px 13px; display:flex; align-items:center; gap:10px;">
            ${box}
            <span style="flex:1; font:600 12px/1.3 inherit; color:#5b5853;">Late pickup to 4 PM</span>
            <span style="font:800 12px/1 'Archivo',sans-serif; color:var(--acc);">+$20</span>
          </div>`;
        }
        return `<div style="border:1px solid ${rowBorder}; border-radius:12px; overflow:hidden;">${header}${lateRow}</div>`;
      }).join('');
      return `<div>
        <div style="font:700 10.5px/1 'Archivo',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:#9b9890; margin-bottom:9px;">Pick P.A. Day dates · $90 each</div>
        <div style="display:flex; flex-direction:column; gap:8px;">${rows}</div>
      </div>`;
    }

    // ---- private flow ----
    function privateFlowHTML() {
      return `<div style="border:1px solid #e8e5dd; background:#faf9f5; border-radius:12px; padding:16px 16px 18px;">
        <div style="display:flex; gap:13px; align-items:flex-start; margin-bottom:14px;">
          <span style="flex:none; width:38px; height:38px; border-radius:10px; background:#fff7ef; display:flex; align-items:center; justify-content:center;"><i class="bi bi-calendar2-week" style="color:var(--acc); font-size:17px;"></i></span>
          <div style="flex:1;">
            <div style="font:800 14.5px/1.15 'Archivo',sans-serif; margin-bottom:6px;">Private days are booked by appointment</div>
            <p style="font:400 13px/1.5 inherit; color:#5b5853; margin:0; text-wrap:pretty;">You pick your own date and we build the day around your group (5+ kids, $90 each). Reserve your date through our booking system — no need to fill out this form.</p>
          </div>
        </div>
        <a href="${BOOKING_URL}" target="_blank" rel="noopener" style="display:inline-flex; align-items:center; gap:9px; text-decoration:none; background:var(--acc); color:#fff; font:800 13px/1 'Archivo',sans-serif; text-transform:uppercase; letter-spacing:.03em; padding:13px 18px; border-radius:10px;">Book a private day <i class="bi bi-arrow-up-right"></i></a>
      </div>`;
    }

    // ---- camper details + waiver ----
    function camperDetailsHTML(k) {
      const satisfied = waiverOk(k);
      const wStat = satisfied ? 'ok' : (k.waiver === 'unset' ? 'neutral' : 'todo');
      const waiverBorder = wStat === 'ok' ? '#cfe6d6' : (wStat === 'todo' ? '#f0dcc2' : '#e8e5dd');
      const waiverBg = wStat === 'ok' ? '#f0f8f2' : (wStat === 'todo' ? '#fff7ef' : '#faf9f5');

      const yesChip = k.waiver === 'yes'
        ? `<span class="chip" data-act="waiver" data-kid="${k.id}" data-val="yes" style="flex:1; display:inline-flex; align-items:center; justify-content:center; gap:7px; padding:11px; border-radius:10px; border:1.5px solid #1b6b2f; background:#eef7f0; color:#1b6b2f; font:800 13px/1 'Archivo',sans-serif;"><i class="bi bi-check-circle-fill"></i>Yes — on file</span>`
        : `<span class="chip" data-act="waiver" data-kid="${k.id}" data-val="yes" style="flex:1; display:inline-flex; align-items:center; justify-content:center; padding:11px; border-radius:10px; border:1.5px solid #e0dcd3; background:#fff; color:#5b5853; font:700 13px/1 'Archivo',sans-serif;">Yes — done before</span>`;
      const noChip = k.waiver === 'no'
        ? `<span class="chip" data-act="waiver" data-kid="${k.id}" data-val="no" style="flex:1; display:inline-flex; align-items:center; justify-content:center; gap:7px; padding:11px; border-radius:10px; border:1.5px solid var(--acc); background:#fff7ef; color:#a2601f; font:800 13px/1 'Archivo',sans-serif;"><i class="bi bi-check-circle-fill"></i>No — first time</span>`
        : `<span class="chip" data-act="waiver" data-kid="${k.id}" data-val="no" style="flex:1; display:inline-flex; align-items:center; justify-content:center; padding:11px; border-radius:10px; border:1.5px solid #e0dcd3; background:#fff; color:#5b5853; font:700 13px/1 'Archivo',sans-serif;">No — first time</span>`;

      let step2 = '';
      if (k.waiver === 'no') {
        const doneRow = k.waiverDone
          ? `<span style="flex:none; width:20px; height:20px; border-radius:6px; background:#1b6b2f; display:flex; align-items:center; justify-content:center;"><i class="bi bi-check-lg" style="color:#fff; font-size:13px;"></i></span><span style="font:700 12.5px/1.2 'Archivo',sans-serif; color:#1b6b2f;">Waiver submitted — all set</span>`
          : `<span style="flex:none; width:20px; height:20px; border-radius:6px; border:2px solid #d5b48a;"></span><span style="font:700 12.5px/1.2 'Archivo',sans-serif; color:#a2601f;">I've completed the waiver</span>`;
        step2 = `<div style="margin-top:12px; padding-top:12px; border-top:1px dashed #e6dcc8;">
          <div style="font:700 12.5px/1.35 'Archivo',sans-serif; color:#a2601f; margin-bottom:9px;">Step 2 — sign the one-time waiver, then confirm it's done.</div>
          <a href="${WAIVER_URL}" target="_blank" rel="noopener" style="display:inline-flex; align-items:center; gap:8px; text-decoration:none; background:var(--acc); color:#fff; font:800 12.5px/1 'Archivo',sans-serif; text-transform:uppercase; letter-spacing:.03em; padding:11px 15px; border-radius:9px; margin-bottom:10px;"><i class="bi bi-pencil-square"></i>Please sign the waiver here</a>
          <div class="pill" data-act="waiverDone" data-kid="${k.id}" style="display:flex; align-items:center; gap:9px;">${doneRow}</div>
        </div>`;
      }

      return `<div>
        <div style="font:700 10.5px/1 'Archivo',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:#9b9890; margin-bottom:9px;">Camper details</div>
        <div style="display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; gap:10px;">
            <input class="reg-in" style="flex:2;" type="text" placeholder="Camper's name" value="${esc(k.name)}" data-field="${k.id}.name">
            <input class="reg-in" style="flex:1;" type="text" placeholder="Age" value="${esc(k.age)}" data-field="${k.id}.age">
          </div>
          <input class="reg-in" type="text" placeholder="Allergies (we're a nut-free facility)" value="${esc(k.allergies)}" data-field="${k.id}.allergies">
          <textarea class="reg-in" placeholder="Anything the coaches should know? (optional)" data-field="${k.id}.notes">${esc(k.notes)}</textarea>
          <div style="border:1px solid ${waiverBorder}; background:${waiverBg}; border-radius:11px; padding:13px 14px;">
            <div style="font:700 10.5px/1 'Archivo',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:#9b9890; margin-bottom:9px;">Waiver</div>
            <div style="font:700 13px/1.35 'Archivo',sans-serif; margin-bottom:11px;">Step 1 — has this camper filled out a Monkey Vault waiver before?</div>
            <div style="display:flex; gap:8px;">${yesChip}${noChip}</div>
            ${step2}
          </div>
        </div>
      </div>`;
    }

    // ---- build stage ----
    function buildStageHTML() {
      const cards = state.kids.map((k, ki) => kidCardHTML(k, ki)).join('');
      const total = grandTotal();
      const totalLabel = money(total);

      const pendingKids = state.kids.filter((k) => k.camp !== 'private' && computeKid(k).total > 0 && !waiverOk(k));
      const waiverPending = pendingKids.length > 0;
      const waiverMsg = waiverPending ? ('Waiver still needed for ' + pendingKids.map((k) => k.name.trim() || ('camper ' + (state.kids.indexOf(k) + 1))).join(', ') + '.') : '';

      const sumInner = summaryKidsHTML();
      const linesBlock = sumInner
        ? `<div style="display:flex; flex-direction:column; gap:16px;">${sumInner}</div>`
        : `<p style="font:500 13px/1.5 inherit; color:#9b9890; margin:0;">Pick a camp and some days to see your total here.</p>`;

      const waiverWarn = waiverPending
        ? `<div style="display:flex; align-items:flex-start; gap:8px; font:600 11.5px/1.4 inherit; color:#a2601f; background:#fff7ef; border:1px solid #f0dcc2; border-radius:9px; padding:9px 11px; margin-top:14px;"><i class="bi bi-exclamation-triangle-fill" style="margin-top:1px;"></i><span>${esc(waiverMsg)}</span></div>`
        : '';
      const errorBlock = state.error
        ? `<div style="font:600 11.5px/1.4 inherit; color:#b3261e; background:#fdecea; border-radius:9px; padding:9px 11px; margin-top:14px;">${esc(state.error)}</div>`
        : '';

      const kc = state.kids.length;
      const mobileCount = kc + ' camper' + (kc > 1 ? 's' : '');

      return `<div>
        <section data-noprint style="background:#211f1b; color:#fff; position:relative; overflow:hidden;">
          <div style="position:absolute; inset:0; background:radial-gradient(680px 340px at 88% -20%, rgba(226,121,2,.16), transparent 70%);"></div>
          <div style="max-width:1140px; margin:0 auto; padding:40px 24px 44px; position:relative;">
            <div style="display:inline-flex; align-items:center; gap:9px; font:700 12px/1 'Archivo',sans-serif; letter-spacing:.14em; text-transform:uppercase; color:var(--acc); margin-bottom:16px;"><span style="width:22px; height:2px; background:var(--acc);"></span>Camp registration</div>
            <h1 style="font:900 clamp(30px,6vw,44px)/1.02 'Archivo',sans-serif; letter-spacing:-.02em; margin:0 0 12px;">Build your camp registration</h1>
            <p style="font:400 15.5px/1.55 inherit; color:rgba(255,255,255,.72); max-width:560px; margin:0; text-wrap:pretty;">Add each child, pick their camp and days, add late pickup only where you need it. Your total updates as you go — pay once, securely, at the end.</p>
          </div>
        </section>

        <div class="reg-wrap" style="max-width:1140px; margin:0 auto; padding:26px 16px 60px;">
          <div class="reg-grid">
            <div>
              <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
                <div style="font:700 11px/1 'Archivo',sans-serif; letter-spacing:.13em; text-transform:uppercase; color:#9b9890;">Who's registering</div>
                <div style="font:600 12px/1 inherit; color:#b0aca3;">Full week $350 · fewer days priced per tier · late pickup $20/day</div>
              </div>
              <div style="display:flex; flex-direction:column; gap:14px;">
                ${cards}
                <div class="reg-cta" data-act="addKid" style="border:1.5px dashed #d5d1c8; border-radius:14px; padding:15px; text-align:center; font:800 13.5px/1 'Archivo',sans-serif; color:#8a877f; background:#fff;"><i class="bi bi-plus-lg"></i>&nbsp; Add another child</div>
                <div style="background:#fff; border:1px solid #e8e5dd; border-radius:16px; padding:18px 18px 20px; box-shadow:0 1px 3px rgba(28,25,23,.05);">
                  <div style="font:700 10.5px/1 'Archivo',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:#9b9890; margin-bottom:12px;">Parent / guardian</div>
                  <div style="display:flex; flex-direction:column; gap:10px;">
                    <input class="reg-in" type="text" placeholder="Your name" value="${esc(state.parent.name)}" data-field="parent.name">
                    <div style="display:flex; gap:10px;">
                      <input class="reg-in" style="flex:1;" type="email" placeholder="Email" value="${esc(state.parent.email)}" data-field="parent.email">
                      <input class="reg-in" style="flex:1;" type="tel" placeholder="Phone" value="${esc(state.parent.phone)}" data-field="parent.phone">
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="reg-side">
              <div style="background:#fff; border:1px solid #e3e0d8; border-radius:18px; overflow:hidden; box-shadow:0 1px 3px rgba(28,25,23,.06),0 24px 50px -40px rgba(28,25,23,.5);">
                <div style="background:#211f1b; color:#fff; padding:16px 20px;">
                  <div style="font:700 10px/1 'Archivo',sans-serif; letter-spacing:.12em; text-transform:uppercase; color:var(--acc);">Your registration</div>
                </div>
                <div style="padding:18px 20px;">
                  ${linesBlock}
                  <div style="margin-top:18px; padding-top:16px; border-top:1px solid #ece9e2;">
                    <div style="display:flex; justify-content:space-between; align-items:baseline;"><span style="font:800 15px/1 'Archivo',sans-serif;">Total</span><span style="font:900 26px/1 'Archivo',sans-serif; color:var(--acc);">${totalLabel}</span></div>
                    <div style="font:500 11px/1.4 inherit; color:#9b9890; margin-top:5px;">HST included · charged in full via Square</div>
                  </div>
                  ${waiverWarn}
                  ${errorBlock}
                  <div class="reg-cta" data-act="register" style="margin-top:16px; text-align:center; padding:15px; border-radius:12px; background:var(--acc); color:#fff; font:800 14.5px/1 'Archivo',sans-serif; text-transform:uppercase; letter-spacing:.03em;">Register &amp; pay ${totalLabel}</div>
                  <div style="display:flex; align-items:center; justify-content:center; gap:6px; font:600 10.5px/1.3 inherit; color:#b0aca3; margin-top:10px;"><i class="bi bi-lock-fill"></i>Secure checkout by Square</div>
                </div>
              </div>
            </div>
          </div>

          <div class="reg-mbar" data-noprint style="align-items:center; justify-content:space-between; gap:12px; background:#211f1b; color:#fff; padding:14px 18px; box-shadow:0 -8px 24px -12px rgba(0,0,0,.5);">
            <div>
              <div style="font:600 10.5px/1 inherit; color:rgba(255,255,255,.55); margin-bottom:5px;">${mobileCount}</div>
              <div style="font:900 21px/1 'Archivo',sans-serif; color:var(--acc);">${totalLabel}</div>
            </div>
            <span class="reg-cta" data-act="register" style="display:inline-flex; align-items:center; gap:9px; padding:13px 20px; border-radius:11px; background:var(--acc); color:#fff; font:800 13.5px/1 'Archivo',sans-serif; text-transform:uppercase; letter-spacing:.03em;">Register <i class="bi bi-arrow-right"></i></span>
          </div>
        </div>
      </div>`;
    }

    // ---- confirm stage ----
    const INSTRUCTIONS = [
      { icon:'bi-clipboard-check', title:'Before camp', items:[
        'Sign the one-time waiver for any first-time camper — it must be done before day 1.',
        'Pack a nut-free lunch and snacks, a labelled water bottle, clean indoor running shoes, and comfy clothes to move in. Label everything.' ] },
      { icon:'bi-sun', title:'The day of camp', items:[
        'Doors open at 8:45 AM for arrival. Camp runs 9:00 AM – 2:00 PM.',
        'On day one, arrive a few minutes early so we can check your camper in.' ] },
      { icon:'bi-box-arrow-in-right', title:'Check-in & check-out', items:[
        'Check in at the front desk — a parent/guardian signs each camper in and out.',
        'Standard pickup is 2:00 PM; late pickup (where purchased) runs until 4:00 PM.',
        'Running late, or need late pickup added last-minute? Call us — we’ll keep your camper until you arrive.',
        'Let us know in advance who else is authorized to pick up your child.' ] },
      { icon:'bi-shield-check', title:'Allergies & safety', items:[
        'We are a nut-free facility — please pack accordingly and let coaches know about any allergies.',
        'Cancellations need two weeks’ written notice (15% deposit retained for late notice; otherwise a $20 transaction fee).' ] },
    ];

    function confirmStageHTML() {
      const totalLabel = money(grandTotal());
      const emailLabel = state.parent.email || 'your email';
      const receipt = summaryKidsHTML();
      const instr = INSTRUCTIONS.map((ins) => {
        const items = ins.items.map((it) => `<div style="font:400 13px/1.5 inherit; color:#5b5853; text-wrap:pretty;">${esc(it)}</div>`).join('');
        return `<div style="display:flex; gap:13px;">
          <span style="flex:none; width:38px; height:38px; border-radius:10px; background:#fff7ef; display:flex; align-items:center; justify-content:center;"><i class="bi ${ins.icon}" style="color:var(--acc); font-size:17px;"></i></span>
          <div style="flex:1;">
            <div style="font:800 14px/1.15 'Archivo',sans-serif; margin-bottom:6px;">${ins.title}</div>
            <div style="display:flex; flex-direction:column; gap:5px;">${items}</div>
          </div>
        </div>`;
      }).join('');

      return `<div style="max-width:820px; margin:0 auto; padding:36px 16px 80px;">
        <div class="reg-doc" style="background:#fff; border:1px solid #e3e0d8; border-radius:20px; padding:34px 38px 40px; box-shadow:0 1px 3px rgba(28,25,23,.06),0 30px 60px -46px rgba(28,25,23,.5);">
          <div class="reg-doc-inner" style="max-width:640px; margin:0 auto;">
            <div style="display:flex; align-items:center; gap:14px; margin-bottom:22px;">
              <span style="flex:none; width:52px; height:52px; border-radius:14px; background:#e6f4ea; display:flex; align-items:center; justify-content:center;"><i class="bi bi-check-lg" style="color:#1b6b2f; font-size:28px;"></i></span>
              <div>
                <h1 style="font:900 26px/1.02 'Archivo',sans-serif; letter-spacing:-.015em; margin:0 0 4px;">You're registered!</h1>
                <p style="font:500 13.5px/1.4 inherit; color:#7a7770; margin:0;">Confirmation sent to ${esc(emailLabel)} · ${esc(state.ref)}</p>
              </div>
            </div>

            <div style="border:1px solid #ece9e2; border-radius:14px; overflow:hidden; margin-bottom:26px;">
              <div style="background:#faf9f5; padding:13px 18px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #ece9e2;">
                <span style="font:800 12px/1 'Archivo',sans-serif; letter-spacing:.04em; text-transform:uppercase; color:#211f1b;">Registration summary</span>
                <span style="font:700 11px/1 'Archivo',sans-serif; color:#9b9890;">Paid in full</span>
              </div>
              <div style="padding:16px 18px;">
                ${receipt}
                <div style="display:flex; justify-content:space-between; align-items:baseline; padding-top:13px; border-top:1px solid #ece9e2;"><span style="font:800 14px/1 'Archivo',sans-serif;">Total paid</span><span style="font:900 20px/1 'Archivo',sans-serif; color:var(--acc);">${totalLabel}</span></div>
              </div>
            </div>

            <div style="font:700 11px/1 'Archivo',sans-serif; letter-spacing:.12em; text-transform:uppercase; color:#9b9890; margin-bottom:14px;">What to know before camp</div>
            <div style="display:flex; flex-direction:column; gap:16px;">${instr}</div>

            <div style="margin-top:22px; padding-top:18px; border-top:1px solid #efece4; font:400 12px/1.5 inherit; color:#9b9890; text-wrap:pretty;">${esc(ADDRESS)} · Questions? Reply to your confirmation email or call the front desk.</div>

            <div data-noprint style="display:flex; flex-wrap:wrap; gap:10px; margin-top:24px;">
              <span class="reg-cta" data-act="download" style="display:inline-flex; align-items:center; gap:9px; background:#211f1b; color:#fff; font:800 13px/1 'Archivo',sans-serif; text-transform:uppercase; letter-spacing:.03em; padding:14px 20px; border-radius:11px;"><i class="bi bi-download"></i>Download PDF summary</span>
              <span class="reg-cta" data-act="edit" style="display:inline-flex; align-items:center; gap:9px; background:transparent; color:#211f1b; font:700 13px/1 'Archivo',sans-serif; padding:14px 18px; border-radius:11px; border:1.5px solid #ddd9d0;">Register another camper</span>
            </div>
          </div>
        </div>
      </div>`;
    }

    // ---- render (preserves focus + caret across full rebuilds) ----
    function render() {
      const active = document.activeElement;
      const field = active && active.dataset ? active.dataset.field : null;
      let caret = null;
      if (field) { try { caret = active.selectionStart; } catch (e) { caret = null; } }

      root.innerHTML = state.stage === 'build' ? buildStageHTML() : confirmStageHTML();

      if (field) {
        const el = root.querySelector(`[data-field="${field}"]`);
        if (el) { el.focus(); if (caret != null) { try { el.setSelectionRange(caret, caret); } catch (e) {} } }
      }
    }

    // ---- click actions (event delegation) ----
    function onRegister() {
      const { kids, parent } = state;
      const total = grandTotal();
      if (total <= 0) { state.error = 'Add at least one camp day. Private days are booked separately with the button in the card.'; render(); return; }
      if (!parent.name.trim() || !parent.email.trim()) { state.error = 'Please add the parent/guardian name and email.'; render(); return; }
      for (const k of kids) {
        if (k.camp === 'private') continue;
        if (computeKid(k).total <= 0) { state.error = 'Every camper needs at least one day (or remove them / switch to a private booking).'; render(); return; }
        if (!k.name.trim()) { state.error = 'Please name each camper.'; render(); return; }
        if (!waiverOk(k)) { state.error = 'Waiver still needed for ' + (k.name.trim() || 'a camper') + ' — answer Step 1 and complete it.'; render(); return; }
      }
      state.ref = 'TMV-' + Math.random().toString(36).slice(2, 7).toUpperCase();
      state.stage = 'confirm'; state.error = '';
      render();
      try { window.scrollTo(0, 0); } catch (e) {}
    }

    root.addEventListener('click', (ev) => {
      const el = ev.target.closest('[data-act]');
      if (!el || !root.contains(el)) return;
      const act = el.dataset.act;
      const id = el.dataset.kid;
      const k = id ? kidById(id) : null;
      state.error = '';

      switch (act) {
        case 'addKid': {
          const nid = 'k' + (++seq);
          state.kids = [...state.kids, blankKid(nid)];
          state.expanded = nid;
          break;
        }
        case 'removeKid': {
          ev.stopPropagation();
          state.kids = state.kids.filter((x) => x.id !== id);
          if (state.expanded === id) state.expanded = state.kids[0] ? state.kids[0].id : null;
          break;
        }
        case 'toggleExpand':
          state.expanded = state.expanded === id ? null : id;
          break;
        case 'setCamp':
          if (k) k.camp = el.dataset.camp;
          break;
        case 'toggleWeek': {
          if (!k) break;
          const w = WEEKS.find((x) => x.id === el.dataset.week);
          if (weekExpired(w)) break; // closed weeks can't be selected
          if (k.weeks[w.id]) delete k.weeks[w.id];
          else { const days = {}, late = {}; w.days.forEach((d) => { days[d] = true; late[d] = false; }); k.weeks[w.id] = { mode:'full', days, late }; }
          break;
        }
        case 'weekMode':
          if (k && k.weeks[el.dataset.week]) k.weeks[el.dataset.week].mode = el.dataset.mode;
          break;
        case 'weekDay': {
          const e = k && k.weeks[el.dataset.week];
          if (e) e.days[el.dataset.day] = !e.days[el.dataset.day];
          break;
        }
        case 'weekLate': {
          const e = k && k.weeks[el.dataset.week];
          if (e) e.late[el.dataset.day] = !e.late[el.dataset.day];
          break;
        }
        case 'togglePa': {
          if (!k) break;
          const pid = el.dataset.pa;
          if (k.paDates[pid]) delete k.paDates[pid];
          else k.paDates[pid] = { late:false };
          break;
        }
        case 'paLate': {
          const e = k && k.paDates[el.dataset.pa];
          if (e) e.late = !e.late;
          break;
        }
        case 'waiver':
          if (k) k.waiver = el.dataset.val;
          break;
        case 'waiverDone':
          if (k) k.waiverDone = !k.waiverDone;
          break;
        case 'register':
          onRegister();
          return; // onRegister renders itself
        case 'edit':
          state.stage = 'build';
          break;
        case 'download':
          try { window.print(); } catch (e) {}
          return; // no state change / re-render needed
      }
      render();
    });

    // ---- text inputs (event delegation) ----
    root.addEventListener('input', (ev) => {
      const el = ev.target.closest('[data-field]');
      if (!el) return;
      const field = el.dataset.field;
      const val = el.value;
      state.error = '';
      if (field.startsWith('parent.')) {
        state.parent = { ...state.parent, [field.split('.')[1]]: val };
      } else {
        const [kid, prop] = field.split('.');
        const k = kidById(kid);
        if (k) k[prop] = val;
      }
      render();
    });

    render();
  </script>
</BaseLayout>
