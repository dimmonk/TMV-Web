---
import '../styles/global.css';
import '../styles/mobile-app.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileTabBar from '../components/MobileTabBar.astro';
import MobileAppHeader from '../components/MobileAppHeader.astro';
import MobileMoreSheet from '../components/MobileMoreSheet.astro';
import { site, social, hours, hoursRange, links, url } from '../data/site';

interface Props {
  title: string;
  description: string;
  /** nav key to highlight (train|camps|events|pricing|store|about) */
  active?: string;
  /** override brand accent for this page */
  brand?: string;
  /** absolute-or-relative OG image; defaults to the logo */
  ogImage?: string;
  /** Which bottom tab to light up. A page that lives *under* a tab passes that
   *  tab's key (e.g. /schedule → 'schedule'); pages in the More sheet pass 'more'. */
  mobileTab?: 'home' | 'train' | 'book' | 'schedule' | 'more' | '';
  /** App-header style. 'brand' for the tab destinations, 'back' for pages
   *  underneath them (shows a back chevron + `appTitle`). */
  appHeader?: 'brand' | 'back';
  /** Label beside the back chevron. Defaults to the page title. */
  appTitle?: string;
  /** Where the back chevron goes. Defaults to home. */
  backHref?: string;
}

const {
  title, description, active = '', brand = '#ffd400', ogImage,
  mobileTab = '', appHeader = 'brand', appTitle, backHref,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const image = new URL(ogImage ?? url('assets/tmvlogo.png'), Astro.site).href;

// LocalBusiness structured data — powers Google's business panel (hours, map,
// rating, socials). Built from the single-source-of-truth `site` data.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsActivityLocation',
  name: site.name,
  legalName: site.legalName,
  description: site.description,
  url: new URL(Astro.site!).href,
  telephone: site.phone,
  email: site.email,
  image,
  logo: image,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng },
  openingHoursSpecification: hours.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.day,
    opens: `${String(hoursRange.open).padStart(2, '0')}:00`,
    closes: `${String(hoursRange.close).padStart(2, '0')}:00`,
  })),
  sameAs: [social.instagram, social.facebook, social.youtube].filter(Boolean),
  hasMap: site.mapUrl,
  potentialAction: {
    '@type': 'ReserveAction',
    target: links.booking,
  },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- No device switch, by design. One responsive document serves every
         width: the md stop in global.css picks the app chrome or the site
         chrome. Nothing sniffs the UA and nothing redirects, so a foldable
         simply re-lays-out when it opens. -->
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#211f1b" />
    <link rel="icon" href={url('assets/tmvlogo.png')} />
    <link rel="apple-touch-icon" href={url('assets/tmvlogo.png')} />

    <!-- PWA — scoped to the site root now that the app shell IS the site. -->
    <link rel="manifest" href={url('manifest.json')} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- ICONS: self-hosted, subset to only the ~108 bi-* glyphs the site uses.
         The full jsdelivr bootstrap-icons font was 127KB from an external origin
         (DNS+TLS+download on every cold load); this subset is 12KB, same-origin,
         HTTP/2-multiplexed, and preloaded so icons render immediately. -->
    <link rel="preload" as="font" type="font/woff2" href={url('fonts/bootstrap-icons-subset.woff2')} crossorigin />
    <link rel="stylesheet" href={url('fonts/bootstrap-icons-subset.css')} />

    <!-- Archivo (display font) stays on Google Fonts: it lazy-loads only the
         weights actually rendered (~34KB total on-demand vs 180KB if all five
         weights were self-hosted eagerly). Loaded NON-render-blocking via the
         media=print swap so first paint never waits on the two Google origins;
         text paints in the system fallback and Archivo swaps in (display=swap). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&display=swap"
      rel="stylesheet" media="print" onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&display=swap" rel="stylesheet" />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Plain multi-page navigation, on purpose. There is no client-side router:
        a tap is a normal browser navigation, so the new page paints the instant
        it streams in — no JS interception, no snapshot, no dead pause between
        the click and the page appearing. (A view-transition router was tried and
        removed: with the cross-fade disabled it added ~250ms of snapshot/swap
        work per tap and bought nothing visually.) Each page is a fresh document,
        so component scripts re-run naturally on load. */}

    {/* Cache warmer. On idle, fetch()es every on-screen internal link so its HTML
        sits in the HTTP cache (Firebase serves HTML with max-age) before it's
        tapped — the subsequent browser navigation is then a 0-byte cache hit and
        paints immediately. Inline in <head>, so it waits for DOMContentLoaded to
        see the body's links. Each URL is fetched at most once. */}
    <script is:inline>
      (function () {
        var warmed = new Set();
        function warm() {
          warmed.add(location.pathname.replace(/\/$/, ''));
          var idle = window.requestIdleCallback || function (f) { return setTimeout(f, 200); };
          document.querySelectorAll('a[href^="/"]').forEach(function (a) {
            var href = a.getAttribute('href');
            if (!href || href.indexOf('#') !== -1 || a.target) return;
            var path = href.replace(/\/$/, '');
            if (warmed.has(path)) return;
            warmed.add(path);
            idle(function () {
              fetch(href, { credentials: 'same-origin' }).catch(function () {});
            });
          });
        }
        document.addEventListener('DOMContentLoaded', warm);
      })();
    </script>
  </head>
  <body style={`--brand:${brand}`}>
    <a href="#main" class="visually-hidden">Skip to content</a>
    {/* Both chromes are always in the document; the md stop in global.css shows
        exactly one. Because they are unconditional, a new page cannot forget its
        nav or end up a dead-end on a phone — the old failure mode that the
        redirect + per-page opt-out flags kept producing. */}
    <MobileAppHeader variant={appHeader} title={appTitle ?? title} backHref={backHref} />
    <SiteHeader active={active} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <MobileTabBar active={mobileTab} />
    <MobileMoreSheet />
  </body>
</html>
