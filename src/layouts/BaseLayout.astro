---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site, social, hours, links, url } from '../data/site';

interface Props {
  title: string;
  description: string;
  /** nav key to highlight (train|camps|events|pricing|store|about) */
  active?: string;
  /** override brand accent for this page */
  brand?: string;
  /** absolute-or-relative OG image; defaults to the logo */
  ogImage?: string;
  /** section hash to deep-link into the app-style mobile UI (m/mobile.html#hash) */
  mobileHash?: string;
  /** false = keep phones on this page (for pages with no mobile-app equivalent,
   * e.g. the invitation maker — the mobile shell has no screen for them) */
  mobileRedirect?: boolean;
}

const { title, description, active = '', brand = '#ffd400', ogImage, mobileHash, mobileRedirect = true } = Astro.props;

// Phones get the dedicated app-style mobile UI (design tool's mobile.html).
// Desktop stays on these SEO-rich Astro pages. Deep-link to the matching
// mobile section where we can.
const activeToHash: Record<string, string> = {
  '': 'home', train: 'train', camps: 'camps', events: 'events',
  pricing: 'pricing', store: 'store', about: 'about',
};
const mHash = mobileHash ?? activeToHash[active] ?? 'home';
const mobileUrl = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/m/mobile.html#${mHash}`;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const image = new URL(ogImage ?? url('assets/tmvlogo.png'), Astro.site).href;

// LocalBusiness structured data — powers Google's business panel (hours, map,
// rating, socials). Built from the single-source-of-truth `site` data.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsActivityLocation',
  name: site.name,
  legalName: site.legalName,
  description: site.description,
  url: new URL(Astro.site!).href,
  telephone: site.phone,
  email: site.email,
  image,
  logo: image,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng },
  openingHoursSpecification: hours.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.day,
    opens: '11:00',
    closes: '22:00',
  })),
  sameAs: [social.instagram, social.facebook, social.youtube].filter(Boolean),
  hasMap: site.mapUrl,
  potentialAction: {
    '@type': 'ReserveAction',
    target: links.booking,
  },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Device switch: phones/narrow viewports get the app-style mobile UI;
         desktop stays on this SEO-rich page. Runs before render to avoid a flash.
         Phone-UA check: bare "Android" also matches Android TABLETS and an
         unfolded Fold (they still report "Android" — a folding phone reports
         itself as a tablet once unfolded), so it can't be the phone signal on
         its own. Android appends "Mobile" to the UA only in phone form factor;
         tablets/unfolded omit it. iPhone/iPod/Windows Phone/BlackBerry are
         already phone-specific tokens. -->
    {mobileRedirect && (
      <script is:inline define:vars={{ mobileUrl }}>
        (function () {
          function isPhoneUA() {
            var ua = navigator.userAgent;
            return /iPhone|iPod|Windows Phone|BlackBerry/i.test(ua) || (/Android/i.test(ua) && /Mobile/i.test(ua));
          }
          function wantsMobile() {
            try {
              return (window.matchMedia && window.matchMedia('(max-width:599px)').matches) || isPhoneUA();
            } catch (e) { return false; }
          }
          function go() { if (wantsMobile()) location.replace(mobileUrl); }
          go();
          var t;
          window.addEventListener('resize', function () { clearTimeout(t); t = setTimeout(go, 250); });
        })();
      </script>
    )}
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#211f1b" />
    <link rel="icon" href={url('assets/tmvlogo.png')} />
    <link rel="apple-touch-icon" href={url('assets/tmvlogo.png')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- fonts + icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body style={`--brand:${brand}`}>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <SiteHeader active={active} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
