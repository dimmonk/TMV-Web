---
/**
 * The "More" slide-up sheet — markup restored verbatim from the /m/ app's
 * `more` screen (tile grid, invite promo, dark Visit-us card). It hosts no
 * content of its own: it's the overflow nav plus "how to reach us", i.e. what
 * the footer is on desktop, which mobile hides. Call + Directions stay one tap
 * from any page.
 *
 * The /m/ screen switched screens via JS (data-goto="#hash"); here the tiles
 * are real <a href> to real routes, and the whole thing is a native <dialog>
 * for free focus-trap + Esc-to-close instead of reimplementing them. Styling
 * is unchanged: wrapped in .mapp so it uses the SAME m-tile/m-invite/m-visit
 * rules as every other phone screen (src/styles/mobile-app.css) — no
 * component-local reinvention.
 */
import { url, site } from '../data/site';
import { exploreTiles } from '../data/explore';
---

<dialog class="m-sheet" data-more-sheet aria-label="More">
  <div class="m-sheet-grab"></div>

  <div class="m-sheet-body mapp">
    <button type="button" class="m-sheet-x" data-more-close aria-label="Close">
      <i class="bi bi-x-lg" aria-hidden="true"></i>
    </button>

    <div class="m-pad">
      <div class="m-tiles">
        {exploreTiles.map((t) => (
          <a class="tile m-tile" href={url(t.path)}>
            <span class="m-tile-ic" style={`background:color-mix(in srgb,${t.fg} 14%,#fff)`}><i class={`bi ${t.icon}`} style={`color:${t.fg}`} aria-hidden="true"></i></span>
            <div><div class="m-tile-t">{t.label}</div><div class="m-tile-s">{t.sub}</div></div>
          </a>
        ))}
      </div>

      <a class="m-invite" href={url('make-invitation')} style="--m-invite-accent:#e5399b">
        <span class="m-invite-ic"><i class="bi bi-postcard-heart-fill" aria-hidden="true"></i></span>
        <div class="m-invite-txt">
          <div class="m-invite-t">Invitation maker <span class="m-invite-badge">Free</span></div>
          <div class="m-invite-s">Make a party invite for your birthday booking and download it — right from your phone.</div>
        </div>
        <i class="bi bi-chevron-right m-chev" aria-hidden="true"></i>
      </a>

      <div class="m-visit">
        <div class="m-visit-eyebrow"><span class="mh-rule"></span>Visit us</div>
        <div class="m-visit-rows">
          <div class="m-visit-row"><i class="bi bi-geo-alt-fill" aria-hidden="true"></i><div><div class="m-visit-t">{site.address.street}</div><div class="m-visit-s">{site.address.neighbourhood}, {site.address.locality}</div></div></div>
          <div class="m-visit-row"><i class="bi bi-clock-fill" aria-hidden="true"></i><div><div class="m-visit-t">{site.hoursLabel}</div><div class="m-visit-s">Open gym to the public daily</div></div></div>
          <div class="m-visit-btns">
            <a href={site.mapUrl} target="_blank" rel="noopener" class="m-visit-btn"><i class="bi bi-geo-alt"></i> Directions</a>
            <a href={`tel:${site.phone}`} class="m-visit-btn"><i class="bi bi-telephone-fill"></i> Call us</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</dialog>

<style>
  /* Sheet chrome only (backdrop, grab handle, slide-up, close button) — none
     of this existed in the /m/ app, which had no modal, so it isn't a restore.
     Everything INSIDE .m-sheet-body is the original design via .mapp. */
  .m-sheet { width: 100%; max-width: 100%; margin: auto auto 0; padding: 0; border: 0; background: transparent; max-height: 90dvh; overflow: hidden; }
  .m-sheet::backdrop { background: rgba(20, 18, 16, .5); }
  .m-sheet-grab { width: 38px; height: 4px; border-radius: 999px; background: rgba(255,255,255,.5); margin: 0 auto 9px; }
  .m-sheet-body { position: relative; overflow-y: auto; max-height: calc(90dvh - 13px); background: #f5f4f1; border-radius: 20px 20px 0 0; padding-top: 8px; }
  .m-sheet-body .m-pad { padding-bottom: calc(28px + env(safe-area-inset-bottom, 0px)); }
  .m-sheet-x { position: absolute; top: 22px; right: 18px; z-index: 1; cursor: pointer; width: 34px; height: 34px; border-radius: 50%; border: 0; background: #eceae4; color: #3a3833; display: flex; align-items: center; justify-content: center; }

  @media (prefers-reduced-motion: no-preference) {
    .m-sheet[open] { animation: m-sheet-up .22s cubic-bezier(.22, 1, .36, 1); }
    @keyframes m-sheet-up { from { transform: translateY(14%); } to { transform: none; } }
  }
</style>

<script>
  const sheet = document.querySelector<HTMLDialogElement>('[data-more-sheet]');
  if (sheet) {
    document.querySelectorAll<HTMLElement>('[data-more-open]').forEach((btn) => {
      btn.addEventListener('click', () => sheet.showModal());
    });
    sheet.querySelector<HTMLElement>('[data-more-close]')?.addEventListener('click', () => sheet.close());
    sheet.addEventListener('click', (e) => {
      if (e.target === sheet) sheet.close();
    });
  }
</script>
