---
/**
 * The app shell's sticky header — the mobile half of the site chrome.
 *
 * BaseLayout renders this alongside SiteHeader and lets CSS pick one: below the
 * md stop this shows and SiteHeader hides, at md and up the reverse (the handoff
 * lives in ONE place, global.css). There is no device sniffing and no redirect.
 *
 * Ported out of the old `/m/` single-page app, where a JS router toggled between
 * a "main" and a "sub" header row. Real routes make that unnecessary: a page
 * simply declares which variant it wears, and the back chevron is a real link,
 * so it works even on a cold deep-link in from search.
 */
import { url, site, hoursRange } from '../data/site';

interface Props {
  /** 'brand' for the tab-bar destinations; 'back' for everything underneath them. */
  variant?: 'brand' | 'back';
  /** Label beside the back chevron on 'back' pages. */
  title?: string;
  /** Where back goes. A real href — not history.back() — so deep links behave. */
  backHref?: string;
}
const { variant = 'brand', title = 'Back', backHref = url('') } = Astro.props;
---

<header class="m-head" data-chrome="app">
  <div class="m-head-row">
    {variant === 'brand' ? (
      <div class="m-brand">
        <img src={url('assets/tmvlogo.png')} alt="" width="32" height="32" />
        <span>{site.name}</span>
      </div>
    ) : (
      <a class="m-back" href={backHref}>
        <i class="bi bi-chevron-left" aria-hidden="true"></i><span>{title}</span>
      </a>
    )}
    <span class="m-status" data-status>
      <span class="m-status-dot"></span><span class="m-status-label">Open now</span>
    </span>
  </div>
</header>

<style>
  /* No border: every screen has a hero of this SAME solid #211f1b directly
     beneath the header, so a dividing line here reads as an unwanted seam
     between two things that should look like one block on first load. Once
     scrolled, the header (still sticky, still dark) against the page's light
     background is already distinct enough on its own — no explicit border
     needed for that either. */
  .m-head { position: sticky; top: 0; z-index: 15; background: #211f1b; padding: calc(16px + env(safe-area-inset-top, 0px)) 18px 16px; }
  /* min-height pinned to the logo's height (32px) — the only fixed-size
     content in either variant — so the header is the same total height
     whether a page shows the brand row or the back row. Without this, the
     back row's negative-margin tap target (below) sizes shorter than the
     logo and the header visibly shrinks on every 'back' page. */
  .m-head-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; min-height: 32px; }
  .m-brand { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .m-brand img { flex: none; width: 32px; height: 32px; object-fit: contain; }
  .m-brand span { font: 900 14.5px/1 'Archivo', sans-serif; letter-spacing: .01em; text-transform: uppercase; color: #fff; white-space: nowrap; }
  /* Negative margin keeps the label optically aligned with the brand row while
     the padding gives the chevron a 44px-tall tap target. */
  .m-back { text-decoration: none; display: inline-flex; align-items: center; gap: 5px; font: 800 17px/1 'Archivo', sans-serif; letter-spacing: -.01em; color: #fff; white-space: nowrap; min-width: 0; min-height: 44px; padding: 0 10px 0 4px; margin: -12px 0 -12px -4px; }
  .m-back span { overflow: hidden; text-overflow: ellipsis; }
  .m-back i { font-size: 18px; color: #ffd400; }
  .m-status { flex: none; display: inline-flex; align-items: center; gap: 6px; font: 700 11px/1 'Archivo', sans-serif; letter-spacing: .04em; text-transform: uppercase; border-radius: 999px; padding: 7px 11px; white-space: nowrap; color: #5fd07f; background: rgba(95,208,127,.13); border: 1px solid rgba(95,208,127,.28); }
  .m-status-dot { flex: none; width: 7px; height: 7px; border-radius: 50%; background: #5fd07f; }
  @keyframes tmv-pulse { 0% { box-shadow: 0 0 0 0 rgba(95,208,127,.5); } 70% { box-shadow: 0 0 0 6px rgba(95,208,127,0); } 100% { box-shadow: 0 0 0 0 rgba(95,208,127,0); } }
  .tmv-pulse { animation: tmv-pulse 1.6s ease-in-out infinite; }
</style>

<script define:vars={{ OPEN_H: hoursRange.open, CLOSE_H: hoursRange.close }}>
  // Live "Open now / Closes at X / Opens 11 AM" pill.
  //
  // Hours come from hoursRange (src/data/site.ts) via define:vars — the same
  // numbers the LocalBusiness JSON-LD emits — rather than being hardcoded here.
  // This previously special-cased Friday to a midnight close, which was wrong:
  // the Friday late window is ADULTS ONLY and deliberately excluded from the
  // advertised general hours, so a family saw "Open now" at 11 PM Friday.
  //
  // NOTE: define:vars makes this an inline script, so it is plain JS — no TS
  // annotations in here.
  function formatHour12(totalMinutes) {
    var h24 = Math.floor(totalMinutes / 60) % 24;
    var h12 = h24 % 12 === 0 ? 12 : h24 % 12;
    return h12 + ' ' + (h24 < 12 ? 'AM' : 'PM');
  }
  function openStatus() {
    var hour = 12, minute = 0;
    try {
      var parts = new Intl.DateTimeFormat('en-US', { timeZone: 'America/Toronto', hour12: false, hour: '2-digit', minute: '2-digit' }).formatToParts(new Date());
      var m = Object.fromEntries(parts.map(function (p) { return [p.type, p.value]; }));
      hour = parseInt(m.hour, 10) % 24; minute = parseInt(m.minute, 10) || 0;
    } catch (e) { /* fall back to open */ }
    var mins = hour * 60 + minute;
    var openAt = OPEN_H * 60, closeAt = CLOSE_H * 60;
    var isOpen = mins >= openAt && mins < closeAt;
    if (isOpen && closeAt - mins <= 120) return { label: 'Closes at ' + formatHour12(closeAt), fg: '#ffb84d', bg: 'rgba(255,184,77,.14)', bd: 'rgba(255,184,77,.3)', dot: '#ffb84d', pulse: false };
    if (isOpen) return { label: 'Open now', fg: '#5fd07f', bg: 'rgba(95,208,127,.13)', bd: 'rgba(95,208,127,.28)', dot: '#5fd07f', pulse: true };
    return { label: 'Opens ' + formatHour12(openAt), fg: 'rgba(255,255,255,.6)', bg: 'rgba(255,255,255,.07)', bd: 'rgba(255,255,255,.15)', dot: 'rgba(255,255,255,.4)', pulse: false };
  }
  function paintStatus() {
    var s = openStatus();
    document.querySelectorAll('[data-status]').forEach(function (el) {
      el.style.color = s.fg; el.style.background = s.bg; el.style.borderColor = s.bd;
      var dot = el.querySelector('.m-status-dot');
      var label = el.querySelector('.m-status-label');
      if (dot) { dot.style.background = s.dot; dot.classList.toggle('tmv-pulse', s.pulse); }
      if (label) label.textContent = s.label;
    });
  }
  // Paint the pill on load, then keep it fresh with a 60s ticker.
  paintStatus();
  setInterval(paintStatus, 60000);
</script>
