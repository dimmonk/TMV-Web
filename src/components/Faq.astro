---
import { site } from '../data/site';
interface QA { q: string; a: string; }
interface Props {
  eyebrow?: string;
  heading?: string;
  subhead?: string;
  faqs?: QA[];
}
const {
  eyebrow = 'Good to know',
  heading = 'Frequently asked questions',
  subhead = 'Everything a first-timer usually wants to know before walking in.',
  faqs = [
    { q: 'Do I need any experience to start?', a: 'None at all. Most people who walk in have never done parkour before. Book an Introduction Class or drop into open gym and a coach will start you with the basics at your own pace.' },
    { q: 'What ages do you welcome?', a: 'Everyone from age 3 and up. We run youth classes, adult classes, camps for kids 6–16, and open gym for all ages. There is a class and a session for every body.' },
    { q: 'What should I wear and bring?', a: 'Comfortable clothes you can move in, a second pair of clean indoor shoes (not the ones you arrived in), and a water bottle. Forgot your shoes? You can train barefoot to start.' },
    { q: 'Do I need to sign a waiver?', a: 'Yes — everyone needs a signed waiver before their first session. It takes a couple of minutes online. A parent or legal guardian must sign for anyone 17 or younger.' },
    { q: 'Do I have to book, or can I just drop in?', a: 'Both work. Open Gym and Group Classes need no reservation — just check the schedule and show up. Introduction and Private Classes are reserved ahead of time so a coach is set aside for you.' },
    { q: 'Is it safe? What about the kids?', a: 'Safety is built into the space — padded floors, a foam pit, and trained coaches who scale every skill to your level. Read the Rules poster at the entrance and your coach will guide the rest.' },
    { q: 'How early should I arrive?', a: "Please arrive 15 minutes before your class to sign in. There's a 15-minute cutoff, and anyone more than 30 minutes late can't be admitted to that class, to be fair to those who arrive on time." },
    { q: 'Can I host a birthday or group event?', a: 'Absolutely. We run full and mini birthday parties plus group events for schools, teams and organizations. Weekend slots fill fast, so book early — see the Events page for details.' },
  ],
} = Astro.props;
---
<section class="faq">
  <div class="faq-wrap">
    <div class="faq-head">
      <div class="faq-eyebrow">{eyebrow}</div>
      <h2 class="faq-heading">{heading}</h2>
      <p class="faq-sub">{subhead}</p>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary class="faq-q"><span>{f.q}</span><i class="bi bi-plus-lg faq-chev" aria-hidden="true"></i></summary>
          <p class="faq-a">{f.a}</p>
        </details>
      ))}
    </div>
    <div class="faq-foot">
      Still have a question? <a href={`mailto:${site.email}`}>Email us</a> or call <a href={`tel:${site.phone}`}>{site.phoneDisplay}</a>.
    </div>
  </div>
</section>

<style>
  .faq { background: var(--bg); }
  .faq-wrap { max-width: 880px; margin-inline: auto; padding: clamp(48px,8vw,72px) 24px; }
  .faq-head { text-align: center; margin-bottom: 38px; }
  .faq-eyebrow { font: 700 12px/1 var(--font-display); letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin-bottom: 10px; }
  .faq-heading { font: 800 clamp(26px,5vw,36px)/1.04 var(--font-display); letter-spacing: -.018em; margin-bottom: 10px; }
  .faq-sub { font: 400 15px/1.55 var(--font-body); color: var(--muted); max-width: 460px; margin-inline: auto; }
  .faq-list { display: flex; flex-direction: column; gap: 12px; }
  .faq-item { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 4px 24px; box-shadow: 0 1px 3px rgba(28,25,23,.04); transition: border-color .2s ease; }
  .faq-item[open] { border-color: #dcd9d1; }
  .faq-q { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 16px 0; cursor: pointer; list-style: none; font: 700 16px/1.4 var(--font-display); color: #2b2925; }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q:hover { color: var(--ink); }
  .faq-chev { flex: none; font-size: 16px; color: var(--brand); transition: transform .25s ease; }
  .faq-item[open] .faq-chev { transform: rotate(45deg); }
  .faq-a { font: 400 14px/1.6 var(--font-body); color: #5a574f; margin: 0 0 16px; text-wrap: pretty; }
  .faq-foot { text-align: center; margin-top: 32px; font: 500 14px/1.6 var(--font-body); color: var(--muted); }
  .faq-foot a { color: var(--ink); font-weight: 700; text-decoration: none; border-bottom: 2px solid var(--brand); }
</style>
