---
/**
 * The app shell's fixed bottom tab bar — the mobile half of the site nav.
 *
 * BaseLayout renders this on every page; the md chrome handoff in global.css
 * shows it below the stop and hides it at md and up (where SiteHeader takes
 * over). It is plain CSS-conditional chrome — which is why an app-style mobile
 * UI needs no separate document, no `/m/` route and no device redirect.
 *
 * The four destinations are real routes, so every tab is a normal link with a
 * real URL, working back button and crawlable target. "More" is not a
 * destination — it opens the More sheet (see MobileMoreSheet).
 */
import { url } from '../data/site';

interface Props {
  /** Which tab to light up. Pages under a tab pass that tab's key. */
  active?: 'home' | 'train' | 'book' | 'schedule' | 'more' | '';
}
const { active = '' } = Astro.props;
---

<nav class="mtab" data-chrome="app" aria-label="Main">
  <a class:list={['mtab-btn', active === 'home' && 'active']} href={url('')}><i class="bi bi-house-door-fill" aria-hidden="true"></i><span>Home</span></a>
  <a class:list={['mtab-btn', active === 'train' && 'active']} href={url('train')}><i class="bi bi-person-arms-up" aria-hidden="true"></i><span>Train</span></a>
  <a class="mtab-btn mtab-center" href={url('book')}><span class="mtab-center-c"><i class="bi bi-calendar-check-fill" aria-hidden="true"></i></span><span>Book</span></a>
  <a class:list={['mtab-btn', active === 'schedule' && 'active']} href={url('schedule')}><i class="bi bi-calendar3" aria-hidden="true"></i><span>Schedule</span></a>
  <button type="button" class:list={['mtab-btn', active === 'more' && 'active']} data-more-open aria-haspopup="dialog"><i class="bi bi-grid-fill" aria-hidden="true"></i><span>More</span></button>
</nav>

<style>
  .mtab { position: fixed; left: 0; right: 0; bottom: 0; z-index: 50; background: rgba(28,26,23,.92); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-top: 1px solid rgba(255,255,255,.08); padding: 9px 12px calc(13px + env(safe-area-inset-bottom, 10px)); display: flex; align-items: flex-end; }
  .mtab-btn { flex: 1; cursor: pointer; background: none; border: 0; padding: 0; text-decoration: none; display: flex; flex-direction: column; align-items: center; gap: 7px; color: rgba(255,255,255,.42); }
  .mtab-btn i { font-size: 26px; }
  .mtab-btn span { font: 700 12px/1 'Archivo', sans-serif; letter-spacing: .02em; }
  .mtab-btn.active { color: #fff; }
  .mtab-btn:active { transform: scale(.9); }
  .mtab-center .mtab-center-c { width: 64px; height: 64px; margin-top: -36px; border-radius: 50%; background: #ffd400; border: 4px solid rgba(28,26,23,.92); box-shadow: 0 6px 15px -7px rgba(255,212,0,.45); display: flex; align-items: center; justify-content: center; }
  .mtab-center .mtab-center-c i { font-size: 29px; color: #211f1b; }
  .mtab-center span:last-child { font-weight: 800; text-transform: uppercase; }
</style>
