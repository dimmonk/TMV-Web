---
interface Props {
  items: string;          // "Ages 5+ | Private room | Coach-led"
  variant?: 'light' | 'dark' | 'tinted';
  color?: string;         // accent for the tinted variant
  gap?: number;
}
const { items, variant = 'light', color = '#2196f3', gap = 8 } = Astro.props;
const list = items.split('|').map((s) => s.trim()).filter(Boolean);

const styles = {
  light: { bg: '#fff', fg: '#3a3833', bd: '#e6e4dd' },
  dark: { bg: 'rgba(255,255,255,.08)', fg: 'rgba(255,255,255,.85)', bd: 'rgba(255,255,255,.16)' },
  tinted: {
    bg: `color-mix(in srgb, ${color} 10%, #fff)`,
    fg: `color-mix(in srgb, ${color} 55%, #000)`,
    bd: `color-mix(in srgb, ${color} 24%, #fff)`,
  },
}[variant];
---
<ul class="pills" style={`--gap:${gap}px; --bg:${styles.bg}; --fg:${styles.fg}; --bd:${styles.bd}`}>
  {list.map((p) => <li class="pill">{p}</li>)}
</ul>

<style>
  .pills { display: flex; flex-wrap: wrap; gap: var(--gap); }
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    font: 600 12.5px/1 var(--font-body); white-space: nowrap;
    border-radius: 999px; padding: 7px 12px;
    color: var(--fg); background: var(--bg); border: 1px solid var(--bd);
  }
</style>
