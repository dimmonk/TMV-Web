---
/** The dark "page hero" card shown at the top of every non-home mobile screen. */
interface Stat { v: string; l: string; }
interface Props {
  eyebrow: string;
  title: string;
  desc: string;
  stats?: Stat[];
}
const { eyebrow, title, desc, stats } = Astro.props;
---
<div class="mh">
  <div class="mh-glow"></div>
  <div class="mh-inner">
    <div class="mh-eyebrow"><span class="mh-rule"></span>{eyebrow}</div>
    <h2 class="mh-title">{title}</h2>
    <p class="mh-desc">{desc}</p>
    {stats && (
      <div class="mh-stats">
        {stats.map((st, i) => (
          <div class="mh-stat" style={`text-align:${i === stats.length - 1 ? 'right' : i === 0 ? 'left' : 'center'};${i === stats.length - 1 ? '' : 'border-right:1px solid rgba(255,255,255,.12);'}`}>
            <div class="mh-stat-v">{st.v}</div>
            <div class="mh-stat-l">{st.l}</div>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  /* Full-bleed: no radius, no side inset — fuses with the sticky app bar above
     it into one continuous dark header band. Internal padding is unchanged so
     the text still clears the edges. */
  .mh { background: #211f1b; color: #fff; padding: 24px 22px; position: relative; overflow: hidden; }
  .mh-glow { position: absolute; inset: 0; background: radial-gradient(360px 200px at 92% -20%, rgba(255,212,0,.16), transparent 70%); }
  .mh-inner { position: relative; }
  .mh-eyebrow { display: inline-flex; align-items: center; gap: 8px; font: 700 10.5px/1 'Archivo', sans-serif; letter-spacing: .12em; text-transform: uppercase; color: #ffd400; margin-bottom: 16px; }
  .mh-rule { width: 18px; height: 2px; background: #ffd400; }
  .mh-title { font: 800 30px/1.04 'Archivo', sans-serif; letter-spacing: -.02em; margin: 0 0 12px; }
  .mh-desc { font: 400 14px/1.55 inherit; color: rgba(255,255,255,.72); margin: 0; }
  .mh-stats { display: flex; border-top: 1px solid rgba(255,255,255,.12); margin-top: 20px; padding-top: 16px; }
  .mh-stat { flex: 1; }
  .mh-stat-v { font: 800 18px/1 'Archivo', sans-serif; color: #ffd400; }
  .mh-stat-l { font: 600 10.5px/1.3 inherit; color: rgba(255,255,255,.6); margin-top: 5px; }
</style>
