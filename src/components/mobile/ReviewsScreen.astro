---
/**
 * Reviews — phone composition. App-native: MobileHero (which already carries
 * the rating + count) followed by a clean stack of quote cards built straight
 * from the reviews SSOT. Deliberately does NOT reuse the desktop <Reviews>
 * component — that's a wide grid with its own rating badge, which duplicated
 * the hero and read as a squished desktop import on a phone.
 */
import MobileHero from '../MobileHero.astro';
import { links, url, reviews, cat } from '../../data/site';

const avatarColors = [cat.openGym, cat.parties, cat.classes, cat.camps, cat.athletic];
const stars = (v: string) => {
  const n = Math.round(parseFloat(v));
  return '★★★★★'.slice(0, n) + '☆☆☆☆☆'.slice(0, 5 - n);
};
---
<MobileHero eyebrow="Reviews" title="Loved by the community" desc="What Toronto says about training here — parents, open-gym members, first-timers and athletes." stats={[{ v: reviews.ratingValue + '★', l: 'Google rating' }, { v: '449', l: 'reviews' }, { v: '5★', l: 'and counting' }]} />
<div class="m-pad">
  <div class="rvm-stack">
    {reviews.items.map((r, i) => (
      <figure class="rvm-card">
        <div class="rvm-stars">{stars(reviews.ratingValue)}</div>
        <blockquote class="rvm-quote">“{r.pull ?? r.quote}”</blockquote>
        <figcaption class="rvm-by">
          <span class="rvm-avatar" style={`background:${avatarColors[i % avatarColors.length]}`}>{r.name.charAt(0)}</span>
          <span class="rvm-bytext"><span class="rvm-name">{r.name}</span><span class="rvm-context">{r.context}</span></span>
        </figcaption>
      </figure>
    ))}
  </div>

  <a href={links.googleReviews} target="_blank" rel="noopener" class="m-darkbtn" style="margin-top:22px"><i class="bi bi-google"></i> Read all {reviews.ratingCount.replace(/^Based on /, '')}</a>
  <a href={url('get-started')} class="m-darkbtn" style="margin-top:10px;background:#fff;color:#211f1b;border:1px solid #ebe9e4">Start your first visit <i class="bi bi-arrow-right"></i></a>
</div>

<style>
  .rvm-stack { display: flex; flex-direction: column; gap: 12px; }
  .rvm-card { background: #fff; border: 1px solid #ebe9e4; border-radius: 16px; box-shadow: 0 1px 3px rgba(28,25,23,.04), 0 14px 30px -24px rgba(28,25,23,.38); padding: 18px 18px 16px; margin: 0; }
  .rvm-stars { color: #e9a300; font-size: 13px; letter-spacing: 2px; margin-bottom: 10px; }
  .rvm-quote { font: 500 14.5px/1.55 var(--font-body); color: #3a3833; margin: 0 0 16px; }
  .rvm-by { display: flex; align-items: center; gap: 11px; }
  .rvm-avatar { flex: none; width: 38px; height: 38px; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; font: 800 15px/1 'Archivo', sans-serif; }
  .rvm-bytext { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .rvm-name { font: 800 13.5px/1.1 'Archivo', sans-serif; color: #211f1b; }
  .rvm-context { font: 600 12px/1.2 var(--font-body); color: #9b9890; }
</style>
