---
/**
 * Train — the phone composition, verbatim from the /m/ app's `train` screen.
 * See HomeScreen for how the mobile/desktop compositions are switched.
 */
import MobileHero from '../MobileHero.astro';
import BookingCard from '../BookingCard.astro';
import ClassCard from '../ClassCard.astro';
import { coreClasses, specializedClasses, partnershipClasses } from '../../data/classes';
import type { ClassItem } from '../../data/classes';
import { cat, links, url } from '../../data/site';

// Action href for a class on the phone: every `link.screen` value is now a
// real route (private-lessons and athletic-program got their own phone
// screens), so this is a straight route lookup — no more falling back to a
// Square link because a screen didn't exist yet.
const classHref = (c: ClassItem): string =>
  'external' in c.link ? c.link.external : url(c.link.screen);
---
<MobileHero eyebrow="Train" title="Every way to move" desc="Open gym, coached classes and the Athletic Program — every age, every level, one big roof." stats={[{ v: '4', l: 'ways to train' }, { v: 'Ages 3+', l: 'all levels' }, { v: '7 days', l: 'a week' }]} />
<div class="m-pad">
  <BookingCard color={cat.openGym} bookingTag="Drop-in" duration="No limit" title="Open Gym" description="Drop in any day and stay as long as you like. Sign the waiver, grab a pass, the floor is yours." pills="All ages | 11 AM – 10 PM | No booking" price="From $25" priceNote="day pass" actionLabel="Get a pass" href={links.store} target="_blank" />

  <div class="m-rowhead" style="margin:26px 0 6px">
    <h3 class="m-h3" style="margin:0">Core programs</h3>
    <a class="m-alllink" href={url('schedule')}>Times <i class="bi bi-calendar3" style={`color:${cat.classes}`} aria-hidden="true"></i></a>
  </div>
  <p class="m-sub" style="margin-bottom:14px">Tap a card to flip it for level, ages, schedule &amp; price.</p>
  <div class="m-stack" style="margin-bottom:30px">
    {coreClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}
  </div>

  <h3 class="m-h3">Specialized classes</h3>
  <p class="m-sub" style="margin-bottom:14px">Focused, skill-specific sessions for one discipline.</p>
  <div class="m-stack" style="margin-bottom:30px">
    {specializedClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}
  </div>

  {/* Desktop's Class Membership block — a $180 unlimited offer that covers
      every class on this screen. Was missing from mobile entirely, so the
      phone showed the classes with no way to learn they can be bought as one
      pass. Uses the same m-gcard/m-gfoot2 pattern Groups uses. */}
  <div class="m-gcard" style="margin-bottom:30px">
    <div class="m-ghead">
      <span class="m-gic" style={`background:color-mix(in srgb,${cat.classes} 14%,#fff)`}><i class="bi bi-infinity" style={`color:${cat.classes}`} aria-hidden="true"></i></span>
      <div><div class="m-geyebrow" style={`color:${cat.classes}`}>One membership · all access</div><div class="m-gtitle">Every class, unlimited</div></div>
    </div>
    <p class="m-gdesc">Unlocks every recreational and specialized class above, plus unlimited open gym. No per-class fees, no reservations. Private lessons, the Athletic Program and partner classes are billed separately.</p>
    <div class="m-gfoot2">
      <div><div class="m-gbig">$180</div><div class="m-gsub">30 days · unlimited</div></div>
      <a href={`${url('store')}#classes`} class="m-darkbtn-sm">Get it <i class="bi bi-arrow-right"></i></a>
    </div>
  </div>

  <h3 class="m-h3">Partnerships</h3>
  <p class="m-sub" style="margin-bottom:14px">Run by trusted partner coaches who share our space.</p>
  <div class="m-stack">
    {partnershipClasses.map((c) => <ClassCard {...c} href={classHref(c)} />)}
  </div>
</div>
