---
import { url } from '../data/site';
interface Props {
  category?: string;
  color?: string;
  tag?: string;
  title: string;
  description?: string;
  pills?: string;
  bookingTag?: string;
  mediaBadge?: string;
  image: string;         // e.g. "assets/recreational.gif"
  actionLabel?: string;
  href: string;
  backEyebrow?: string;
  backHeadline?: string;
  backBody?: string;
  specs?: string;        // "Level: All levels || Ages: 7+ || Price: $30"
  backActionLabel?: string;
}
const {
  category = 'Parkour', color = '', tag = '', title, description = '', pills = '',
  bookingTag = '', mediaBadge = '', image, actionLabel = 'View schedule', href,
  backEyebrow = '', backHeadline = '', backBody = '', specs = '', backActionLabel = '',
} = Astro.props;

const catKeyMap: Record<string, string> = {
  parkour: 'classes', flips: 'classes', strength: 'classes', tricking: 'classes',
  gymnastics: 'classes', private: 'private', athletic: 'athletic', partner: 'partner',
};
const palette: Record<string, string> = { classes: '#2196f3', private: '#f44336', athletic: '#ffb82a', partner: '#0d9488' };
const key = category.toLowerCase();
const catKey = catKeyMap[key] ?? 'classes';
const catColor = color.trim() || palette[catKey] || '#2196f3';
const isAthletic = key === 'athletic';
const tagText = isAthletic ? '#2a1e00' : '#ffffff';
const catInk = isAthletic ? `color-mix(in srgb, ${catColor} 70%, #000)` : catColor;
const tagLabel = tag.trim() || category;

const pillList = pills.split('|').map((s) => s.trim()).filter(Boolean);
const bookingIconMap: Record<string, string> = {
  'Drop-in': 'bi-door-open', 'By appointment': 'bi-calendar-check', 'Membership': 'bi-arrow-repeat',
  'Register': 'bi-calendar-event', 'Direct with coach': 'bi-chat-dots',
};
const bookingIcon = bookingIconMap[bookingTag] || 'bi-info-circle';

const specList = specs.split('||').map((s) => s.trim()).filter(Boolean).map((row) => {
  const i = row.indexOf(':');
  return i >= 0 ? { label: row.slice(0, i).trim(), value: row.slice(i + 1).trim() } : { label: '', value: row };
});
const hasBack = !!backHeadline.trim();
const backEye = backEyebrow.trim() || `${tagLabel} · ${category}`;
const backAction = backActionLabel.trim() || actionLabel;
// external links (mailto:, http) open as-is; internal ".dc.html" refs are mapped by callers
const isExternal = /^(https?:|mailto:)/.test(href);
const src = image.startsWith('assets/') ? url(image) : image;
---
<article class:list={['cc', { flippable: hasBack }]} style={`--cat:${catColor}; --cat-ink:${catInk}`} aria-pressed="false">
  <div class="cc-inner">
    <div class="cc-face cc-front">
      <div class="cc-strip"></div>
      <div class="cc-media">
        <img class="cc-img" src={src} alt={title} loading="lazy" />
        <div class="cc-tags">
          <span class="cc-tag" style={`color:${tagText}`}>{tagLabel}</span>
          {mediaBadge && <span class="cc-badge"><i class="bi bi-lock-fill" aria-hidden="true"></i>{mediaBadge}</span>}
        </div>
        {hasBack && <button class="cc-flipbtn" type="button" aria-label="More info"><i class="bi bi-arrow-repeat" aria-hidden="true"></i></button>}
      </div>
      <div class="cc-body">
        {bookingTag && <span class="cc-booking" style={`color:${tagText}`}><i class={`bi ${bookingIcon}`} aria-hidden="true"></i>{bookingTag}</span>}
        <h3 class="cc-title">{title}</h3>
        <p class="cc-desc">{description}</p>
        <div class="cc-bottom">
          {pillList.length > 0 && <div class="cc-pills">{pillList.map((p) => <span class="cc-pill">{p}</span>)}</div>}
          <a href={href} class="cc-act" {...(isExternal ? { target: '_blank', rel: 'noopener' } : {})}>{actionLabel} <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
        </div>
      </div>
    </div>

    {hasBack && (
      <div class="cc-face cc-back">
        <div class="cc-backhead">
          <span class="cc-backeye">{backEye}</span>
          <button class="cc-flipback" type="button"><i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i> Flip back</button>
        </div>
        <h3 class="cc-backtitle">{backHeadline}</h3>
        <p class="cc-backbody">{backBody}</p>
        <div class="cc-specs">
          {specList.map((s) => (
            <div class="cc-spec"><span class="cc-spec-l">{s.label}</span><span class="cc-spec-v">{s.value}</span></div>
          ))}
        </div>
        <a href={href} class="cc-act" {...(isExternal ? { target: '_blank', rel: 'noopener' } : {})}>{backAction} <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
      </div>
    )}
  </div>
</article>

<style>
  .cc { position: relative; height: 100%; perspective: 1600px; transition: transform .22s ease; }
  .cc.flippable { cursor: pointer; }
  .cc:hover { transform: translateY(-5px); }
  .cc-inner { position: relative; width: 100%; height: 100%; transition: transform .6s cubic-bezier(.2,.75,.25,1); transform-style: preserve-3d; }
  .cc.flipped .cc-inner { transform: rotateY(180deg); }
  .cc-face { backface-visibility: hidden; -webkit-backface-visibility: hidden; box-shadow: 0 1px 3px rgba(28,25,23,.05), 0 12px 30px -22px rgba(28,25,23,.4); }
  .cc:hover .cc-face { box-shadow: 0 1px 3px rgba(28,25,23,.05), 0 22px 40px -22px rgba(28,25,23,.45); }
  .cc-front { position: relative; min-height: 100%; display: flex; flex-direction: column; background: #fff; border: 1px solid var(--line); border-radius: 16px; overflow: hidden; }
  .cc-back { position: absolute; inset: 0; transform: rotateY(180deg); background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 22px 22px 20px; display: flex; flex-direction: column; overflow: auto; }
  .cc-strip { height: 4px; background: var(--cat); flex: none; }
  .cc-media { position: relative; aspect-ratio: 16/11; overflow: hidden; background: var(--ink); }
  .cc-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s ease; }
  .cc:hover .cc-img { transform: scale(1.05); }
  .cc-tags { position: absolute; top: 12px; left: 12px; display: flex; flex-direction: column; align-items: flex-start; gap: 7px; }
  .cc-tag { padding: 5px 10px; border-radius: 999px; background: var(--cat); font: 700 11px/1 var(--font-display); letter-spacing: .08em; text-transform: uppercase; box-shadow: 0 3px 10px rgba(0,0,0,.3); }
  .cc-badge { display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 999px; background: rgba(28,25,23,.62); backdrop-filter: blur(4px); color: #ffd86b; font: 700 10px/1 var(--font-display); letter-spacing: .06em; text-transform: uppercase; }
  .cc-badge i { font-size: 10px; }
  .cc-flipbtn { position: absolute; top: 12px; right: 12px; z-index: 2; width: 30px; height: 30px; border-radius: 50%; background: rgba(28,25,23,.5); backdrop-filter: blur(4px); border: 0; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; cursor: pointer; transition: all .15s; }
  .cc-flipbtn:hover { background: var(--cat); }
  .cc-body { display: flex; flex-direction: column; gap: 13px; padding: 20px 20px 22px; flex: 1; }
  .cc-booking { align-self: flex-start; display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 6px; background: var(--cat); font: 800 10.5px/1 var(--font-display); letter-spacing: .07em; text-transform: uppercase; }
  .cc-booking i { font-size: 12px; }
  .cc-title { font: 800 21px/1.1 var(--font-display); letter-spacing: -.01em; color: var(--ink); margin: 0; }
  .cc-desc { font: 400 13px/1.5 var(--font-body); color: var(--text-3); margin: 0; }
  .cc-bottom { margin-top: auto; display: flex; flex-direction: column; gap: 13px; }
  .cc-pills { display: flex; flex-wrap: wrap; gap: 6px; }
  .cc-pill { font: 600 12.5px/1 var(--font-body); color: var(--cat-ink); background: color-mix(in srgb, var(--cat) 10%, #fff); border: 1px solid color-mix(in srgb, var(--cat) 24%, #fff); border-radius: 999px; padding: 5px 10px; white-space: nowrap; }
  .cc-act { display: inline-flex; align-items: center; gap: 7px; padding-top: 13px; border-top: 1px solid var(--line-soft); font: 800 14px/1 var(--font-display); text-transform: uppercase; letter-spacing: .03em; color: var(--ink); text-decoration: none; transition: gap .15s; }
  .cc-act:hover { gap: 11px; }
  .cc-act i { color: var(--cat); }
  .cc-backhead { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .cc-backeye { font: 700 11px/1 var(--font-display); letter-spacing: .1em; text-transform: uppercase; color: var(--cat-ink); }
  .cc-flipback { background: none; border: 0; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; font: 700 11px/1 var(--font-display); letter-spacing: .06em; text-transform: uppercase; color: var(--faint); transition: color .15s; }
  .cc-flipback:hover { color: var(--ink); }
  .cc-backtitle { font: 800 20px/1.1 var(--font-display); letter-spacing: -.01em; color: var(--ink); margin: 0 0 10px; }
  .cc-backbody { font: 400 13px/1.5 var(--font-body); color: #4a4843; margin: 0 0 14px; }
  .cc-specs { margin-top: auto; display: flex; flex-direction: column; }
  .cc-spec { display: grid; grid-template-columns: max-content 1fr; gap: 14px; padding: 8px 0; border-top: 1px solid #efeee8; }
  .cc-spec-l { font: 700 10px/1.4 var(--font-display); letter-spacing: .07em; text-transform: uppercase; color: var(--cat-ink); white-space: nowrap; }
  .cc-spec-v { font: 600 13px/1.3 var(--font-body); color: var(--text-2); }
  .cc-back .cc-act { margin-top: 16px; }
</style>

<script>
  document.querySelectorAll('.cc.flippable').forEach((card) => {
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) return;
      card.classList.toggle('flipped');
      card.setAttribute('aria-pressed', card.classList.contains('flipped') ? 'true' : 'false');
    });
  });
</script>
