---
interface Card {
  theme: 'dark' | 'light';
  eyebrow: string;
  title: string;
  icon: string;
  href: string;
}
interface Props { cards: Card[]; }
const { cards } = Astro.props;
---
<div class="ctab" style={`--cols:${cards.length}`}>
  {cards.map((c) => (
    <a href={c.href} class:list={['ctab-card', c.theme]}>
      <div class="ctab-left">
        <span class="ctab-icon"><i class={`bi ${c.icon}`} aria-hidden="true"></i></span>
        <div>
          <div class="ctab-eyebrow">{c.eyebrow}</div>
          <div class="ctab-title">{c.title}</div>
        </div>
      </div>
      <i class="bi bi-arrow-right ctab-arrow" aria-hidden="true"></i>
    </a>
  ))}
</div>

<style>
  .ctab { display: grid; grid-template-columns: repeat(var(--cols), 1fr); gap: 18px; }
  .ctab-card { text-decoration: none; display: flex; align-items: center; justify-content: space-between; gap: 18px; border-radius: 16px; padding: 28px 30px; box-shadow: var(--shadow-sm); transition: transform .18s ease; }
  .ctab-card:hover { transform: translateY(-3px); }
  .ctab-card:hover .ctab-arrow { transform: translateX(4px); }
  .ctab-left { display: flex; align-items: center; gap: 18px; }
  .ctab-icon { flex: none; width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
  .ctab-eyebrow { font: 700 11px/1 var(--font-display); letter-spacing: .13em; text-transform: uppercase; margin-bottom: 8px; }
  .ctab-title { font: 800 23px/1.05 var(--font-display); letter-spacing: -.012em; }
  .ctab-arrow { font-size: 22px; flex: none; transition: transform .18s ease; }

  .ctab-card.dark { background: var(--ink); color: #fff; border: 0; }
  .ctab-card.dark .ctab-icon { background: rgba(255,255,255,.1); color: var(--brand); }
  .ctab-card.dark .ctab-eyebrow { color: var(--brand); }
  .ctab-card.dark .ctab-arrow { color: var(--brand); }

  .ctab-card.light { background: #fff; color: var(--ink); border: 1px solid var(--line); }
  .ctab-card.light .ctab-icon { background: color-mix(in srgb, var(--brand) 22%, #fff); color: var(--ink); }
  .ctab-card.light .ctab-eyebrow { color: var(--faint); }
  .ctab-card.light .ctab-arrow { color: var(--ink); }

  @media (max-width: 720px) { .ctab { grid-template-columns: 1fr; } }
</style>
