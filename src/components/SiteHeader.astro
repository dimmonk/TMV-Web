---
import { nav, links, url, site } from '../data/site';
interface Props { active?: string; }
const { active = '' } = Astro.props;
---
<header class="sh" data-chrome="site">
  <div class="sh-bar container">
    <a href={url('')} class="sh-brand" aria-label={`${site.name} — home`}>
      <img src={url('assets/tmvlogo.png')} alt="" width="40" height="40" />
      <span class="sh-word">The&nbsp;Monkey&nbsp;Vault</span>
    </a>

    <nav class="sh-nav" aria-label="Primary">
      {nav.map((n) => (
        <a href={url(n.path)} class:list={['sh-link', { on: n.key === active }]} aria-current={n.key === active ? 'page' : undefined}>{n.label}</a>
      ))}
    </nav>

    <div class="sh-actions">
      <a href={url('get-started')} class="sh-new"><i class="bi bi-flag" aria-hidden="true"></i> New here?</a>
      <a href={url('book')} class="sh-cta">Book Now</a>
      <button class="sh-burger" aria-label="Menu" aria-expanded="false" aria-controls="sh-menu">
        <i class="bi bi-list" aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <nav id="sh-menu" class="sh-menu" aria-label="Mobile">
    {nav.map((n) => (
      <a href={url(n.path)} class:list={['sh-mlink', { on: n.key === active }]}>{n.label}</a>
    ))}
    <a href={url('get-started')} class="sh-mlink accent"><i class="bi bi-flag" aria-hidden="true"></i> New here? Start here</a>
    <a href={url('book')} class="sh-mlink accent"><i class="bi bi-calendar-check" aria-hidden="true"></i> Book Now</a>
  </nav>
</header>

<style>
  .sh { position: sticky; top: 0; z-index: 50; background: var(--ink); border-bottom: 1px solid rgba(255,255,255,.08); }
  .sh-bar { height: 66px; display: flex; align-items: center; gap: 20px; }
  .sh-brand { display: flex; align-items: center; gap: 12px; text-decoration: none; flex-shrink: 0; }
  .sh-brand img { width: 40px; height: 40px; object-fit: contain; }
  .sh-word { font: 900 18px/1 var(--font-display); letter-spacing: .02em; color: var(--brand); text-transform: uppercase; }

  .sh-nav { display: flex; align-items: center; gap: 22px; margin-left: auto; }
  .sh-link { position: relative; font: 600 13.5px/1 var(--font-body); color: rgba(255,255,255,.65); text-decoration: none; padding-bottom: 3px; transition: color .15s; }
  .sh-link:hover { color: #fff; }
  .sh-link.on { color: #fff; font-weight: 700; }
  .sh-link.on::after { content: ''; position: absolute; left: 0; right: 0; bottom: -23px; height: 3px; background: var(--brand); }

  .sh-actions { display: flex; align-items: center; gap: 10px; flex-shrink: 0; margin-left: auto; }
  .sh-new { display: inline-flex; align-items: center; gap: 6px; font: 700 12.5px/1 var(--font-display); text-transform: uppercase; letter-spacing: .03em; color: rgba(255,255,255,.72); text-decoration: none; padding: 9px 13px; border-radius: 8px; border: 1px solid rgba(255,255,255,.2); white-space: nowrap; transition: all .15s; }
  .sh-new:hover { color: #fff; border-color: rgba(255,255,255,.4); }
  .sh-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--brand); color: var(--ink); font: 800 13px/1 var(--font-display); text-transform: uppercase; letter-spacing: .03em; text-decoration: none; padding: 11px 15px; border-radius: 9px; white-space: nowrap; transition: transform .15s; }
  .sh-cta:hover { transform: translateY(-1px); }

  .sh-burger { display: none; align-items: center; justify-content: center; width: 42px; height: 42px; flex-shrink: 0; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.16); border-radius: 9px; color: #fff; font-size: 20px; cursor: pointer; padding: 0; }
  .sh-burger:hover { background: rgba(255,255,255,.14); }

  .sh-menu { display: none; flex-direction: column; padding: 6px 24px 18px; background: var(--ink); border-top: 1px solid rgba(255,255,255,.08); }
  .sh-mlink { display: flex; align-items: center; gap: 9px; font: 600 16px/1 var(--font-display); color: rgba(255,255,255,.72); text-decoration: none; padding: 14px 4px; border-bottom: 1px solid rgba(255,255,255,.07); transition: color .15s; }
  .sh-mlink:hover { color: #fff; }
  .sh-mlink.on { color: #fff; font-weight: 800; }
  .sh-mlink.accent { color: var(--brand); border-bottom: 0; }

  /* The full nav (brand + 6 links + New here? + Book Now) genuinely doesn't
     fit until ~925px (measured) — 820px left a real gap where it overflowed
     the header horizontally. 960px gives a safe margin above that. */
  @media (max-width: 960px) {
    .sh-nav, .sh-new { display: none; }
    .sh-burger { display: inline-flex; }
    .sh-menu.open { display: flex; }
  }
  @media (max-width: 460px) { .sh-word { display: none; } }
</style>

<script>
  // Progressive enhancement: toggle the mobile menu.
  {
    const burger = document.querySelector('.sh-burger');
    const menu = document.getElementById('sh-menu');
    burger?.addEventListener('click', () => {
      const open = menu?.classList.toggle('open');
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
      burger.querySelector('i')?.setAttribute('class', open ? 'bi bi-x-lg' : 'bi bi-list');
    });
  }
</script>
