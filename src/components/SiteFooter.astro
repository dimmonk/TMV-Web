---
import { site, social, links, url } from '../data/site';
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Explore',
    items: [
      { text: 'Train', href: url('train') },
      { text: 'Camps', href: url('camps') },
      { text: 'Events', href: url('events') },
      { text: 'Pricing', href: url('pricing') },
      { text: 'About', href: url('about') },
    ],
  },
  {
    title: 'Visit',
    items: [
      { text: site.address.street, static: true },
      { text: `${site.address.locality}, ${site.address.region}`, static: true },
      { text: site.hoursLabel, static: true },
      { text: 'New here? Get started', href: url('get-started'), accent: true },
    ],
  },
  {
    title: 'Book',
    items: [
      { text: 'Book a session', href: url('book') },
      { text: 'Passes & Pricing', href: url('pricing') },
      { text: 'Online store', href: url('store') },
      { text: 'Gift cards', href: links.giftCard, ext: true },
    ],
  },
];

const socials = [
  { icon: 'bi-instagram', label: 'Instagram', href: social.instagram },
  { icon: 'bi-facebook', label: 'Facebook', href: social.facebook },
  { icon: 'bi-youtube', label: 'YouTube', href: social.youtube },
].filter((s) => s.href);
---
<footer class="sf" data-chrome="site">
  <div class="sf-grid container">
    <div>
      <div class="sf-brand">
        <img src={url('assets/tmvlogo.png')} alt="" width="38" height="38" />
        <span>The Monkey Vault</span>
      </div>
      <p class="sf-blurb">Toronto's home for parkour, flips and movement. Train, play and level up — every age, every level.</p>
      <div class="sf-socials">
        {socials.map((s) => (
          <a href={s.href} aria-label={s.label} class="sf-soc" target="_blank" rel="noopener"><i class={`bi ${s.icon}`} aria-hidden="true"></i></a>
        ))}
      </div>
    </div>

    {columns.map((col) => (
      <div>
        <div class="sf-coltitle">{col.title}</div>
        <div class="sf-collist">
          {col.items.map((l) => (
            l.static
              ? <span class="sf-text">{l.text}</span>
              : <a href={l.href} class:list={['sf-link', { accent: l.accent }]} {...(l.ext ? { target: '_blank', rel: 'noopener' } : {})}>{l.text}</a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="sf-legal container">
    <span>© {year} {site.legalName} All rights reserved.</span>
    <span>Parkour &amp; Movement Training Centre · Toronto</span>
  </div>
</footer>

<style>
  .sf { background: var(--ink-2); color: rgba(255,255,255,.6); }
  .sf-grid { padding-block: 54px 32px; display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 40px; }
  .sf-brand { display: flex; align-items: center; gap: 11px; margin-bottom: 16px; }
  .sf-brand img { width: 38px; height: 38px; object-fit: contain; }
  .sf-brand span { font: 900 16px/1 var(--font-display); color: var(--brand); text-transform: uppercase; }
  .sf-blurb { font: 400 13px/1.5 var(--font-body); color: rgba(255,255,255,.55); max-width: 300px; }
  .sf-socials { display: flex; gap: 10px; margin-top: 18px; }
  .sf-soc { width: 36px; height: 36px; border-radius: 9px; background: rgba(255,255,255,.08); display: inline-flex; align-items: center; justify-content: center; color: #fff; text-decoration: none; transition: all .15s; }
  .sf-soc:hover { background: var(--brand); color: var(--ink); }

  .sf-coltitle { font: 700 11px/1 var(--font-display); letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 15px; }
  .sf-collist { display: flex; flex-direction: column; gap: 10px; }
  .sf-text { font: 500 13px/1.5 var(--font-body); color: rgba(255,255,255,.6); }
  .sf-link { font: 500 13px/1.3 var(--font-body); color: rgba(255,255,255,.6); text-decoration: none; transition: color .15s; }
  .sf-link:hover { color: var(--brand); }
  .sf-link.accent { color: var(--brand); font-weight: 700; }

  .sf-legal { padding-block: 20px; border-top: 1px solid rgba(255,255,255,.08); display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; font: 500 12.5px/1.5 var(--font-body); color: rgba(255,255,255,.35); }

  @media (max-width: 720px) { .sf-grid { grid-template-columns: 1fr 1fr; gap: 34px 24px; } }
  @media (max-width: 440px) { .sf-grid { grid-template-columns: 1fr; } }
</style>
